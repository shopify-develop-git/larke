/*
 * Horizon's stock `main-blog-post` is replaced by our own dev-article section. The stock one
 * renders a system-font heading on a white page with a square full-bleed image and matches
 * nothing else in the theme. Project rule: custom dev-* sections only — stock sections are
 * never used or edited. Original stock config: git history of this file.
 */
{
  "sections": {
    "dev-article": {
      "type": "dev-article",
      "settings": {
        "back_label": "Back to Journal",
        "read_time_label": "min read",
        "author_prefix": "By",
        "show_date": true,
        "background_color": "rgba(0,0,0,0)",
        "text_color": "#333333",
        "meta_color": "#666666",
        "badge_color": "#FCF5E3",
        "rule_color": "#C4BCA9",
        "padding_top": 48,
        "padding_bottom": 80
      }
    }
  },
  "order": [
    "dev-article"
  ]
}
