{% schema %}
{
  "name": "Cart drawer",
  "tag": null,
  "settings": [
    { "type": "header", "content": "Content" },
    { "type": "paragraph", "content": "The feature badges under each line are no longer configured here. They come from the product's Cart badges metafield (larke.cart_badges), so each line in the basket shows its OWN product's badges. Each badge entry carries a label plus either one of the theme's icons or an uploaded image." },
    { "type": "inline_richtext", "id": "heading", "label": "Heading", "default": "Your Order" },
    { "type": "text", "id": "close_label", "label": "Close button label (screen readers only)", "default": "Close basket" },
    { "type": "text", "id": "remove_label", "label": "Remove link label", "default": "Remove" },
    { "type": "text", "id": "quantity_label", "label": "Quantity label", "default": "Qty" },
    { "type": "text", "id": "empty_text", "label": "Empty basket message", "default": "Your basket is empty." },
    { "type": "text", "id": "continue_label", "label": "Empty basket button label", "default": "Continue shopping", "info": "Leave empty to show no button." },
    { "type": "url", "id": "continue_url", "label": "Empty basket button link", "info": "Leave empty to use the all-products collection." },
    { "type": "text", "id": "checkout_label", "label": "Checkout button label", "default": "Checkout Securely" },
    { "type": "url", "id": "checkout_url", "label": "Checkout link", "info": "Leave empty to use the store's checkout." },
    { "type": "text", "id": "payment_label", "label": "Payment methods label", "default": "Accepted payment methods" },

    { "type": "header", "content": "Payment icons" },
    {
      "type": "select",
      "id": "payment_icons_source",
      "label": "Icon source",
      "default": "dynamic",
      "info": "Real: the marks Shopify actually enables at checkout — Shopify's own artwork, always accurate, no maintenance. Brand: a fixed set matched to the Figma artwork, updated in code if payment methods change.",
      "options": [
        { "value": "dynamic", "label": "Real (enabled payment methods)" },
        { "value": "custom", "label": "Brand icons (fixed set)" }
      ]
    },

    { "type": "header", "content": "Colors" },
    { "type": "color", "id": "background_color", "label": "Background", "default": "#FFFCF4" },
    { "type": "color", "id": "text_color", "label": "Text color", "default": "#333333" },
    { "type": "color", "id": "card_color", "label": "Line item card background", "default": "#FCF5E3" },
    { "type": "color", "id": "badge_color", "label": "Feature badge background", "default": "#FFFCF4" },
    { "type": "color", "id": "header_divider_color", "label": "Header divider", "default": "#D8D1C0" },
    { "type": "color", "id": "header_divider_color_mobile", "label": "Header divider (mobile)", "default": "#C4BCA9", "info": "The mobile artboard uses a darker divider than desktop." },
    { "type": "color", "id": "footer_divider_color", "label": "Footer divider", "default": "#D8D1C0" },
    { "type": "color", "id": "cta_color", "label": "Checkout button fill", "default": "#343434" },
    { "type": "range", "id": "cta_opacity", "min": 0, "max": 100, "step": 1, "unit": "%", "label": "Checkout button fill opacity", "default": 66, "info": "The Figma fill is a translucent dark neutral, not a solid accent." },
    { "type": "color", "id": "cta_text_color", "label": "Checkout button text & border", "default": "#FFFFFF" },
    { "type": "color", "id": "backdrop_color", "label": "Backdrop color", "default": "#333333" },
    { "type": "range", "id": "backdrop_opacity", "min": 0, "max": 100, "step": 5, "unit": "%", "label": "Backdrop opacity", "default": 40, "info": "No scrim was authored in Figma — set to taste." },

    { "type": "header", "content": "Spacing" },
    { "type": "range", "id": "padding_top", "min": 0, "max": 100, "step": 4, "unit": "px", "label": "Padding top", "default": 32 },
    { "type": "range", "id": "padding_bottom", "min": 0, "max": 100, "step": 4, "unit": "px", "label": "Padding bottom", "default": 32 },

    { "type": "header", "content": "Layout" },
    { "type": "checkbox", "id": "open_on_load", "label": "Open on page load", "default": false, "info": "Preview only — lets the drawer be designed in the editor. Leave off in production." }
  ]
}
{% endschema %}
