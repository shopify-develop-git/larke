{%- comment -%}
  dev-button — the shared button/CTA component.

  Renders an <a> when `link` is present, otherwise a <button>. Styling lives entirely
  in assets/dev-button.css (loaded globally from layout/theme.liquid). This snippet only
  assembles the correct classes and the label/icon.

  Use it for simple label CTAs. Composite buttons (add-to-cart with a price divider,
  cart checkout with an icon) adopt the `.dev-btn` classes on their own markup instead —
  they need inner structure a snippet can't express.

  Parameters
  ----------
  variant       filled | dark | outline | ghost | text   (default: filled)
  label         button text (required unless `content` is passed)
  link          href — when present renders <a>, else <button>
  type          <button> type: button | submit           (default: button)
  full          true -> full width (.dev-btn--full)
  icon          raw inline SVG string for an icon slot    (optional)
  icon_left     true -> icon before the label (.dev-btn--icon-left)  (default: after)
  class         extra classes to add (section BEM class for token overrides / JS hooks)
  id            element id                                (optional)
  aria_label    aria-label                               (optional)
  target        <a> target                               (optional)
  rel           <a> rel                                  (optional)
  disabled      true -> disabled attribute (button)       (optional)
  attrs         raw extra attributes string (e.g. data-*) (optional)
{%- endcomment -%}

{%- liquid
  assign v = variant | default: 'filled'
  assign btn_class = 'dev-btn dev-btn--' | append: v
  if full
    assign btn_class = btn_class | append: ' dev-btn--full'
  endif
  if icon != blank and icon_left
    assign btn_class = btn_class | append: ' dev-btn--icon-left'
  endif
  if class != blank
    assign btn_class = btn_class | append: ' ' | append: class
  endif
-%}

{%- capture inner -%}
  {%- if icon != blank and icon_left -%}<span class="dev-btn__icon">{{ icon }}</span>{%- endif -%}
  {%- if label != blank -%}<span class="dev-btn__label">{{ label }}</span>{%- endif -%}
  {%- if icon != blank and icon_left != true -%}<span class="dev-btn__icon">{{ icon }}</span>{%- endif -%}
{%- endcapture -%}

{%- if link != blank -%}
  <a
    class="{{ btn_class }}"
    href="{{ link }}"
    {%- if id != blank %} id="{{ id }}"{% endif -%}
    {%- if aria_label != blank %} aria-label="{{ aria_label | escape }}"{% endif -%}
    {%- if target != blank %} target="{{ target }}"{% endif -%}
    {%- if rel != blank %} rel="{{ rel }}"{% endif -%}
    {%- if attrs != blank %} {{ attrs }}{% endif -%}
  >{{ inner }}</a>
{%- else -%}
  <button
    class="{{ btn_class }}"
    type="{{ type | default: 'button' }}"
    {%- if id != blank %} id="{{ id }}"{% endif -%}
    {%- if aria_label != blank %} aria-label="{{ aria_label | escape }}"{% endif -%}
    {%- if disabled %} disabled{% endif -%}
    {%- if attrs != blank %} {{ attrs }}{% endif -%}
  >{{ inner }}</button>
{%- endif -%}
