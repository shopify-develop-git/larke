{{ 'dev-wash-dry-repeat.css' | asset_url | stylesheet_tag }}
{%- comment -%}
  No JS: the Brief's Interactivity section is "none" — both tiles are static (no arrows,
  dots, or off-screen frames at either breakpoint) and the CTA is a plain link.

  No inline SVG: this section has no vector artwork in Figma. The only assets are the two
  raster promo photos, uploaded to Shopify Files by the Assets stage. There is therefore
  no .figma-assets/wash-dry-repeat/ ground truth and nothing for svg-fidelity to verify —
  and, deliberately, not a single hand-authored <path> below.
{%- endcomment -%}

{%- comment -%} Fixed design tokens from Figma — not merchant-controlled {%- endcomment -%}
<style>
  .wash-dry-repeat {
    /* Brand params (Design Brief → Brand Params table) */
    --container-max: 1312px;
    --section-px: 64px;
    --section-px-m: 16px;

    /* Typography — desktop */
    --font-heading-size: 32px;
    --font-heading-weight: 500;
    --font-heading-lh: 1.2;
    --font-body-size: 18px;
    --font-body-weight: 500;
    --font-body-lh: 1.4;
    --font-button-size: 18px;
    --font-button-weight: 700;
    --font-button-lh: 1.4;

    /* Typography — mobile (from the Mobile artboard, not a scale factor) */
    --font-heading-size-m: 24px;
    --font-body-size-m: 16px;
    --font-button-size-m: 16px;

    /* Spacing — desktop */
    --spacing-sm: 16px; /* heading → body */
    --spacing-md: 24px; /* text block → button */
    --spacing-lg: 32px; /* tile → tile */

    /* Spacing — mobile */
    --spacing-sm-m: 8px; /* heading → body */
    --spacing-md-m: 24px; /* text → images → button (same value reused twice) */
    --spacing-lg-m: 16px; /* tile → tile */

    /* 80px desktop → 48px mobile, kept proportional to the merchant's padding_top */
    --pt-scale-m: 0.6;

    /* Layout */
    --images-w: 640px; /* fixed-width image block, flush left; text takes the rest */
    --tile-ratio: 304 / 412; /* 2 tiles + 32px gap = 640px exactly */
    --tile-h-m: 220px; /* mobile tiles are a fixed height, per the Mobile artboard */
    --text-max: 341px;

    /* Decoration */
    --radius-image: 16px;
    --radius-button: 60px;
    --border-image: 1px; /* desktop only — dropped at mobile (Brief, Note 2) */
    --button-px: 24px;
    --button-py: 18px;
    --button-px-m: 18px;
    --button-py-m: 12px;
  }
</style>

{%- liquid
  assign button_link = section.settings.button_link
  if button_link == blank
    assign button_link = routes.root_url
  endif
-%}

<div
  class="wash-dry-repeat"
  style="
    --bg: {{ section.settings.background_color }};
    --color: {{ section.settings.text_color }};
    --accent: {{ section.settings.accent_color }};
    --pt: {{ section.settings.padding_top }}px;
    --pb: {{ section.settings.padding_bottom }}px;
  "
>
  <div class="wash-dry-repeat__inner">
    {%- if section.blocks.size > 0 -%}
      <div class="wash-dry-repeat__images">
        {%- for block in section.blocks -%}
          <figure class="wash-dry-repeat__tile" {{ block.shopify_attributes }}>
            {%- if block.settings.image != blank -%}
              {%- liquid
                assign image = block.settings.image
                assign image_alt = block.settings.alt_text
                if image_alt == blank
                  assign image_alt = image.alt
                endif
                assign image_alt = image_alt | default: '' | escape
              -%}
              {{
                image
                | image_url: width: 640
                | image_tag:
                  loading: 'lazy',
                  widths: '164, 240, 304, 328, 480, 608, 640',
                  sizes: '(min-width: 1025px) 304px, (min-width: 769px) 25vw, calc(50vw - 24px)',
                  alt: image_alt,
                  class: 'wash-dry-repeat__image'
              }}
            {%- endif -%}
          </figure>
        {%- endfor -%}
      </div>
    {%- endif -%}

    {%- comment -%}
      Desktop: this column sits to the right of the image block. Mobile: it becomes
      `display: contents` so heading/body and the button can sit either side of the
      image row in the single column stack (Brief, Note 3 — a genuine reflow).
    {%- endcomment -%}
    <div class="wash-dry-repeat__content">
      {%- if section.settings.heading != blank or section.settings.body_text != blank -%}
        <div class="wash-dry-repeat__text">
          {%- if section.settings.heading != blank -%}
            <h2 class="wash-dry-repeat__heading">{{ section.settings.heading }}</h2>
          {%- endif -%}

          {%- if section.settings.body_text != blank -%}
            <div class="wash-dry-repeat__body">
              {{- section.settings.body_text -}}
            </div>
          {%- endif -%}
        </div>
      {%- endif -%}

      {%- if section.settings.button_label != blank -%}
        {%- render 'dev-button',
          variant: 'outline',
          label: section.settings.button_label | escape,
          link: button_link,
          class: 'wash-dry-repeat__button'
        -%}
      {%- endif -%}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Image and text promo",
  "tag": "section",
  "presets": [
    {
      "name": "Image and text promo",
      "blocks": [{ "type": "promo_image" }, { "type": "promo_image" }]
    }
  ],
  "settings": [
    { "type": "header", "content": "Content" },
    { "type": "inline_richtext", "id": "heading", "label": "Heading", "default": "Wash. Dry. Repeat." },
    {
      "type": "richtext",
      "id": "body_text",
      "label": "Body text",
      "info": "Line breaks are preserved.",
      "default": "<p>Fuss-free comfort.<br/>Fresh again by bedtime.</p>"
    },
    { "type": "text", "id": "button_label", "label": "Button label", "default": "Discover Tree-Fibre" },
    { "type": "url", "id": "button_link", "label": "Button link" },

    { "type": "header", "content": "Colors" },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background",
      "info": "Transparent by default — the section inherits the page background.",
      "default": "rgba(0,0,0,0)"
    },
    { "type": "color", "id": "text_color", "label": "Text color", "default": "#333333" },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Accent color",
      "info": "Image border. Desktop only.",
      "default": "#C4BCA9"
    },

    { "type": "header", "content": "Spacing" },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px",
      "label": "Padding top",
      "default": 80
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px",
      "label": "Padding bottom",
      "default": 0
    }
  ],
  "blocks": [
    {
      "type": "promo_image",
      "name": "Promo image",
      "limit": 2,
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Image" },
        {
          "type": "text",
          "id": "alt_text",
          "label": "Alt text",
          "info": "Falls back to the image's own alt text."
        }
      ]
    }
  ],
  "max_blocks": 2
}
{% endschema %}
