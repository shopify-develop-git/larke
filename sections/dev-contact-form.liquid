{{ 'dev-contact-form.css' | asset_url | stylesheet_tag }}

{%- comment -%} Fixed design tokens from Figma — not merchant-controlled {%- endcomment -%}
<style>
  .dev-contact-form {
    --font-body: 'Public Sans', sans-serif;
    --font-heading: 'Test Tiempos Headline', serif;

    --font-title-size: 32px;
    --font-title-size-mobile: 24px;
    --font-heading-weight: 500;
    --font-heading-lh: 1.2;

    --font-body-size: 18px;
    --font-field-size: 16px;
    --font-body-weight: 500;
    --font-body-lh: 1.4;
    --font-button-weight: 700;

    --card-radius: 32px;
    --card-pad: 32px;
    --card-pad-mobile: 24px;
    --card-gap: 16px;

    /* Fluid, not stepped. A single breakpoint at 1024 left 1025–1200 holding the full 533px card
       AND the full 136px gutter, so the form was squeezed to ~228px at 1025 — the worst point on
       the curve sat just ABOVE the breakpoint meant to fix it. The vw terms are the artboard ratios
       (64/1440, 136/1440, 533/1440), so at 1440 they resolve to exactly 64 / 136 / 533 and the pixel
       reference is untouched; below that everything scales together. */
    --section-px: clamp(24px, 4.4444vw, 64px);
    --section-py: 40px;
    --col-gap: clamp(40px, 9.4444vw, 136px);
    --card-w: clamp(280px, 37.0139vw, 533px);

    --section-px-mobile: 16px;
    --section-py-mobile: 16px;
    --stack-gap-mobile: 24px;

    /* The Figma "Input Fields" component exposes no layout of its own, so these are measured off
       the 1:1 render (45246:3826): 58px tall, 1px #666666 stroke, transparent fill, text 18px from
       the top edge and 20px from the left. Radius fitted to the corner arc — 4px, NOT the footer
       input's 8px.

       The padding is short of those insets ON PURPOSE. Figma draws a stroke INSIDE the box, so its
       padding is measured from the outer edge. CSS puts the border OUTSIDE the padding, so
       border + padding must add up to the Figma inset. Using the inset directly makes every field
       2px too big and shifts the text 1px.

       And the block padding is 16.8, not 17. The real inset is not a round 18: a 58px box holding a
       16px/1.4 line (22.4px) leaves (58 - 22.4) / 2 = 17.8px a side. Rounding that to 18 left the
       content box 0.4px shorter than its own line, and a textarea whose content overflows by any
       amount grows a scrollbar — visible even when the field is empty. 1 + 16.8 = 17.8 makes the
       line fit exactly, and the scrollbar goes away at the root instead of being hidden. */
    --field-h: 58px;
    --field-pad: 16.8px 19px;
    --field-radius: 4px;
    --field-border-w: 1px;

    --field-gap: 8px;
    --form-gap: 16px;

    /* Same inside-stroke correction: the button is 148x46 with a 1px white stroke and its label
       12px/18px from the outer edge, so 1 + 11 = 12 and 1 + 17 = 18. */
    --button-pad: 11px 17px;
    --button-radius: 60px;
    --button-border-w: 1px;
  }
</style>

{%- liquid
  assign button_alpha = section.settings.button_opacity | divided_by: 100.0
  assign button_fill = section.settings.button_color | color_modify: 'alpha', button_alpha
-%}

{%- comment -%}
  Contact. 45246:3640 (desktop) / 45246:1199 (mobile).

  Desktop: cream card on the left (sticky), the form on the right.
  Mobile:  the card becomes a full-width banner holding ONLY the centred heading, and its body
           copy drops out of the card to sit underneath it as plain copy — then the form.

  That reflow is done with `display: contents` on the card at <=768 rather than by rendering
  the copy twice. Duplicating it would put the same paragraph in the DOM twice, which screen
  readers and search engines both read as two paragraphs.
{%- endcomment -%}
<div
  class="dev-contact-form"
  style="
    --bg: {{ section.settings.background_color }};
    --color: {{ section.settings.text_color }};
    --card-bg: {{ section.settings.card_color }};
    --field-border: {{ section.settings.field_border_color }};
    --field-placeholder: {{ section.settings.placeholder_color }};
    --button-bg: {{ button_fill }};
    --button-color: {{ section.settings.button_text_color }};
    --pt: {{ section.settings.padding_top }}px;
    --pb: {{ section.settings.padding_bottom }}px;
  "
>
  <div class="dev-contact-form__inner">
    <div class="dev-contact-form__card">
      {%- if section.settings.title != blank -%}
        {%- comment -%} inline_richtext: already safe HTML from Shopify — never escape it. {%- endcomment -%}
        <h2 class="dev-contact-form__title">{{ section.settings.title }}</h2>
      {%- endif -%}

      {%- if section.settings.body != blank -%}
        <div class="dev-contact-form__body">{{ section.settings.body }}</div>
      {%- endif -%}
    </div>

    <div class="dev-contact-form__col">
      {%- form 'contact', class: 'dev-contact-form__form' -%}
        {%- if form.posted_successfully? -%}
          <p class="dev-contact-form__success" role="status">
            {{- section.settings.success_text | escape -}}
          </p>
        {%- endif -%}

        {%- if form.errors -%}
          <div class="dev-contact-form__errors" role="alert">
            {{ form.errors | default_errors }}
          </div>
        {%- endif -%}

        <div class="dev-contact-form__fields">
          <div class="dev-contact-form__row">
            <div class="dev-contact-form__field">
              <label class="dev-contact-form__label" for="contact-name">
                {{- section.settings.name_placeholder | escape -}}
              </label>
              <input
                id="contact-name"
                class="dev-contact-form__input"
                type="text"
                name="contact[name]"
                value="{{ form.name }}"
                placeholder="{{ section.settings.name_placeholder | escape }}"
                autocomplete="name"
              >
            </div>

            <div class="dev-contact-form__field">
              <label class="dev-contact-form__label" for="contact-email">
                {{- section.settings.email_placeholder | escape -}}
              </label>
              <input
                id="contact-email"
                class="dev-contact-form__input"
                type="email"
                name="contact[email]"
                value="{{ form.email }}"
                placeholder="{{ section.settings.email_placeholder | escape }}"
                autocomplete="email"
                autocorrect="off"
                autocapitalize="off"
                spellcheck="false"
                required
              >
            </div>
          </div>

          <div class="dev-contact-form__field">
            <label class="dev-contact-form__label" for="contact-body">
              {{- section.settings.message_placeholder | escape -}}
            </label>
            <textarea
              id="contact-body"
              class="dev-contact-form__input dev-contact-form__input--textarea"
              name="contact[body]"
              placeholder="{{ section.settings.message_placeholder | escape }}"
              required
            >{{ form.body }}</textarea>
          </div>
        </div>

        <button type="submit" class="dev-contact-form__button">
          {{- section.settings.button_label | escape -}}
        </button>
      {%- endform -%}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Contact form",
  "tag": "section",
  "settings": [
    { "type": "header", "content": "Content" },
    { "type": "inline_richtext", "id": "title", "label": "Title", "default": "Contact" },
    { "type": "richtext", "id": "body", "label": "Intro copy", "default": "<p>Lorem ipsum dolor sit amet, consectetur adipiscing elit.</p>" },
    { "type": "text", "id": "name_placeholder", "label": "Name field label", "default": "Your name" },
    { "type": "text", "id": "email_placeholder", "label": "Email field label", "default": "Your email" },
    { "type": "text", "id": "message_placeholder", "label": "Message field label", "default": "Your message" },
    { "type": "text", "id": "button_label", "label": "Button label", "default": "Send message" },
    { "type": "text", "id": "success_text", "label": "Success message", "default": "Thanks — we’ll be in touch shortly." },

    { "type": "header", "content": "Colors" },
    { "type": "color", "id": "background_color", "label": "Background", "default": "#FFFCF4" },
    { "type": "color", "id": "text_color", "label": "Text color", "default": "#333333" },
    { "type": "color", "id": "card_color", "label": "Card background", "default": "#FCF5E3" },
    { "type": "color", "id": "field_border_color", "label": "Field border", "default": "#666666" },
    { "type": "color", "id": "placeholder_color", "label": "Placeholder text", "default": "#666666" },
    { "type": "color", "id": "button_color", "label": "Button fill", "default": "#343434" },
    { "type": "range", "id": "button_opacity", "min": 0, "max": 100, "step": 1, "unit": "%", "label": "Button fill opacity", "default": 66, "info": "The Figma fill is a translucent dark neutral, not a solid." },
    { "type": "color", "id": "button_text_color", "label": "Button text & border", "default": "#FFFFFF" },

    { "type": "header", "content": "Spacing" },
    { "type": "range", "id": "padding_top", "min": 0, "max": 120, "step": 4, "unit": "px", "label": "Padding top", "default": 0 },
    { "type": "range", "id": "padding_bottom", "min": 0, "max": 120, "step": 4, "unit": "px", "label": "Padding bottom", "default": 0 }
  ],
  "presets": [
    { "name": "Contact form" }
  ]
}
{% endschema %}
