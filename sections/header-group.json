{
  "type": "header",
  "name": "Header",
  "sections": {
    "dev-announcement-bar": {
      "type": "dev-announcement-bar",
      "settings": {
        "background_color": "#FCF5E3",
        "text_color": "#333333",
        "accent_color": "#333333",
        "padding_top": 12,
        "padding_bottom": 12
      },
      "blocks": {
        "link-delivery": {
          "type": "link",
          "settings": {
            "label": "Delivery",
            "url": "/pages/delivery",
            "position": "left"
          }
        },
        "link-returns": {
          "type": "link",
          "settings": {
            "label": "Returns",
            "url": "/pages/returns",
            "position": "left"
          }
        },
        "message-trial": {
          "type": "message",
          "settings": {
            "text": "Safe 60-Night Trial"
          }
        },
        "message-delivery": {
          "type": "message",
          "settings": {
            "text": "Free UK Delivery"
          }
        },
        "link-faqs": {
          "type": "link",
          "settings": {
            "label": "FAQs",
            "url": "/pages/faqs",
            "position": "right"
          }
        },
        "link-contact": {
          "type": "link",
          "settings": {
            "label": "Contact",
            "url": "/pages/contact",
            "position": "right"
          }
        }
      },
      "block_order": [
        "link-delivery",
        "link-returns",
        "message-trial",
        "message-delivery",
        "link-faqs",
        "link-contact"
      ]
    },
    "dev-site-header": {
      "type": "dev-site-header",
      "settings": {
        "logo_width": 140,
        "show_cart_count": true,
        "background_color": "#FFFCF4",
        "text_color": "#333333",
        "accent_color": "#4EA448",
        "padding_top": 24,
        "padding_bottom": 24
      },
      "blocks": {
        "menu-drawer": {
          "type": "dev-menu-drawer",
          "blocks": {
            "nav": {
              "type": "dev-menu-drawer-nav",
              "blocks": {
                "nav-link-1": {
                  "type": "dev-menu-drawer-nav-link",
                  "settings": {
                    "label": "Shop Our Duvet",
                    "link": "/collections/all"
                  }
                },
                "nav-link-2": {
                  "type": "dev-menu-drawer-nav-link",
                  "settings": {
                    "label": "Our Story",
                    "link": "/pages/our-story"
                  }
                },
                "nav-link-3": {
                  "type": "dev-menu-drawer-nav-link",
                  "settings": {
                    "label": "Discover Tree-Fibre",
                    "link": "/pages/tree-fibre"
                  }
                }
              },
              "block_order": [
                "nav-link-1",
                "nav-link-2",
                "nav-link-3"
              ],
              "settings": {}
            },
            "footer": {
              "type": "dev-menu-drawer-footer",
              "blocks": {
                "footer-link-1": {
                  "type": "dev-menu-drawer-footer-link",
                  "settings": {
                    "label": "FAQs",
                    "link": "/pages/faqs"
                  }
                },
                "footer-link-2": {
                  "type": "dev-menu-drawer-footer-link",
                  "settings": {
                    "label": "Delivery",
                    "link": "/pages/delivery"
                  }
                },
                "footer-link-3": {
                  "type": "dev-menu-drawer-footer-link",
                  "settings": {
                    "label": "Returns",
                    "link": "/pages/returns"
                  }
                },
                "footer-link-4": {
                  "type": "dev-menu-drawer-footer-link",
                  "settings": {
                    "label": "Contact",
                    "link": "/pages/contact"
                  }
                }
              },
              "block_order": [
                "footer-link-1",
                "footer-link-2",
                "footer-link-3",
                "footer-link-4"
              ],
              "settings": {}
            }
          },
          "block_order": [
            "nav",
            "footer"
          ],
          "settings": {}
        },
        "cart-drawer": {
          "type": "dev-cart-drawer",
          "blocks": {
            "badge-1": {
              "type": "dev-cart-drawer-badge",
              "settings": {
                "icon": "wind",
                "label": "Breathable"
              }
            },
            "badge-2": {
              "type": "dev-cart-drawer-badge",
              "settings": {
                "icon": "care",
                "label": "Easy care"
              }
            },
            "badge-3": {
              "type": "dev-cart-drawer-badge",
              "settings": {
                "icon": "organic",
                "label": "Hypoallergenic"
              }
            }
          },
          "block_order": [
            "badge-1",
            "badge-2",
            "badge-3"
          ],
          "settings": {}
        }
      },
      "block_order": [
        "menu-drawer",
        "cart-drawer"
      ]
    },
    "dev-promo-bar": {
      "type": "dev-promo-bar",
      "settings": {
        "rating_value": "4.6/5",
        "rating_label": "Rated Excellent",
        "background_color": "#FFFCF4",
        "text_color": "#333333",
        "star_color": "#F1B500",
        "divider_color": "#C4BCA9",
        "padding_top": 12,
        "padding_bottom": 12
      }
    }
  },
  "order": [
    "dev-announcement-bar",
    "dev-site-header",
    "dev-promo-bar"
  ]
}