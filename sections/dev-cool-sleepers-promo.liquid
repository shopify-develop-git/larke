{{ 'dev-cool-sleepers-promo.css' | asset_url | stylesheet_tag }}
<script src="{{ 'dev-cool-sleepers-promo.js' | asset_url }}" defer></script>

{%- comment -%}
  The logos strip IS a marquee. Figma has it flattened into one rectangle, so the
  original build shipped it as a static image and deferred the call — correctly, since a
  marquee could not be inferred from a screenshot. Product has since made that call
  explicitly, and the artboard corroborates it: the set of five repeats, and the ninth
  logo is clipped by the right edge — a strip that is meant to keep moving.

  The marquee uses Horizon's OWN stock technique (blocks/_marquee.liquid + marquee.js): fill the
  row with whole copies of the set until it spans the frame, duplicate it once for two identical
  halves, then loop with a percentage shift (translate3d -50%). A percentage is exact by
  construction — no measured pixel shift to correct mid-animation — which is what finally killed
  the Safari blink/jump. The animation pauses on hover and is simply not applied under
  prefers-reduced-motion.

  Numbers below are measured off the Figma strip (1440x55), not guessed: the gap is a
  uniform 83px and each logo has its own optical height (Vogue 21, Mail Online 17,
  Refinery29 39, Grazia 21, Women's Health 21) — which is why height is a per-block
  setting rather than one shared value.
{%- endcomment -%}

{%- comment -%} Fixed design tokens from Figma — not merchant-controlled {%- endcomment -%}
<style>
  .cool-sleepers-promo {

    /* No --container-max and no single --section-px: this section has no centred
       max-width frame, and its horizontal inset differs per element (Brief,
       Brand Params + Structure). Same precedent as dev-site-header. */

    --font-heading-size: 32px;
    --font-heading-weight: 500;
    --font-heading-lh: 1.2;
    --font-body-size: 18px;
    --font-body-weight: 500;
    --font-body-lh: 1.4;

    /* The Mobile artboard specifies its own type sizes and paddings — those win
       over any scale factor (code standards, "Responsive type"). */
    --font-heading-size-mobile: 24px;
    --font-body-size-mobile: 16px;
    --pt-mobile: 32px;

    /* The banner (everything above the lifestyle image) is trimmed ~20% against the artboard —
       client call, 2026-07-24: "too imposing". Only the AIR shrinks: the type sizes and the
       55px logo strip stay exactly as designed. Desktop 286 → 230 (pt 80→48 in the template +
       these gaps 40→28); mobile follows the same rhythm (pt 48→32, gaps 24→16). */
    --spacing-sm: 8px; /* heading → subheading */
    --spacing-md: 28px; /* heading block → logos → image (artboard 40, see trim note) */
    --spacing-md-mobile: 16px;
    --spacing-lg: 54px; /* lifestyle image horizontal inset (desktop only) */

    /* Text frame is a fixed 421.33px centred column on desktop, fluid on mobile. */
    --text-width: 421.33px;
    --text-px: 16px;

    /* Radius sits on the "Image and text" frame at both breakpoints even though it
       has no fill today — preserved so it honours a merchant background (Brief #7). */
    --radius: 32px;
    /* The mobile image genuinely loses the radius AND the inset — it is edge-to-edge
       with square corners. A real breakpoint delta, not a scaled-down desktop (Brief #6). */
    --radius-image: 32px;

    /* Two intentionally distinct Figma crops per image role, not one source at two
       sizes (Brief, Images). Aspect ratios are the artboard node dimensions. */
    --image-aspect: 1332 / 400;
    --image-aspect-mobile: 375 / 250;

    /* Marquee. The strip is 55px tall on BOTH artboards and the logos are the same size
       on each — the mobile crop simply shows fewer of them, so the height carries across. */
    --logos-height: 55px;
    --logo-gap: 83px;
  }

  /* Mobile tightens the logo spacing to 40 (owner's call, 2026-07-22 — the desktop 83 leaves
     barely two logos on a 375 screen).

     It has to be declared HERE and not in dev-cool-sleepers-promo.css: that file is linked above
     this block, and a media query there would carry the same 0,1,0 specificity as the rule it is
     trying to beat — so it would lose on source order and do nothing.

     Do not write a literal style tag into a comment in here, even inside CSS comment markers:
     theme-check parses this element as HTML, sees a nested opening tag and fails the whole file
     with "Attempting to end parsing before HtmlElement 'style' was closed".

     Retuning the TOKEN, not __set's gap. The same value spaces logos inside a set, sets inside a
     half, and the two halves against each other; changing one of the three leaves the strip
     evenly spaced everywhere except at the seams. The keyframe reads it too, so its -50% wrap
     correction follows automatically. */
  @media (max-width: 768px) {
    .cool-sleepers-promo {
      --logo-gap: 40px;
    }
  }
</style>

{%- liquid
  assign heading = section.settings.heading
  assign subheading = section.settings.subheading

  assign lifestyle = section.settings.lifestyle_image
  assign lifestyle_mobile = section.settings.lifestyle_image_mobile

  assign lifestyle_alt = lifestyle.alt | default: '' | escape

  assign lifestyle_mobile_1x = lifestyle_mobile | image_url: width: 375
  assign lifestyle_mobile_2x = lifestyle_mobile | image_url: width: 750
  assign lifestyle_mobile_3x = lifestyle_mobile | image_url: width: 1125

  assign lifestyle_mobile_srcset = lifestyle_mobile_1x | append: ' 375w, ' | append: lifestyle_mobile_2x | append: ' 750w, ' | append: lifestyle_mobile_3x | append: ' 1125w'

  assign lifestyle_sizes = '(max-width: 768px) 100vw, calc(100vw - 108px)'
-%}

<div
  class="cool-sleepers-promo"
  style="
    --bg: {{ section.settings.background_color }};
    --color: {{ section.settings.text_color }};
    --accent: {{ section.settings.accent_color }};
    --pt: {{ section.settings.padding_top }}px;
    --pb: {{ section.settings.padding_bottom }}px;
  "
>
  <div class="cool-sleepers-promo__inner">
    {%- if heading != blank or subheading != blank -%}
      <div class="cool-sleepers-promo__text">
        {%- if heading != blank -%}
          <h2 class="cool-sleepers-promo__heading">{{ heading }}</h2>
        {%- endif -%}
        {%- if subheading != blank -%}
          <p class="cool-sleepers-promo__subheading">{{ subheading }}</p>
        {%- endif -%}
      </div>
    {%- endif -%}

    {%- if section.blocks.size > 0 -%}
      {%- comment -%}
        Structure mirrors Horizon's own stock marquee (blocks/_marquee.liquid + marquee.js):
        wrapper → content → repeated-items. One authored set (__set) is rendered; the JS fills the
        __track with copies of it until the row spans the frame, then duplicates the whole __track
        once so the wrapper holds TWO identical halves. The CSS then loops by exactly one half with a
        percentage shift (-50%). See the CSS keyframe for why a percentage is the whole point.
      {%- endcomment -%}
      <div
        class="cool-sleepers-promo__logos"
        style="--marquee-duration: {{ section.settings.marquee_duration }}s;"
        data-marquee-root
      >
        <div class="cool-sleepers-promo__marquee" data-marquee-wrapper>
          <div class="cool-sleepers-promo__track" data-marquee-content>
            <ul class="cool-sleepers-promo__set" data-marquee-set>
              {%- for block in section.blocks -%}
                {%- if block.settings.image != blank -%}
                  {%- assign logo_alt = block.settings.alt_text | default: block.settings.image.alt | default: '' | escape -%}
                  <li
                    class="cool-sleepers-promo__logo"
                    style="--logo-height: {{ block.settings.logo_height }}px;"
                    {{ block.shopify_attributes }}
                  >
                    {%- comment -%}
                      eager, NOT lazy: the strip is measured and cloned from these logos, so they
                      must have their real width BEFORE the strip is scrolled into view. Left lazy,
                      a real device (Safari especially) loads them only as you reach the section, so
                      the build would run on screen. They are five tiny press SVGs; loading them up
                      front is negligible.
                    {%- endcomment -%}
                    {{
                      block.settings.image
                      | image_url: width: 600
                      | image_tag: loading: 'eager', alt: logo_alt, class: 'cool-sleepers-promo__logo-image'
                    }}
                  </li>
                {%- endif -%}
              {%- endfor -%}
            </ul>
          </div>
        </div>
      </div>
    {%- endif -%}

    {%- if lifestyle != blank -%}
      <div class="cool-sleepers-promo__media">
        <picture>
          {%- if lifestyle_mobile != blank -%}
            <source
              media="(max-width: 768px)"
              srcset="{{ lifestyle_mobile_srcset }}"
              sizes="100vw"
              width="375"
              height="250"
            >
          {%- endif -%}
          {{
            lifestyle
            | image_url: width: 2664
            | image_tag:
              loading: 'lazy',
              widths: '750, 1100, 1332, 1998, 2664',
              sizes: lifestyle_sizes,
              alt: lifestyle_alt,
              class: 'cool-sleepers-promo__image'
          }}
        </picture>
      </div>
    {%- endif -%}
  </div>
</div>

{% schema %}
{
  "name": "As seen in",
  "tag": "section",
  "settings": [
    { "type": "header", "content": "Content" },
    { "type": "inline_richtext", "id": "heading", "label": "Heading", "default": "As seen in" },
    { "type": "inline_richtext", "id": "subheading", "label": "Subheading", "default": "Comfort put to the test" },
    { "type": "image_picker", "id": "lifestyle_image", "label": "Lifestyle image (desktop)" },
    { "type": "image_picker", "id": "lifestyle_image_mobile", "label": "Lifestyle image (mobile)" },

    { "type": "header", "content": "Colors" },
    { "type": "color", "id": "background_color", "label": "Background", "default": "rgba(0,0,0,0)" },
    { "type": "color", "id": "text_color", "label": "Text color", "default": "#333333" },
    { "type": "color", "id": "accent_color", "label": "Accent color", "default": "#333333" },

    { "type": "header", "content": "Layout" },
    {
      "type": "range",
      "id": "marquee_duration",
      "min": 10,
      "max": 90,
      "step": 5,
      "unit": "s",
      "label": "Marquee loop duration",
      "info": "Time for the logo strip to scroll one full set. Higher is slower. Pauses on hover, and stops for visitors who ask for reduced motion.",
      "default": 30
    },

    { "type": "header", "content": "Spacing" },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px",
      "label": "Padding top",
      "default": 80
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px",
      "label": "Padding bottom",
      "default": 0
    }
  ],
  "blocks": [
    {
      "type": "logo",
      "name": "Press logo",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Logo" },
        {
          "type": "text",
          "id": "alt_text",
          "label": "Alt text",
          "info": "The publication's name, e.g. \"Vogue\". Falls back to the image's own alt text."
        },
        {
          "type": "range",
          "id": "logo_height",
          "min": 8,
          "max": 55,
          "step": 1,
          "unit": "px",
          "label": "Logo height",
          "info": "Set per logo so the strip reads evenly — a tall stacked mark needs more height than a wide wordmark to look the same weight.",
          "default": 21
        }
      ]
    }
  ],
  "max_blocks": 12,
  "presets": [
    {
      "name": "As seen in",
      "blocks": [
        { "type": "logo" },
        { "type": "logo" },
        { "type": "logo" },
        { "type": "logo" },
        { "type": "logo" }
      ]
    }
  ]
}
{% endschema %}
