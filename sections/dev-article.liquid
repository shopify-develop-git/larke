{{ 'dev-article.css' | asset_url | stylesheet_tag }}

{%- comment -%}
  Section: "Article" (dev name `dev-article`). The blog post page.

  NO FIGMA ARTBOARD EXISTS FOR THIS PAGE — read that before "correcting" any value here.
  Every other dev-* section in this theme is measured off a 1440/375 artboard and QA'd with a
  pixel diff. This one cannot be, because the design does not cover it. So it is COMPOSED from the
  system the artboards already establish, and every value below is borrowed from a section that
  WAS measured, rather than invented:

    * Tiempos Headline Medium 48/1.2 heading  -> dev-hero's --font-heading-size
    * Public Sans Medium 18/1.4 body          -> dev-journal-cards' card copy (Body/Lg)
    * 16px meta, 14px badge                   -> dev-journal-cards' __meta / __badge
    * 32px media radius, 16px inline radius   -> dev-journal-cards' --radius-media
    * 64px / 16px gutters, 80px top spacer    -> the shared section rhythm
    * the back arrow                          -> the SAME exported vector as journal-cards' CTA

  The one thing that is genuinely new is the READING COLUMN (--measure, 720px). No section in the
  design has long-form prose, so nothing to copy: 720px at 18px type is ~72 characters per line,
  which is the middle of the 45–75 range typography treats as readable. Flagged as a judgement
  call, not a measurement — if a Journal artboard ever lands, this is the first value to check.

  Reading time is NOT computed here. It comes from snippets/dev-article-read-time.liquid, shared
  with dev-journal-cards, so the "4 min read" on the card and on the post it links to are the same
  number by construction.
{%- endcomment -%}

{%- comment -%} Fixed design tokens — borrowed from the measured sections, see above {%- endcomment -%}
<style>
  .dev-article {

    --section-px: 64px;
    --section-px-m: 16px;

    /* Two widths. --measure is the reading column: 720px at 18px type is ~72 characters per line,
       the middle of the 45–75 range that is comfortable to read. --media-w is the wider container
       the hero image fills, so the photo has presence without the prose inheriting a 960px line.
       Both are judgement calls — no artboard covers this page. See the header comment. */
    --measure: 720px;
    --media-w: 960px;

    --font-title-size: 48px;
    --font-title-size-m: 32px;
    --font-title-weight: 500;
    --font-title-lh: 1.2;

    /* Body copy and the headings INSIDE the article body. The body h2/h3 step down from the
       title rather than repeating it, so the page has one obvious top. */
    --font-body-size: 18px;
    --font-body-size-m: 16px;
    --font-body-weight: 500;
    --font-body-lh: 1.6; /* looser than the 1.4 the cards use: those are 2-line captions, this is prose */
    --font-h2-size: 32px;
    --font-h3-size: 22px;

    --font-meta-size: 16px;
    --font-badge-size: 14px;

    --spacing-xs: 8px;
    --spacing-sm: 16px;
    --spacing-md: 24px;
    --spacing-lg: 32px;
    --spacing-xl: 48px;
    --spacing-2xl: 64px;

    /* Hero crop. 3:2 is the shape a camera hands you, so it is the least violent thing to impose
       on photography a merchant did not shoot for this slot — and unlike `height: auto` it is the
       SAME shape for every article, portrait uploads included. At the 960px container that is
       960x640, comfortably inside one screen, with the first paragraph visible under it.

       One value for both breakpoints, which is this theme's habit (story-slider and
       values-we-cherish do the same): the ratio is the design, not a per-device measurement. */
    --ratio-media: 3 / 2;

    --radius-media: 32px;
    --radius-inline: 16px;
    --radius-badge: 60px;

    --icon-size: 24px;
  }
</style>

{%- liquid
  assign article_tag = article.tags | first
  assign blog_url = blog.url | default: routes.root_url
-%}

<div
  class="dev-article"
  style="
    --bg: {{ section.settings.background_color }};
    --color: {{ section.settings.text_color }};
    --muted: {{ section.settings.meta_color }};
    --badge-bg: {{ section.settings.badge_color }};
    --rule: {{ section.settings.rule_color }};
    --pt: {{ section.settings.padding_top }}px;
    --pb: {{ section.settings.padding_bottom }}px;
  "
>
  <article class="dev-article__inner">
    {%- if section.settings.back_label != blank -%}
      <a class="dev-article__back dev-btn dev-btn--text dev-btn--icon-left" href="{{ blog_url }}">
        {%- comment -%} Same vector as dev-journal-cards' CTA, mirrored to point back. {%- endcomment -%}
        <svg class="dev-article__back-icon dev-btn__icon" width="24" height="24" viewBox="99 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true" focusable="false">
          <path d="M106 16L102 12L106 8M102 12L120 12" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
        <span class="dev-btn__label">{{ section.settings.back_label | escape }}</span>
      </a>
    {%- endif -%}

    <header class="dev-article__head">
      {%- if article_tag != blank -%}
        <span class="dev-article__badge">{{ article_tag | escape }}</span>
      {%- endif -%}

      <h1 class="dev-article__title">{{ article.title | escape }}</h1>

      {%- comment -%}
        The meta line is built from the parts that actually exist. An article with no author must
        not render a dangling "ㆍBy" — hence the per-part guards rather than one fixed string.
      {%- endcomment -%}
      {%- capture read_minutes -%}{%- render 'dev-article-read-time', article: article -%}{%- endcapture -%}
      {%- liquid
        assign meta = read_minutes | append: ' ' | append: section.settings.read_time_label

        if article.author != blank
          assign meta = meta | append: ' ㆍ' | append: section.settings.author_prefix | append: ' ' | append: article.author
        endif

        if section.settings.show_date
          assign published = article.published_at | date: format: 'date'
          assign meta = meta | append: ' ㆍ' | append: published
        endif
      -%}
      <p class="dev-article__meta">{{ meta | escape }}</p>
    </header>

    {%- if article.image != blank -%}
      {%- comment -%}
        The alt is resolved in its own assign, NOT inline in the image_tag arguments. Liquid does
        not allow a filter pipe inside an argument list: `alt: article.image.alt | default: x` is
        parsed as "pipe the whole image_tag output into `default`", which swallows every argument
        after it — the `class` never reached image_tag and the <img> rendered unclassed, so its
        `width: 100%` never applied. This bit once; keep the assign.
      {%- endcomment -%}
      {%- comment -%}
        THE HERO IS THIS PAGE'S LCP ELEMENT — confirmed with a PerformanceObserver on the rendered
        page at both widths, not assumed. Everything below follows from that.

        `sizes` said 1312px and the box has never been wider than 960. 1312 is the Figma content
        frame (1440 − 2×64), which is the width of the SECTION; the image lives inside
        .dev-article__inner, capped at --media-w: 960px. The 37% overshoot was enough to push the
        browser off the 1000w entry and all the way onto 2600w:

          box 960 CSS @ DPR2  ->  1920 device px needed
          shipped             ->  2600w, 519,042 B

        On the CDN, same image: 2600 = 519,042 B, 1920 = 292,806 B, 1920 at q75 = 151,846 B, and
        1920x1280 cropped at q75 = 69,078 B. The crop is the bigger half — see --ratio-media.

        The ladder now stops at 1920 for the same reason — 960 × 2 is the most a correct `sizes`
        can ever ask for, and the entries above it were unreachable weight in the srcset. Below
        1088 the cap stops binding and the padding takes over, hence the middle branch: 64px each
        side above 768, 16px below.

        `quality` cannot be passed blind — image_url raises "quality can't be used with ext png" and
        the src renders as an error string. This is a merchant's featured image, so the extension is
        read off the URL first. A png keeps the correct width and skips the recompression rather
        than being flattened to jpg, which would drop any alpha it does have.

        fetchpriority high: `eager` only removes it from the lazy queue. Being the LCP element, it
        should also outrank the rest of the page's subresources, and nothing else here competes.
      {%- endcomment -%}
      {%- liquid
        assign hero_alt = article.image.alt | default: article.title
        assign hero_ext = article.image | image_url: width: 1 | split: '?' | first | split: '.' | last | downcase

        comment
          1920x1280 is --ratio-media (3/2) at the widest the box ever gets: 960 CSS at DPR 2.
          `image_tag`'s `widths:` scales the height with each rung, so every srcset entry keeps the
          ratio and the browser is handed the box rather than a portrait to trim.
        endcomment
        if hero_ext == 'gif'
          assign hero_src = article.image | image_url: width: 1920, height: 1280, crop: 'center'
        elsif hero_ext == 'png'
          assign hero_src = article.image | image_url: width: 1920, height: 1280, crop: 'center', format: 'webp', quality: 75
        else
          assign hero_src = article.image | image_url: width: 1920, height: 1280, crop: 'center', quality: 75
        endif
      -%}
      <div class="dev-article__media">
        {{
          hero_src
          | image_tag:
            loading: 'eager',
            fetchpriority: 'high',
            widths: '400, 500, 600, 700, 800, 900, 1000, 1120, 1280, 1440, 1600, 1920',
            sizes: '(min-width: 1088px) 960px, (min-width: 769px) calc(100vw - 128px), calc(100vw - 32px)',
            alt: hero_alt,
            class: 'dev-article__image'
        }}
      </div>
    {%- endif -%}

    {%- comment -%}
      article.content is merchant HTML from the Shopify editor — already safe, never escape it.
      Every tag it can emit is styled in the CSS; the class is `dev-article__body`, deliberately
      NOT Horizon's `.rte`, which is a stock class and would drag stock rules in with it.
    {%- endcomment -%}
    {%- comment -%}
      Images the merchant drops into the post body come out of the rich-text editor as bare
      `<img src="…cdn…">`: no loading attribute, so every one of them is eager by default and
      competes with the hero above for the connection that decides LCP. There is no markup here to
      fix — the HTML is the merchant's — so the attribute is injected into the string.

      Prepending is deliberate. Duplicate attributes are legal and the FIRST one wins, so a post
      whose editor already emitted `loading="eager"` still ends up lazy, and one that emitted
      `loading="lazy"` is unchanged. `<img ` with the trailing space cannot match `<image` or any
      other tag that starts the same way.

      srcset is NOT injectable this way and is not attempted: the editor's URL is whatever width it
      pasted, and rewriting merchant HTML with `replace` past a single attribute is how you corrupt
      a post. The CSS below already caps them at the measure.
    {%- endcomment -%}
    <div class="dev-article__body">
      {{ article.content | replace: '<img ', '<img loading="lazy" decoding="async" ' }}
    </div>

    {%- if section.settings.back_label != blank -%}
      <div class="dev-article__foot">
        <a class="dev-article__back dev-btn dev-btn--text dev-btn--icon-left" href="{{ blog_url }}">
          <svg class="dev-article__back-icon dev-btn__icon" width="24" height="24" viewBox="99 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true" focusable="false">
            <path d="M106 16L102 12L106 8M102 12L120 12" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
          <span class="dev-btn__label">{{ section.settings.back_label | escape }}</span>
        </a>
      </div>
    {%- endif -%}
  </article>
</div>

{% schema %}
{
  "name": "Article",
  "tag": "section",
  "settings": [
    { "type": "header", "content": "Content" },
    { "type": "text", "id": "back_label", "label": "Back link label", "default": "Back to Journal" },
    {
      "type": "text",
      "id": "read_time_label",
      "label": "Reading time label",
      "info": "Set the article's 'Reading time' metafield to state the minutes. Left empty, it is estimated from the word count.",
      "default": "min read"
    },
    { "type": "text", "id": "author_prefix", "label": "Author prefix", "default": "By" },
    { "type": "checkbox", "id": "show_date", "label": "Show the published date", "default": true },

    { "type": "header", "content": "Colors" },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background",
      "info": "Transparent by default so the page canvas shows through, as on the Journal section.",
      "default": "rgba(0,0,0,0)"
    },
    { "type": "color", "id": "text_color", "label": "Text color", "default": "#333333" },
    { "type": "color", "id": "meta_color", "label": "Meta text", "default": "#666666" },
    { "type": "color", "id": "badge_color", "label": "Tag badge background", "default": "#FCF5E3" },
    { "type": "color", "id": "rule_color", "label": "Rules and borders", "default": "#C4BCA9" },

    { "type": "header", "content": "Spacing" },
    { "type": "range", "id": "padding_top", "min": 0, "max": 120, "step": 4, "unit": "px", "label": "Padding top", "default": 48 },
    { "type": "range", "id": "padding_bottom", "min": 0, "max": 120, "step": 4, "unit": "px", "label": "Padding bottom", "default": 80 }
  ]
}
{% endschema %}
