{{ 'dev-announcement-bar.css' | asset_url | stylesheet_tag }}

{%- comment -%} Fixed design tokens from Figma — not merchant-controlled {%- endcomment -%}
<style>
  .dev-announcement-bar {
    {%- comment -%}
      No --font-heading here on purpose: this section contains no heading-level text,
      so the Brief records the heading font as NOT FOUND. Sourcing one from another
      section would be inventing design.
    {%- endcomment -%}
    --section-px: 64px;
    --section-px-mobile: 16px;

    {%- comment -%}
      Past 1440 the bar's CONTENT stops growing with the window. The bar itself must stay
      full-bleed — it is a coloured strip across the top of the page, and a floating one with
      the page showing either side would read as a mistake — so the cap is expressed as a
      gutter rather than a max-width, and the background is untouched.

      1312 is 1440 - 2x64: the content width the artboard actually draws.

      max() is what makes this safe at every width already signed off. Below 1440 the second
      term is smaller than --section-px (and below 1312 it is negative), so --section-px wins
      and every existing breakpoint resolves to exactly the padding it has now. Above 1440 the
      gutter takes the surplus and the content sits centred at 1312.
    {%- endcomment -%}
    --container-max: 1312px;
    --gutter: max(var(--section-px), (100% - var(--container-max)) / 2);

    --font-body-size: 16px;
    --font-body-size-sm: 14px;
    --font-body-lh: 1.4;
    --font-body-weight: 500;
    --font-body-weight-bold: 700;
    --spacing-sm: 16px;
    --spacing-md: 24px;
    --bar-min-h: 48px;
    --bar-min-h-mobile: 36px;
    --link-h: 24px;
    --divider-w: 1px;
    --divider-h: 18px;

    {%- comment -%}
      Hover underline — the "Text link" component's hover variant (Figma 45201:1588).
      Not a straight rule: the exported stroke is a tapered lens, 1.4px in the middle
      thinning to ~0.5px at softly curved ends, inset 8px from each end of the label,
      centred on the bottom edge of the 24px link box. The geometry lives in
      dev-announcement-bar-underline.svg (exported verbatim, preserveAspectRatio="none"
      so it stretches to each label's width) and is applied as a mask so the colour
      stays in CSS. #666666 is the variant's own colour, deliberately distinct from
      the #333333 label — do not unify it with --color.
    {%- endcomment -%}
    --link-underline-svg: url('{{ 'dev-announcement-bar-underline.svg' | asset_url }}');
    --link-underline-h: 1.4px;
    --link-underline-inset: 8px;
    --link-underline-color: #666666;
  }
</style>

{%- liquid
  comment
    Count only the messages that actually render, so a divider is never emitted
    after the last one (or after a message block the merchant left blank).
  endcomment
  assign message_count = 0
  assign left_count = 0
  assign right_count = 0
  for block in section.blocks
    case block.type
      when 'message'
        if block.settings.text != blank
          assign message_count = message_count | plus: 1
        endif
      when 'link'
        if block.settings.label != blank
          if block.settings.position == 'right'
            assign right_count = right_count | plus: 1
          else
            assign left_count = left_count | plus: 1
          endif
        endif
    endcase
  endfor
  assign message_index = 0
-%}

<div
  class="dev-announcement-bar"
  style="
    --bg: {{ section.settings.background_color }};
    --color: {{ section.settings.text_color }};
    --accent: {{ section.settings.accent_color }};
    --pt: {{ section.settings.padding_top }}px;
    --pb: {{ section.settings.padding_bottom }}px;
  "
>
  {%- if left_count > 0 -%}
    <nav class="dev-announcement-bar__links dev-announcement-bar__links--left" aria-label="Announcement bar links, left">
      {%- for block in section.blocks -%}
        {%- if block.type == 'link' and block.settings.position != 'right' and block.settings.label != blank -%}
          {%- assign link_url = block.settings.url | default: routes.root_url -%}
          <a class="dev-announcement-bar__link" href="{{ link_url }}" {{ block.shopify_attributes }}>
            {{- block.settings.label | escape -}}
          </a>
        {%- endif -%}
      {%- endfor -%}
    </nav>
  {%- endif -%}

  {%- if message_count > 0 -%}
    <div class="dev-announcement-bar__messages">
      {%- for block in section.blocks -%}
        {%- if block.type == 'message' and block.settings.text != blank -%}
          {%- assign message_index = message_index | plus: 1 -%}
          <p class="dev-announcement-bar__message" {{ block.shopify_attributes }}>
            {{- block.settings.text | escape -}}
          </p>

          {%- if message_index < message_count -%}
            {%- comment -%}
              Divider — geometry pasted verbatim from the Figma export
              (.figma-assets/announcement-bar/divider-line-{desktop,mobile}.svg).
              Each viewBox crops that frame's own coordinate space to the 1x18 line box,
              so the rendered aspect ratio equals the viewBox aspect ratio exactly (1:18)
              and x1/y1/x2/y2/stroke-linecap stay byte-identical to Figma. The only change
              is stroke #333333 -> currentColor, so the line follows --color instead of
              hardcoding a hex (project rule: never hardcode a colour).
            {%- endcomment -%}
            <span class="dev-announcement-bar__divider" aria-hidden="true">
              <svg
                class="dev-announcement-bar__divider-line dev-announcement-bar__divider-line--desktop"
                width="1"
                height="18"
                viewBox="729.5 15 1 18"
                fill="none"
                xmlns="http://www.w3.org/2000/svg"
                focusable="false"
              >
                <line x1="730" y1="15.5" x2="730" y2="32.5" stroke="currentColor" stroke-linecap="round"/>
              </svg>
              <svg
                class="dev-announcement-bar__divider-line dev-announcement-bar__divider-line--mobile"
                width="1"
                height="18"
                viewBox="195.5 9 1 18"
                fill="none"
                xmlns="http://www.w3.org/2000/svg"
                focusable="false"
              >
                <line x1="196" y1="9.5" x2="196" y2="26.5" stroke="currentColor" stroke-linecap="round"/>
              </svg>
            </span>
          {%- endif -%}
        {%- endif -%}
      {%- endfor -%}
    </div>
  {%- endif -%}

  {%- if right_count > 0 -%}
    <nav class="dev-announcement-bar__links dev-announcement-bar__links--right" aria-label="Announcement bar links, right">
      {%- for block in section.blocks -%}
        {%- if block.type == 'link' and block.settings.position == 'right' and block.settings.label != blank -%}
          {%- assign link_url = block.settings.url | default: routes.root_url -%}
          <a class="dev-announcement-bar__link" href="{{ link_url }}" {{ block.shopify_attributes }}>
            {{- block.settings.label | escape -}}
          </a>
        {%- endif -%}
      {%- endfor -%}
    </nav>
  {%- endif -%}
</div>

{% schema %}
{
  "name": "Announcement bar",
  "tag": "section",
  "settings": [
    { "type": "header", "content": "Colors" },
    { "type": "color", "id": "background_color", "label": "Background", "default": "#FCF5E3" },
    { "type": "color", "id": "text_color", "label": "Text color", "default": "#333333" },
    { "type": "color", "id": "accent_color", "label": "Accent color", "default": "#333333" },

    { "type": "header", "content": "Spacing" },
    { "type": "range", "id": "padding_top", "min": 0, "max": 60, "step": 2, "unit": "px", "label": "Padding top", "default": 12 },
    { "type": "range", "id": "padding_bottom", "min": 0, "max": 60, "step": 2, "unit": "px", "label": "Padding bottom", "default": 12 }
  ],
  "blocks": [
    {
      "type": "message",
      "name": "Message",
      "limit": 2,
      "settings": [
        { "type": "text", "id": "text", "label": "Message", "default": "Free UK Delivery" }
      ]
    },
    {
      "type": "link",
      "name": "Link",
      "limit": 4,
      "settings": [
        { "type": "text", "id": "label", "label": "Label", "default": "Delivery" },
        { "type": "url", "id": "url", "label": "Link" },
        {
          "type": "select",
          "id": "position",
          "label": "Position",
          "default": "left",
          "info": "Desktop only — links are not shown on mobile.",
          "options": [
            { "value": "left", "label": "Left" },
            { "value": "right", "label": "Right" }
          ]
        }
      ]
    }
  ],
  "max_blocks": 6,
  "presets": [
    {
      "name": "Announcement bar",
      "blocks": [
        { "type": "link", "settings": { "label": "Delivery", "url": "/pages/delivery", "position": "left" } },
        { "type": "link", "settings": { "label": "Returns", "url": "/pages/returns", "position": "left" } },
        { "type": "message", "settings": { "text": "Safe 60-Night Trial" } },
        { "type": "message", "settings": { "text": "Free UK Delivery" } },
        { "type": "link", "settings": { "label": "FAQs", "url": "/pages/faqs", "position": "right" } },
        { "type": "link", "settings": { "label": "Contact", "url": "/pages/contact", "position": "right" } }
      ]
    }
  ]
}
{% endschema %}
