{{ 'dev-tree-fibre-hero.css' | asset_url | stylesheet_tag }}
{%- comment -%}
  No JS tag: this section is static — one background photo, one heading, no controls.
  Loading an empty dev-tree-fibre-hero.js on every page render would buy nothing.
{%- endcomment -%}

{%- comment -%} Fixed design tokens from Figma — not merchant-controlled {%- endcomment -%}
<style>
  .tree-fibre-hero {
    /* Brand params. The faces themselves are loaded theme-wide by snippets/dev-brand-fonts.liquid —
       this only selects them. --container-max is deliberately absent: the hero is full-bleed, there
       is no inner max-width frame (same call as dev-hero / dev-site-header). */
    --section-px: 64px;
    --section-px-m: 16px;

    /* The mobile artboard states its own top padding, so it is a fixed token, not a scale
       factor off --pt. Derived from the artboard: the heading's ink starts at y=46, and the
       ink-top-to-box-top delta for this face at lh 1.2 is 0.2105em (calibrated on the desktop
       artboard, where padding is a known 64px and ink starts at y=72 for 38px type).
       46 - (0.2105 x 28) = 40.1  ->  40px. */
    --pt-m: 40px;

    /* Typography. Desktop 38px / mobile 28px, both Tiempos Headline Regular at lh 1.2.
       Mobile size is measured off the artboard: baseline pitch is exactly 34px and
       34 / 1.2 = 28.3, and the ascender-to-descender ink height (27px) over the desktop's
       measured 0.974 em ratio gives 27.7 — both round to 28. */
    --font-heading-size: 38px;
    --font-heading-size-m: 28px;
    --font-heading-weight: 400;
    --font-heading-lh: 1.2;

    /* --em-weight is NOT here any more: the two pages this section serves want different weights
       (Our Story 700, Tree Fibre 600), so it is a per-instance `emphasis_weight` setting and rides
       inline on the root wrapper below, with the merchant-controlled values. See the note there. */

    /* Frame — 550px tall on BOTH artboards (1440x550 desktop, 375x550 mobile). */
    --hero-min-h: 550px;
    --radius-bottom: 32px;

    /* Desktop text column: w-[480px] on the artboard. */
    --text-col-w: 480px;
    --spacing-md: 24px;

    /* ---- Squiggle underline (optional; see `show_underline` in the schema) --------
       The Our Story hero (45078:8864) is this same _Master Hero Media component, but it
       underlines its emphasised runs — TWO of them ("starting", "duvets.") — with a hand-drawn
       stroke. Rather than pin an SVG under one hard-coded word (the mistake baked into dev-hero,
       where --squiggle-x/-y only ever fit "trees"), the stroke here is a MASK on the <em> itself,
       so it follows whatever the merchant italicises, however many runs there are.

       Figma exports both strokes with preserveAspectRatio="none" and width="100%" — they are
       MEANT to stretch to their word, and they do: 145x5 under "starting" (146.106/6.784 of real
       ink) and 134x5 under "duvets." (135.105/7.653). Different aspect ratios, same stroke idea.
       So the mask stretches to the <em>'s width and only the HEIGHT is a token.

       The two files are the two real Figma vectors, pasted verbatim; the CSS alternates them per
       <em> (nth-of-type) so a two-emphasis heading reproduces the artboard exactly.

       Geometry, off the desktop artboard: the anchor box is 5px tall at y=207.06, but Figma
       overflows the art out of it (inset -24.64% top), so the real ink is 6.78px starting at
       y=205.83. Heading line 3's box bottom sits at 64 + 3x(38x1.2) = 200.8 — hence a 5px gap. */
    --squiggle-1: url('{{ 'dev-tree-fibre-hero-underline-1.svg' | asset_url }}');
    --squiggle-2: url('{{ 'dev-tree-fibre-hero-underline-2.svg' | asset_url }}');
    --squiggle-h: 6.78px;
    --squiggle-gap: 5px;
    --squiggle-h-m: 5px;
    --squiggle-gap-m: 4px;

    /* Mobile heading wrap guard. The artboard wraps as
         "Turns out, taking care of" / "our planet never felt more" / "comfortable."
       The widest line measures 312px of ink, and the string "Turns out, taking care of our"
       needs ~344.5px — so ANY box width in [314px, 344px) reproduces this wrap, and because
       the text is centred every width in that band renders pixel-identically. The mobile
       gutter (16px) puts the box at 343px, which is only 1.4px inside the threshold — close
       enough that a sub-pixel metrics difference would pull "our" up a line and break the
       design. 336px sits in the middle of the safe band: same render, no cliff edge. */
    --heading-max-w-m: 336px;

    /* ---- Background photo framing ----------------------------------------------
       Percentages of the section box, so the crop holds at every viewport width.

       DESKTOP — Figma's own numbers, used verbatim (w-full, h-[392.68%], top-[-149.98%]).
       1440 wide x 2159.74 tall = aspect 0.66675, which is exactly the source photo
       (2731x4096 = 0.66675) — so the fill is a plain cover-by-width with the visible band
       taken from 51.24% down the photo. No distortion.

       MOBILE — the mobile master crops the SAME photo differently: it is zoomed 1.117x past
       cover. Solved against the 375x550 artboard by a 2D scale/offset search over the raw
       source (mean abs error fell from 38.5 to 3.6/255 at the fit, i.e. JPEG noise):
         displayed 419.0 x 628.5 px, centred horizontally, top -72px
         -> width  419.0 / 375 = 111.73%
            height 628.5 / 550 = 114.27%   (419.0 / 0.66675 = 628.5, aspect exact)
            top    -72   / 550 = -13.09%
            left   -22   / 375 =  -5.87%   ((419 - 375) / 2 = 22, i.e. dead centre)
       Both dimensions stay larger than the box at every width, so it always covers.
       object-fit: cover is belt-and-braces against sub-pixel aspect drift. */
    --bg-w-d: 100%;
    --bg-h-d: 392.68%;
    --bg-top-d: -149.98%;
    --bg-left-d: 0%;

    --bg-w-m: 111.73%;
    --bg-h-m: 114.27%;
    --bg-top-m: -13.09%;
    --bg-left-m: -5.87%;

    /* ---- Scrim -------------------------------------------------------------------
       DESKTOP: Figma's gradient, verbatim. At 164.82deg the gradient line runs down-and-right,
       so the 0.6 black lands top-LEFT, under the heading, and is gone by 48% of the way down.

       MOBILE: there is NO scrim, and that is not an omission. The mobile crop reaches up into
       the dark treeline at the top of the photo, so the heading already has contrast without
       one. Measured on the artboard against the aligned source: at y=0 the source reads 14.9
       and the artboard reads 15.0 — a ratio of 1.00, i.e. zero darkening. A 0.6-alpha scrim
       would have driven that to ~6. Do not "restore" the desktop gradient here; it would
       visibly crush a region the design leaves alone. */
    --overlay-d: linear-gradient(
      164.8221deg,
      rgba(0, 0, 0, 0.6) 3.8161%,
      rgba(0, 0, 0, 0) 48.295%
    );
    --overlay-m: none;
  }
</style>

{%- liquid
  assign bg_image = section.settings.background_image
  assign bg_mobile = section.settings.background_image_mobile
-%}

{%- comment -%}
  The mobile background is OPTIONAL and changes how the crop works, so the two cases are kept apart:

  - No mobile image (the default, and what the artboard describes): the desktop photo is re-framed
    on mobile by --bg-*-m — a 111.73% x 114.27% overflow crop that reaches up into the dark treeline.
    Unchanged from before this setting existed.
  - A mobile image IS set: it is a picture chosen FOR that frame, so re-applying the overflow crop
    would push its subject off the top. The modifier below drops the crop and lets it simply cover.
{%- endcomment -%}
<div
  class="tree-fibre-hero{% if section.settings.show_underline %} tree-fibre-hero--underline{% endif %}{% if section.settings.stretch_background %} tree-fibre-hero--stretch-bg{% endif %}{% if bg_mobile != blank %} tree-fibre-hero--mobile-bg{% endif %}"
  {%- comment -%}
    --em-weight lives here, per instance, because the two pages disagree: the Our Story hero sets
    its runs in Bold Italic (45078:8868) and Tree Fibre wants Semibold. One token in the block
    above could only ever serve one of them.

    READ THIS BEFORE ASSUMING 600/700 LOOK RIGHT. dev-brand-fonts.liquid registers italic faces at
    400 and 500 ONLY — 600 (Semibold) and 700 (Bold) are upright-only, and there is no
    TiemposHeadline-BoldItalic.woff2 or -SemiboldItalic.woff2 in assets/. So above 500 the browser
    SYNTHESISES the italic by shearing the upright face. A true Tiempos italic has its own
    letterforms (single-storey 'a', descending 'f', calligraphic entry strokes); a sheared upright
    has none of them. 500 is therefore the only value that draws a REAL italic, and it is one
    weight light of both artboards — every option trades one kind of wrong for the other.

    The fix that retires this whole note is an asset, not CSS: supply the missing italic faces and
    register them in snippets/dev-brand-fonts.liquid (shared-chrome lane, not this one).
  {%- endcomment -%}
  style="
    --bg: {{ section.settings.background_color }};
    --color: {{ section.settings.text_color }};
    --accent: {{ section.settings.accent_color }};
    --pt: {{ section.settings.padding_top }}px;
    --pb: {{ section.settings.padding_bottom }}px;
    --em-weight: {{ section.settings.emphasis_weight }};
  "
>
  <div class="tree-fibre-hero__bg-layer">
    {%- if bg_image != blank -%}
      {%- comment -%}
        <picture>, not two <img> hidden from each other by display:none. A hidden <img> is still
        FETCHED — the sibling hero does exactly that, so a phone downloads the desktop photo it will
        never show, at fetchpriority: high, against the LCP of the page. A <source media=...> makes
        the browser pick one file and download only that one.

        The <img> stays the desktop candidate: it is the fallback every browser understands, and it
        is what <picture> falls back to when no <source> matches.
      {%- endcomment -%}
      {%- comment -%}
        NO CDN CROP ON THIS ONE, deliberately, and it is the exception on the site. The zoom mode
        below blows the photo up to ~393% of the frame and pulls it up out of it — the trick that
        lets one image supply both the desktop slice and a different mobile slice. Those offsets are
        measured against the WHOLE photo, so cropping it at the CDN would move the framing. Every
        other section here crops; this one only recompresses.

        Weight, measured on the rendered page at 1440 / DPR 2:

          tree-fibre  3200w entry, 527,434 B   — the heaviest asset on either page
          our-story   3200w entry, 144,688 B

        The ladder stops at 2600. The box is 1429 CSS wide, so DPR 2 asks for 2858 and 2600 is 9%
        short of it — on a decorative background sitting under a scrim with a heading over it, at a
        density no one is inspecting. 3200 was the entry actually being chosen, and it was the last
        one on the ladder rather than the right one.

        q65 on top of that. 2600 alone is 472,240 B; measured on the DELIVERED WebP at that width:

          q75  250 KB      q65  214 KB      q55  185 KB
          q70  229 KB      q60  197 KB

        65 is a second pass on an earlier, more cautious 75. The section's own overlay is what the
        visitor sees this photo through, and there is an h1 over it — dev-video-promo-banner went to
        q60 on exactly this kind of surface and stayed indistinguishable at 2x. 65 keeps a margin on
        that because this one fills the whole viewport rather than a banner, and it is the biggest
        single asset on the page, on the fetchpriority: high path.

        Both settings are image_pickers, so neither extension is knowable — `quality` on a png makes
        image_url raise "quality can't be used with ext png" and the srcset renders as the error
        text. Today they are .jpg and .webp; the guard is for the upload after this one.
      {%- endcomment -%}
      {%- liquid
        assign bg_ext = bg_image | image_url: width: 1 | split: '?' | first | split: '.' | last | downcase
        if bg_ext == 'gif'
          assign bg_src = bg_image | image_url: width: 2600
        elsif bg_ext == 'png'
          assign bg_src = bg_image | image_url: width: 2600, format: 'webp', quality: 65
        else
          assign bg_src = bg_image | image_url: width: 2600, quality: 65
        endif

        assign bgm_ext = bg_mobile | image_url: width: 1 | split: '?' | first | split: '.' | last | downcase
        assign bgm_quality = true
        assign bgm_png = false
        if bgm_ext == 'png' or bgm_ext == 'gif'
          assign bgm_quality = false
        endif
        if bgm_ext == 'png'
          assign bgm_png = true
        endif
      -%}
      <picture>
        {%- if bg_mobile != blank -%}
          <source
            media="(max-width: 768px)"
            srcset="
              {%- assign bgm_widths = '400, 600, 800, 1000, 1200, 1400, 1600' | split: ', ' -%}
              {%- for w in bgm_widths -%}
                {%- assign wn = w | plus: 0 -%}
                {%- if bgm_quality -%}
                  {{ bg_mobile | image_url: width: wn, quality: 65 }} {{ wn }}w
                {%- elsif bgm_png -%}
                  {{ bg_mobile | image_url: width: wn, format: 'webp', quality: 65 }} {{ wn }}w
                {%- else -%}
                  {{ bg_mobile | image_url: width: wn }} {{ wn }}w
                {%- endif -%}
                {%- unless forloop.last %}, {% endunless -%}
              {%- endfor -%}
            "
            sizes="100vw"
            width="{{ bg_mobile.width }}"
            height="{{ bg_mobile.height }}"
          >
        {%- endif -%}

        {{
          bg_src
          | image_tag:
            loading: 'eager',
            fetchpriority: 'high',
            widths: '400, 600, 800, 1000, 1200, 1600, 2000, 2200, 2600',
            sizes: '(max-width: 768px) 112vw, 100vw',
            alt: '',
            class: 'tree-fibre-hero__bg'
        }}
      </picture>
    {%- endif -%}

    <span class="tree-fibre-hero__overlay" aria-hidden="true"></span>
  </div>

  <div class="tree-fibre-hero__content">
    {%- if section.settings.heading != blank -%}
      {%- comment -%} inline_richtext: already safe HTML from Shopify — never escape it. {%- endcomment -%}
      <h1 class="tree-fibre-hero__heading">{{ section.settings.heading }}</h1>
    {%- endif -%}
  </div>
</div>

{% schema %}
{
  "name": "Tree fibre hero",
  "tag": "section",
  "presets": [
    { "name": "Tree fibre hero" }
  ],
  "settings": [
    { "type": "header", "content": "Content" },
    {
      "type": "inline_richtext",
      "id": "heading",
      "label": "Heading",
      "info": "Italicise a word to emphasise it.",
      "default": "Turns out, taking care of our planet never felt more <em>comfortable.</em>"
    },
    {
      "type": "select",
      "id": "emphasis_weight",
      "label": "Emphasis weight",
      "info": "How heavy the italicised words are. Only Medium has a real italic in the theme — above it the browser fakes the slant by leaning the upright face, which is heavier but not true Tiempos italic. Our Story uses Bold, Tree Fibre uses Semibold.",
      "default": "600",
      "options": [
        { "value": "500", "label": "Medium (true italic)" },
        { "value": "600", "label": "Semibold" },
        { "value": "700", "label": "Bold" }
      ]
    },
    {
      "type": "checkbox",
      "id": "show_underline",
      "label": "Underline the emphasised words",
      "info": "Draws the hand-drawn accent stroke under every italicised run, in the accent colour.",
      "default": false
    },
    { "type": "image_picker", "id": "background_image", "label": "Background image (desktop)" },
    {
      "type": "image_picker",
      "id": "background_image_mobile",
      "label": "Background image (mobile)",
      "info": "Optional. Left empty, mobile shows the desktop image. Set one and it is shown as-is, cropped to fill — never stretched, even with the setting below on."
    },
    {
      "type": "checkbox",
      "id": "stretch_background",
      "label": "Stretch the background to the Figma crop",
      "info": "Off, the photo simply fills the frame. On, it is blown up to ~393% of the frame's height and pulled up out of it — the trick that lets ONE image supply both the desktop slice and a different mobile slice. Those offsets were measured against the original photo, so a different picture will land somewhere else.",
      "default": false
    },

    { "type": "header", "content": "Colors" },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background",
      "info": "Sits behind the photo. Visible while the photo is still loading, so a solid colour here reads as a flash of that colour before the image lands. Transparent by default, which lets the page canvas through.",
      "default": "rgba(0,0,0,0)"
    },
    { "type": "color", "id": "text_color", "label": "Text color", "default": "#FFFFFF" },
    { "type": "color", "id": "accent_color", "label": "Accent color", "default": "#A8CF78" },

    { "type": "header", "content": "Spacing" },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px",
      "label": "Padding top",
      "default": 64
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px",
      "label": "Padding bottom",
      "default": 64
    }
  ]
}
{% endschema %}
