        <div class="fibre-benefits__text">
          {%- if block.settings.heading != blank -%}
            {%- comment -%}
              inline_richtext: already safe HTML from Shopify — never escape it.
            {%- endcomment -%}
            <h3 class="fibre-benefits__heading">
              <span class="fibre-benefits__heading-line">{{ block.settings.heading }}</span>
              {%- comment -%}
                Card 2's heading carries an explicit manual line break on the mobile artboard
                ("Grown sustainably" / "— FSC Certified") that does not exist on desktop, where it
                is a single unbroken line (Brief: Auto Layout (mobile)). Modelled as a second,
                optional line rather than a hardcoded <br>: the spans are inline on desktop (the
                ::before restores the separating space) and block on mobile (forced break).
                Whitespace is carried by the ::before, never by markup, so dash tags stay safe.
              {%- endcomment -%}
              {%- if block.settings.heading_line_2 != blank -%}
                <span class="fibre-benefits__heading-line fibre-benefits__heading-line--2">{{ block.settings.heading_line_2 }}</span>
              {%- endif -%}
            </h3>
          {%- endif -%}
          {%- if block.settings.body != blank -%}
            <p class="fibre-benefits__body">{{ block.settings.body | escape }}</p>
          {%- endif -%}
        </div>
      </article>
    {%- endfor -%}
  </div>
</div>

{% schema %}
{
  "name": "Fibre benefits",
  "tag": "section",
  "settings": [
    { "type": "header", "content": "Colors" },
    { "type": "color", "id": "page_background_color", "label": "Page background", "default": "#FFFCF4", "info": "Sits behind the band — visible in the top spacer, and around the rounded card on mobile." },
    { "type": "color", "id": "background_color", "label": "Band background", "default": "#FCF5E3" },
    { "type": "color", "id": "card_background_color", "label": "Card background", "default": "#FFFCF4" },
    { "type": "color", "id": "text_color", "label": "Text color", "default": "#333333" },
    { "type": "color", "id": "accent_color", "label": "Accent color", "default": "#333333" },

    { "type": "header", "content": "Spacing" },
    { "type": "range", "id": "padding_top", "min": 0, "max": 200, "step": 4, "unit": "px", "label": "Padding top", "default": 80 },
    { "type": "range", "id": "padding_bottom", "min": 0, "max": 200, "step": 4, "unit": "px", "label": "Padding bottom", "default": 0, "info": "0 by design — no bottom spacer exists on either artboard." },

    { "type": "header", "content": "Layout" },
    { "type": "range", "id": "card_radius", "min": 0, "max": 48, "step": 2, "unit": "px", "label": "Card corner radius", "default": 16 },
    { "type": "range", "id": "container_radius", "min": 0, "max": 48, "step": 2, "unit": "px", "label": "Band corner radius", "default": 32, "info": "Mobile only. The band is full-bleed and square on desktop." }
  ],
  "blocks": [
    {
      "type": "benefit_card",
      "name": "Benefit card",
      "limit": 3,
      "settings": [
        { "type": "header", "content": "Content" },
        {
          "type": "select",
          "id": "icon",
          "label": "Icon",
          "default": "no_chemicals",
          "options": [
            { "value": "no_chemicals", "label": "No chemicals" },
            { "value": "fsc_certified", "label": "FSC certified" },
            { "value": "biodegradable", "label": "Biodegradable" }
          ]
        },
        { "type": "image_picker", "id": "icon_image", "label": "Custom icon image", "info": "Optional. Replaces the built-in icon above." },
        { "type": "inline_richtext", "id": "heading", "label": "Heading", "default": "No chemicals used to grow" },
        { "type": "inline_richtext", "id": "heading_line_2", "label": "Heading second line", "info": "Optional. Joins the heading on one line on desktop, and breaks onto its own line on mobile." },
        { "type": "text", "id": "body", "label": "Body", "default": "Zero pesticides or fertilisers." }
      ]
    }
  ],
  "max_blocks": 3,
  "presets": [
    {
      "name": "Fibre benefits",
      "blocks": [
        {
          "type": "benefit_card",
          "settings": {
            "icon": "no_chemicals",
            "heading": "No chemicals used to grow",
            "body": "Zero pesticides or fertilisers."
          }
        },
        {
          "type": "benefit_card",
          "settings": {
            "icon": "fsc_certified",
            "heading": "Grown sustainably",
            "heading_line_2": "— FSC Certified",
            "body": "Every tree is traced back to responsibly managed forests."
          }
        },
        {
          "type": "benefit_card",
          "settings": {
            "icon": "biodegradable",
            "heading": "Too natural for landfills",
            "body": "Biodegradable, compostable and gone in 130 days."
          }
        }
      ]
    }
  ]
}
{% endschema %}
