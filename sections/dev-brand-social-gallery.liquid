{{ 'dev-brand-social-gallery.css' | asset_url | stylesheet_tag }}
{%- comment -%} No JS: Brief → Interactivity: none. Static badge + 4-image gallery grid. {%- endcomment -%}

{%- comment -%} Fixed design tokens from Figma — not merchant-controlled {%- endcomment -%}
<style>
  .brand-social-gallery {

    /* No --container-max: Brief note #1 — no centred max-width frame exists in this
       node, exactly as for dev-site-header. The desktop inset comes entirely from
       --section-px, and on mobile the grid is genuinely edge-to-edge (Brief note #2),
       so the horizontal padding lives on __inner and drops to 0 at ≤768px. */
    --section-px: 64px;
    --section-px-mobile: 0px;

    /* Mobile artboard specifies its own top spacer (48px), not a scale factor. */
    --pt-mobile: 48px;

    --font-heading-size: 32px;
    --font-heading-size-mobile: 24px;
    --font-heading-weight: 500;
    --font-heading-lh: 1.2;
    --font-body-size: 16px;
    --font-body-size-mobile: 14px;
    --font-body-weight: 500;
    --font-body-lh: 1.4;

    --spacing-sm: 2px;   /* gap between grid tiles (both breakpoints) */
    --spacing-md: 16px;  /* gap inside the text column */
    --spacing-lg: 32px;  /* gap between the text column and the grid */
    --spacing-md-mobile: 8px;
    --spacing-lg-mobile: 16px;

    /* Rounded on desktop, square on mobile — the mobile Grid node carries no
       corner-radius class because it is full-bleed (Brief note #2). */
    --radius-gallery: 32px;
    --radius-gallery-mobile: 0px;

    --social-text-w: 327px;
    --social-handle-w-mobile: 122px;

    /* The grid's own width on the 1440 artboard: 1312 (inner) - 327 (text col) - 32 (gap) = 953.
       Read off the artboard, not invented. Once the row stacks (see the ≤1200 block in the CSS)
       the grid would otherwise span the full inner width and the tiles would balloon PAST their
       designed size; capping it here keeps them at the artboard's ~236px across the stack. */
    --social-grid-w: 953px;

    /* Profile badge: a single full 58px circle — ring and content are one image,
       no longer split into a ring layer + inset mark. */
    --badge-size: 58px;
  }
</style>

{%- liquid
  assign badge_image = section.settings.profile_badge_logo
  assign badge_src = badge_image | image_url: width: 174
-%}

<div
  class="brand-social-gallery"
  style="
    --bg: {{ section.settings.background_color }};
    --color: {{ section.settings.text_color }};
    --accent: {{ section.settings.accent_color }};
    --pt: {{ section.settings.padding_top }}px;
    --pb: {{ section.settings.padding_bottom }}px;
  "
>
  <div class="brand-social-gallery__inner">
    <div class="brand-social-gallery__intro">
      {%- comment -%}
        Profile badge — a single full circle (Brief note #5): the ring and the
        green/white mark are one image, no longer split into a ring layer + inset
        mark. The accent and wordmark are baked into the artwork, not live CSS
        colours. Merchant image wins; when unset we fall back to the vector
        exported from Figma (.figma-assets/brand-social-gallery/), pasted verbatim.
      {%- endcomment -%}
      <div class="brand-social-gallery__badge" aria-hidden="true">
        {%- if badge_image != blank -%}
          {{
            badge_src
            | image_tag:
              loading: 'lazy',
              widths: '58, 116, 174',
              sizes: '58px',
              alt: '',
              class: 'brand-social-gallery__badge-img'
          }}
        {%- else -%}
