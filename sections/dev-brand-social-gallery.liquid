</g>
</g>
</g>
</g>
</svg>
        {%- endif -%}
      </div>

      {%- if section.settings.heading != blank -%}
        <h2 class="brand-social-gallery__heading">{{ section.settings.heading }}</h2>
      {%- endif -%}

      {%- if section.settings.social_handle != blank -%}
        <p class="brand-social-gallery__handle">
          {%- if section.settings.social_handle_link != blank -%}
            <a
              class="brand-social-gallery__handle-link"
              href="{{ section.settings.social_handle_link }}"
              target="_blank"
              rel="noopener"
            >{{ section.settings.social_handle | escape }}</a>
          {%- else -%}
            {{ section.settings.social_handle | escape }}
          {%- endif -%}
        </p>
      {%- endif -%}
    </div>

    {%- if section.blocks.size > 0 -%}
      <div class="brand-social-gallery__grid">
        {%- for block in section.blocks -%}
          <figure class="brand-social-gallery__tile" {{ block.shopify_attributes }}>
            {%- if block.settings.image != blank -%}
              {%- liquid
                assign tile_src = block.settings.image | image_url: width: 800
                assign tile_alt = block.settings.alt | default: block.settings.image.alt | escape
              -%}
              {{
                tile_src
                | image_tag:
                  loading: 'lazy',
                  widths: '200, 300, 400, 600, 800',
                  sizes: '(min-width: 769px) 20vw, 50vw',
                  alt: tile_alt,
                  class: 'brand-social-gallery__image'
              }}
            {%- endif -%}
          </figure>
        {%- endfor -%}
      </div>
    {%- endif -%}
  </div>
</div>

{% schema %}
{
  "name": "Brand social gallery",
  "tag": "section",
  "settings": [
    { "type": "header", "content": "Content" },
    { "type": "inline_richtext", "id": "heading", "label": "Heading", "default": "Larke, lived in." },
    { "type": "text", "id": "social_handle", "label": "Social handle", "default": "@wearelarke.com" },
    {
      "type": "url",
      "id": "social_handle_link",
      "label": "Social handle link",
      "info": "Wraps the handle in a link (opens in a new tab) when set."
    },
    {
      "type": "image_picker",
      "id": "profile_badge_logo",
      "label": "Profile badge",
      "info": "58×58 circle — the whole badge is one image. Falls back to the Figma vector when empty."
    },

    { "type": "header", "content": "Colors" },
    { "type": "color", "id": "background_color", "label": "Background", "default": "#FFFCF4" },
    { "type": "color", "id": "text_color", "label": "Text color", "default": "#333333" },
    { "type": "color", "id": "accent_color", "label": "Accent color", "default": "#4EA448" },

    { "type": "header", "content": "Spacing" },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px",
      "label": "Padding top",
      "default": 80
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px",
      "label": "Padding bottom",
      "default": 0,
      "info": "The Figma node has no bottom spacer — the next section's top spacer creates the gap."
    }
  ],
  "blocks": [
    {
      "type": "gallery_image",
      "name": "Gallery image",
      "limit": 4,
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Image" },
        { "type": "text", "id": "alt", "label": "Alt text", "info": "Describes the photo for screen readers." }
      ]
    }
  ],
  "max_blocks": 4,
  "presets": [
    {
      "name": "Brand social gallery",
      "blocks": [
        { "type": "gallery_image" },
        { "type": "gallery_image" },
        { "type": "gallery_image" },
        { "type": "gallery_image" }
      ]
    }
  ]
}
{% endschema %}
