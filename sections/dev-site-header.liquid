        </svg>
        <svg
          class="site-header__logo-mark site-header__logo-mark--mobile"
          viewBox="0 0 110 33.0161"
          fill="none"
          xmlns="http://www.w3.org/2000/svg"
          aria-hidden="true"
          focusable="false"
        >
          <path d="M83.3138 32.4672C79.0494 32.3267 77.7032 28.4072 76.1952 24.6343C75.8106 23.6666 75.0322 23.0317 74.0432 22.4272C74.034 22.238 74.6873 21.6916 74.9803 21.6061C77.3735 20.9284 79.3455 19.4601 79.8797 16.9967C80.0567 16.1847 79.7668 14.9881 79.2906 14.402C78.8724 13.8892 77.6025 13.4649 76.9126 13.5962C73.5456 14.2341 72.1658 16.9906 72.2483 20.0584L72.5718 32.2748H65.4807C65.6211 29.9763 65.7677 27.8578 65.7677 25.547L65.7585 5.42747C65.7585 3.62646 65.5998 2.03607 65.4502 0H72.6207C72.465 2.34438 72.3154 4.24307 72.3185 6.33409L72.3337 15.8734C74.6629 12.3507 77.9718 10.0674 82.0073 10.5161C83.8511 10.7206 85.411 11.7371 86.0978 13.1444C86.9372 14.866 86.6381 16.7861 85.411 18.3246C83.5611 20.6476 80.7741 21.6122 77.8925 22.1006C84.1716 22.9676 83.9824 26.9725 86.8518 31.0874C87.6607 31.0935 88.198 31.5727 88.0453 32.2565C86.5251 32.3969 84.8707 32.516 83.3108 32.4641L83.3138 32.4672Z" fill="currentColor"/>
