{{ 'dev-site-header.css' | asset_url | stylesheet_tag }}
<script src="{{ 'dev-site-header.js' | asset_url }}" defer></script>

{%- comment -%} Fixed design tokens from Figma — not merchant-controlled {%- endcomment -%}
<style>
  .site-header {

    /* Horizontal gutters. No --container-max: this header is full-bleed by
       design (Brief note #1 — no centred max-width frame exists in Figma);
       the inset comes entirely from --section-px. */
    --section-px: 64px;
    --section-px-mobile: 16px;

    /* Mobile artboard specifies its own fixed padding, not a scale factor. */
    --pt-mobile: 16px;
    --pb-mobile: 16px;

    --spacing-sm: 7px;
    --radius-icon-btn: 60px;
    --icon-size: 24px;

    /* Two DISTINCT logo assets (Brief note #4), not one scaled by CSS.
       Desktop mark is 140x42 (viewBox 140 42).
       Mobile mark is 110x33.016 (viewBox 110 33.0161) centred in a 124x34 box.
       Rendered size must equal the viewBox aspect or QA fails it. */
    --logo-aspect: 140 / 42;
    --logo-mobile-w: 110px;
    --logo-mobile-h: 33.016px;
    --logo-mobile-box-w: 124px;
    --logo-mobile-box-h: 34px;
  }
</style>

{%- liquid
  assign logo_image = section.settings.logo
  assign logo_w = section.settings.logo_width
  assign logo_link_label = 'accessibility.home_logo_alt' | t: store_name: shop.name
  assign logo_alt = logo_image.alt | default: shop.name | escape
  assign logo_sizes = '(max-width: 768px) 124px, ' | append: logo_w | append: 'px'
  assign logo_src = logo_image | image_url: width: 560
  assign cart_label = 'accessibility.cart' | t
  assign cart_label = cart_label | append: ', ' | append: cart.item_count
-%}

<header
  class="site-header"
  style="
    --bg: {{ section.settings.background_color }};
    --color: {{ section.settings.text_color }};
    --accent: {{ section.settings.accent_color }};
    --pt: {{ section.settings.padding_top }}px;
    --pb: {{ section.settings.padding_bottom }}px;
    --logo-w: {{ logo_w }}px;
  "
  data-menu-open="false"
>
  <div class="site-header__inner">
    {%- comment -%}
      Hamburger. The drawer it opens was NOT exported in the Figma nodes for this
      section (Brief note #6) — this section owns the trigger + aria state only and
      announces `site-header:menu-toggle`; it must not invent the drawer's layout.
    {%- endcomment -%}
    <button
      type="button"
      class="site-header__menu-toggle"
      aria-label="{{ 'accessibility.menu' | t }}"
      aria-haspopup="true"
      aria-expanded="false"
      aria-controls="menu-drawer"
    >
      <svg
        class="site-header__menu-icon"
        viewBox="0 0 24 24"
        fill="none"
        xmlns="http://www.w3.org/2000/svg"
        aria-hidden="true"
        focusable="false"
      >
        <path d="M4 6H20M4 12H20M4 18H20" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    </button>

    <a href="{{ routes.root_url }}" class="site-header__logo" aria-label="{{ logo_link_label | escape }}">
      {%- if logo_image != blank -%}
        {{
          logo_src
          | image_tag:
            loading: 'eager',
            widths: '140, 280, 420, 560',
            sizes: logo_sizes,
            alt: logo_alt,
            class: 'site-header__logo-image'
        }}
      {%- else -%}
        <svg
          class="site-header__logo-mark site-header__logo-mark--desktop"
          viewBox="0 0 140 42"
          fill="none"
          xmlns="http://www.w3.org/2000/svg"
          aria-hidden="true"
          focusable="false"
