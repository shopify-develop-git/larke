        </svg>
      {%- endif -%}
    </a>

    {%- comment -%}
      Cart. Stays a real link to /cart so it works with no JS and before the cart
      drawer component exists; the JS upgrades it to a drawer trigger if one is present.
    {%- endcomment -%}
    <a
      href="{{ routes.cart_url }}"
      class="site-header__cart-toggle"
      aria-haspopup="true"
      aria-expanded="false"
      aria-controls="cart-drawer"
      aria-label="{{ cart_label | escape }}"
    >
      <svg
        class="site-header__cart-icon"
        viewBox="0 0 24 24"
        fill="none"
        xmlns="http://www.w3.org/2000/svg"
        aria-hidden="true"
        focusable="false"
      >
        <path d="M16 11V7C16 4.79086 14.2091 3 12 3C9.79086 3 8 4.79086 8 7V11M5 9H19L20 21H4L5 9Z" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
      {%- if section.settings.show_cart_count and cart.item_count > 0 -%}
        <span class="site-header__cart-count" aria-hidden="true">{{ cart.item_count }}</span>
      {%- endif -%}
    </a>
  </div>
</header>

{%- comment -%}
  The menu and cart drawers, as blocks. They render OUTSIDE <header> on purpose: they are
  role="dialog" overlays, not part of the banner landmark. They were sections once, which
  meant re-adding and re-configuring them in every template; as blocks of the header they
  are configured once and travel with the triggers above that open them.
{%- endcomment -%}
{% content_for 'blocks' %}

{% schema %}
{
  "name": "Header",
  "tag": "section",
  "blocks": [
    { "type": "dev-menu-drawer" },
    { "type": "dev-cart-drawer" }
  ],
  "max_blocks": 2,
  "presets": [
    { "name": "Header" }
  ],
  "settings": [
    { "type": "header", "content": "Content" },
    { "type": "image_picker", "id": "logo", "label": "Logo" },
    { "type": "range", "id": "logo_width", "min": 80, "max": 240, "step": 2, "unit": "px", "label": "Logo width", "default": 140 },
    { "type": "link_list", "id": "menu", "label": "Menu" },
    { "type": "checkbox", "id": "show_cart_count", "label": "Show cart count", "default": true },

    { "type": "header", "content": "Colors" },
    { "type": "color", "id": "background_color", "label": "Background", "default": "#FFFCF4" },
    { "type": "color", "id": "text_color", "label": "Text color", "default": "#333333" },
    { "type": "color", "id": "accent_color", "label": "Accent color", "default": "#4EA448" },

    { "type": "header", "content": "Spacing" },
    { "type": "range", "id": "padding_top", "min": 0, "max": 100, "step": 4, "unit": "px", "label": "Padding top", "default": 24 },
    { "type": "range", "id": "padding_bottom", "min": 0, "max": 100, "step": 4, "unit": "px", "label": "Padding bottom", "default": 24 }
  ]
}
{% endschema %}
