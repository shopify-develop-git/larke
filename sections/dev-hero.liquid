{{ 'dev-hero.css' | asset_url | stylesheet_tag }}
{%- comment -%}
  No JS tag: the Brief's Interactivity section is "none" — static photo, static copy, one CTA link.
  Adding a dev-hero.js here would load an empty file on every page for nothing.
{%- endcomment -%}

{%- comment -%} Fixed design tokens from Figma — not merchant-controlled {%- endcomment -%}
<style>
  .hero {
    /* Brand params (Brief → Brand Params). The faces themselves are loaded theme-wide by
       snippets/dev-brand-fonts.liquid — this only selects them.
       --container-max is deliberately absent: full-bleed section, no inner max-width frame
       (Brief, Note 1 — same call already made in dev-site-header.css). */
    --section-px: 64px;
    --section-px-m: 24px;

    /* The mobile artboard states its own paddings (24px), so they are fixed tokens, not a
       scale factor off --pt/--pb. Same precedent as dev-site-header. */
    --pt-m: 24px;
    --pb-m: 24px;

    /* Typography — desktop / mobile */
    --font-heading-size: 48px;
    --font-heading-size-m: 32px;
    --font-heading-weight: 500;
    --font-heading-lh: 1.2;
    --font-heading-ls: 0px;
    --font-heading-ls-m: 0.5px;

    --font-body-size: 20px;
    --font-body-size-m: 18px;
    --font-body-weight: 500;
    --font-body-lh: 1.4;

    /* The italic run ("trees") is Medium Italic on desktop but Bold Italic on mobile.
       Confirmed intentional in the source data — Brief, Note 3. Do not normalise. */
    --em-weight: 500;
    --em-weight-m: 700;

    /* Spacing */
    --spacing-sm: 8px;
    --spacing-md: 24px;
    --spacing-lg: 64px;

    /* Frame — 550px tall on BOTH artboards (Brief, Note 4: not responsive) */
    --hero-min-h: 550px;
    --radius-bottom: 32px;
    --text-col-w: 533px;

    /* CTA */
    --cta-size: 18px;
    --cta-weight: 700;
    --cta-lh: 1.4;
    --cta-py: 18px;
    --cta-px: 24px;
    --radius-cta: 60px;

    /* ---- Background photo framing ----------------------------------------------
       Figma's MOBILE fill is width:113.45% / height:116.06% of the 375x550 box.
       425.44 / 638.33 = 0.6665 — exactly the aspect of the real source (2730x4096),
       which proves hero-bg.jpg IS that fill. Used verbatim.

       Figma's DESKTOP numbers (height:432.11%, top:-149.36%) belong to a different,
       differently-cropped export whose aspect is 0.606 — feeding them to the 0.6665
       source would stretch the photo ~10% vertically. So the desktop fill is re-derived
       instead: same visible band of the photo, no distortion.
         width 100% (1440px) -> height 1440 * 4096/2730 = 2160.6px = 392.83% of 550
         Figma shows the band 34.57%..57.71% of the photo's height (centre 46.14%)
         top = 275 - (0.46137 * 2160.6) = -721.9px = -131.25% of 550
       object-fit: cover in the CSS is a belt-and-braces against sub-pixel aspect drift. */
    --bg-w-d: 100%;
    --bg-h-d: 392.83%;
    --bg-top-d: -131.25%;
    --bg-left-d: 0%;

    --bg-w-m: 113.45%;
    --bg-h-m: 116.06%;
    --bg-top-m: -14.55%;
    --bg-left-m: -6.73%;

    /* ---- Decorative squiggle ("Vector 3") ---------------------------------------
       The stroke rides on the <em>, as a MASK on its ::after — the same construction as
       dev-tree-fibre-hero and dev-values-we-cherish.

       It used to be an inline <svg> pinned to measured coordinates inside .hero__text:
         --squiggle-x: 195.48px; --squiggle-y: -3.3px  (and 173.48px on mobile)
       Those numbers are exactly where the word "trees" happens to fall on the artboard. The
       setting says "Wrap a word in italics to emphasise it" — so a merchant italicises some
       other word, and the squiggle stays behind, underlining thin air. The artwork was never
       attached to the emphasis at all; it only looked like it was, for one sentence.

       Riding the <em> means it follows whatever is italicised, at any width, for one run or
       five. The mask stretches (preserveAspectRatio="none" in the asset), which is correct
       HERE and would have been a bug for the old free-standing <svg> — a mask has no aspect
       of its own to preserve, it is the shape of the box it is painting.

       Height 5.89px is the real drawn height off the artboard: Figma's node box is 49x3, but
       the art overflows it (inset -46.73% -1.12% -49.98% -1.07%), so the box is an ANCHOR,
       not the size. w = 49 * 1.0219 = 50.07, h = 3 * 1.9671 = 5.90. */
    --underline: url('{{ 'dev-hero-underline.svg' | asset_url }}');
    --underline-h: 5.89px;
    --underline-gap: -2px;
    --underline-h-m: 5px;
    --underline-gap-m: -2px;

    /* ---- Effects -----------------------------------------------------------------
       The Brief's binding token (Figma style "Text Shadow/lg") is:
         0 4px 40px rgba(50,44,45,0.6), 0 0 15px rgba(50,44,45,0.8)
       An earlier pass doubled these to 80px/30px, reasoning from the exported SVG's
       filter0_dd (stdDeviation 15 and 40) via the SVG rule blur = 2 x stdDeviation.
       That reasoning is right about SVG but wrong about the source of truth: 15 and 40
       are the blur values as AUTHORED in Figma, and Figma's canvas — which is what QA
       pixel-diffs — renders them on the same "blur radius" convention CSS uses. The
       exported SVG writing stdDeviation="15" for a blur-15 shadow is a Figma export
       quirk (it should be 7.5); following it makes the shadow twice as soft as the
       artboard. So: use the authored values verbatim.
       Colours confirmed against the export's feColorMatrix — 0.196078/0.172549/0.176471
       = rgb(50,44,45), at 0.8 and 0.6 alpha. Both agree; only the blur was in dispute.

       text-shadow does not reach SVG, so the squiggle re-states the same two shadows as
       drop-shadow filters. CSS drop-shadow() takes the same blur-radius convention as
       text-shadow, so the numbers are identical and the two stay visually welded. */
    --text-shadow: 0 4px 40px rgba(50, 44, 45, 0.6), 0 0 15px rgba(50, 44, 45, 0.8);
    --squiggle-shadow: drop-shadow(0 4px 40px rgba(50, 44, 45, 0.6))
      drop-shadow(0 0 15px rgba(50, 44, 45, 0.8));

    /* Figma reports the scrim angle as 0.1487deg (desktop) / 0.5712deg (mobile). Brief
       Note 4 is explicit that both are floating-point noise and are to be treated as
       0deg — a bottom-anchored scrim, not a deliberate tilt. At 0deg the two breakpoints
       become the same gradient, so there is one token, not two. */
    --overlay: linear-gradient(0deg, rgba(0, 0, 0, 0.4) 6.42%, rgba(0, 0, 0, 0) 60.23%);

    /* Fixed, like every other button on the site. No section lets a merchant recolour one. */
    --cta-text: #333333;
  }
</style>

{%- liquid
  assign bg_desktop = section.settings.background_image
  assign bg_mobile = section.settings.background_image_mobile
  if bg_mobile == blank
    assign bg_mobile = bg_desktop
  endif

  assign cta_link = section.settings.cta_link
  if cta_link == blank
    assign cta_link = routes.root_url
  endif

  # richtext: already-safe HTML from Shopify — never escape it. The <p> wrapper is unwrapped so
  # the copy stays inline inside the <h1> (same idiom as dev-featured-product).
  assign heading_html = section.settings.heading | remove: '<p>' | remove: '</p>'
  assign cta_label = section.settings.cta_label | escape
-%}

<div
  class="hero{% if section.settings.show_underline_accent %} hero--underline{% endif %}{% if section.settings.stretch_background %} hero--stretch-bg{% endif %}"
  style="
    --bg: {{ section.settings.background_color }};
    --color: {{ section.settings.text_color }};
    --accent: {{ section.settings.accent_color }};
    --pt: {{ section.settings.padding_top }}px;
    --pb: {{ section.settings.padding_bottom }}px;
  "
>
  <div class="hero__bg-layer">
    {%- if bg_desktop != blank -%}
      {{
        bg_desktop
        | image_url: width: 3200
        | image_tag:
          loading: 'eager',
          fetchpriority: 'high',
          widths: '800, 1200, 1600, 2000, 2600, 3200',
          sizes: '100vw',
          alt: '',
          class: 'hero__bg hero__bg--desktop'
      }}
    {%- endif -%}

    {%- if bg_mobile != blank -%}
      {{
        bg_mobile
        | image_url: width: 1600
        | image_tag:
          loading: 'eager',
          fetchpriority: 'high',
          widths: '400, 600, 800, 1200, 1600',
          sizes: '115vw',
          alt: '',
          class: 'hero__bg hero__bg--mobile'
      }}
    {%- endif -%}

    <span class="hero__overlay" aria-hidden="true"></span>
  </div>

  <div class="hero__content">
    {%- if section.settings.heading != blank or section.settings.subtext != blank -%}
      <div class="hero__text">
        {%- if section.settings.heading != blank -%}
          <h1 class="hero__heading">{{ heading_html }}</h1>
        {%- endif -%}

        {%- if section.settings.subtext != blank -%}
          <div class="hero__subtext">{{ section.settings.subtext }}</div>
        {%- endif -%}


      </div>
    {%- endif -%}

    {%- if section.settings.cta_label != blank -%}
      <div class="hero__actions">
        {%- render 'dev-button', variant: 'filled', label: cta_label, link: cta_link, class: 'hero__button' -%}
      </div>
    {%- endif -%}
  </div>
</div>

{% schema %}
{
  "name": "Hero",
  "tag": "section",
  "presets": [
    { "name": "Hero" }
  ],
  "settings": [
    { "type": "header", "content": "Content" },
    {
      "type": "richtext",
      "id": "heading",
      "label": "Heading",
      "info": "Use a line break to split the heading across two lines.",
      "default": "<p>Not just any<br/>ordinary duvet</p>"
    },
    {
      "type": "richtext",
      "id": "subtext",
      "label": "Subtext",
      "info": "Wrap a word in italics to emphasise it.",
      "default": "<p>This one begins with <em>trees</em>.</p>"
    },
    { "type": "text", "id": "cta_label", "label": "Button label", "default": "Discover Our Duvet" },
    { "type": "url", "id": "cta_link", "label": "Button link" },
    { "type": "image_picker", "id": "background_image", "label": "Background image (desktop)" },
    {
      "type": "image_picker",
      "id": "background_image_mobile",
      "label": "Background image (mobile)",
      "info": "Falls back to the desktop image when empty."
    },
    {
      "type": "checkbox",
      "id": "stretch_background",
      "label": "Stretch the background to the Figma crop",
      "info": "Off, the photo simply fills the frame. On, it is blown up to ~393% of the frame's height and pulled up out of it — the trick that lets ONE image supply both the desktop slice and a different mobile slice. Those offsets were measured against the original photo, so a different picture will land somewhere else.",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "show_underline_accent",
      "label": "Show underline accent",
      "info": "Decorative squiggle beneath the emphasised word.",
      "default": true
    },

    { "type": "header", "content": "Colors" },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background",
      "info": "Sits behind the photo — only visible if no image is set.",
      "default": "#333333"
    },
    { "type": "color", "id": "text_color", "label": "Text color", "default": "#FFFFFF" },
    { "type": "color", "id": "accent_color", "label": "Accent color", "default": "#A8CF78" },

    { "type": "header", "content": "Spacing" },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px",
      "label": "Padding top",
      "default": 64
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px",
      "label": "Padding bottom",
      "default": 64
    }
  ]
}
{% endschema %}
