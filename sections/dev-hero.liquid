{{ 'dev-hero.css' | asset_url | stylesheet_tag }}
{%- comment -%}
  No JS tag: the Brief's Interactivity section is "none" — static photo, static copy, one CTA link.
  Adding a dev-hero.js here would load an empty file on every page for nothing.
{%- endcomment -%}

{%- comment -%} Fixed design tokens from Figma — not merchant-controlled {%- endcomment -%}
<style>
  .hero {
    /* Brand params (Brief → Brand Params). The faces themselves are loaded theme-wide by
       snippets/dev-brand-fonts.liquid — this only selects them.
       --container-max is deliberately absent: full-bleed section, no inner max-width frame
       (Brief, Note 1 — same call already made in dev-site-header.css). */
    --font-body: 'Public Sans', sans-serif;
    --font-heading: 'Test Tiempos Headline', serif;
    --section-px: 64px;
    --section-px-m: 24px;

    /* The mobile artboard states its own paddings (24px), so they are fixed tokens, not a
       scale factor off --pt/--pb. Same precedent as dev-site-header. */
    --pt-m: 24px;
    --pb-m: 24px;

    /* Typography — desktop / mobile */
    --font-heading-size: 48px;
    --font-heading-size-m: 32px;
    --font-heading-weight: 500;
    --font-heading-lh: 1.2;
    --font-heading-ls: 0px;
    --font-heading-ls-m: 0.5px;

    --font-body-size: 20px;
    --font-body-size-m: 18px;
    --font-body-weight: 500;
    --font-body-lh: 1.4;

    /* The italic run ("trees") is Medium Italic on desktop but Bold Italic on mobile.
       Confirmed intentional in the source data — Brief, Note 3. Do not normalise. */
    --em-weight: 500;
    --em-weight-m: 700;

    /* Spacing */
    --spacing-sm: 8px;
    --spacing-md: 24px;
    --spacing-lg: 64px;

    /* Frame — 550px tall on BOTH artboards (Brief, Note 4: not responsive) */
    --hero-min-h: 550px;
    --radius-bottom: 32px;
    --text-col-w: 533px;

    /* CTA */
    --cta-size: 18px;
    --cta-weight: 700;
    --cta-lh: 1.4;
    --cta-py: 18px;
    --cta-px: 24px;
    --radius-cta: 60px;

    /* ---- Background photo framing ----------------------------------------------
       Figma's MOBILE fill is width:113.45% / height:116.06% of the 375x550 box.
       425.44 / 638.33 = 0.6665 — exactly the aspect of the real source (2730x4096),
       which proves hero-bg.jpg IS that fill. Used verbatim.

       Figma's DESKTOP numbers (height:432.11%, top:-149.36%) belong to a different,
       differently-cropped export whose aspect is 0.606 — feeding them to the 0.6665
       source would stretch the photo ~10% vertically. So the desktop fill is re-derived
       instead: same visible band of the photo, no distortion.
         width 100% (1440px) -> height 1440 * 4096/2730 = 2160.6px = 392.83% of 550
         Figma shows the band 34.57%..57.71% of the photo's height (centre 46.14%)
         top = 275 - (0.46137 * 2160.6) = -721.9px = -131.25% of 550
       object-fit: cover in the CSS is a belt-and-braces against sub-pixel aspect drift. */
    --bg-w-d: 100%;
    --bg-h-d: 392.83%;
    --bg-top-d: -131.25%;
    --bg-left-d: 0%;

    --bg-w-m: 113.45%;
    --bg-h-m: 116.06%;
    --bg-top-m: -14.55%;
    --bg-left-m: -6.73%;

    /* ---- Decorative squiggle ("Vector 3") ---------------------------------------
       READ BEFORE CHANGING A NUMBER HERE.
       Figma's node box is 49x3, but Figma then overflows the artwork out of that box with
       inset: -46.73% -1.12% -49.98% -1.07%. The box is an ANCHOR, not the size.
       Real drawn size:
         w = 49 * (1 + .0112 + .0107) = 50.07px
         h = 3  * (1 + .4673 + .4998) = 5.90px   -> 50.07/5.90 = 8.49 ~= viewBox 51/6 = 8.5
       Sizing the <svg> to the 49x3 anchor is the bug that shipped once: SVG preserves aspect,
       so the art scaled to half and floated in an empty box. The height below is 50.07/8.5 =
       5.89px, so the rendered aspect equals the viewBox aspect EXACTLY. And never reach for
       preserveAspectRatio="none" to "make it fit" — that is the same bug wearing a different
       hat; QA fails any inline SVG more than 2% off its viewBox aspect.

       Placement — the squiggle underlines "trees", the last word of the subtext. It is
       anchored to the heading+subtext group (.hero__text):
         desktop  x 196 -> 196 - (1.07% * 49) = 195.48px from the group's left edge
                  y 150 -> real top 148.60px; the group is 151.2px tall (115.2 + 8 + 28),
                           so the art's bottom sits 3.3px BELOW it  -> bottom: -3.3px
         mobile   x 198 (frame) - 24 (padding) = 174 -> 173.48px from the group's left edge
                  y 443 (frame) -> real top 441.60px; group top 330.8, height 110,
                           so the art's bottom sits 6.7px below it  -> bottom: -6.7px
       Anchoring on `bottom` rather than `top` keeps it welded to the subtext baseline even if
       line-height rounds differently in the browser than it did in Figma. */
    --squiggle-w: 50.07px;
    --squiggle-h: 5.89px;
    --squiggle-x: 195.48px;
    --squiggle-y: -3.3px;
    --squiggle-x-m: 173.48px;
    --squiggle-y-m: -6.7px;

    /* ---- Effects -----------------------------------------------------------------
       The Brief's binding token (Figma style "Text Shadow/lg") is:
         0 4px 40px rgba(50,44,45,0.6), 0 0 15px rgba(50,44,45,0.8)
       An earlier pass doubled these to 80px/30px, reasoning from the exported SVG's
       filter0_dd (stdDeviation 15 and 40) via the SVG rule blur = 2 x stdDeviation.
       That reasoning is right about SVG but wrong about the source of truth: 15 and 40
       are the blur values as AUTHORED in Figma, and Figma's canvas — which is what QA
       pixel-diffs — renders them on the same "blur radius" convention CSS uses. The
       exported SVG writing stdDeviation="15" for a blur-15 shadow is a Figma export
       quirk (it should be 7.5); following it makes the shadow twice as soft as the
       artboard. So: use the authored values verbatim.
       Colours confirmed against the export's feColorMatrix — 0.196078/0.172549/0.176471
       = rgb(50,44,45), at 0.8 and 0.6 alpha. Both agree; only the blur was in dispute.

       text-shadow does not reach SVG, so the squiggle re-states the same two shadows as
       drop-shadow filters. CSS drop-shadow() takes the same blur-radius convention as
       text-shadow, so the numbers are identical and the two stay visually welded. */
    --text-shadow: 0 4px 40px rgba(50, 44, 45, 0.6), 0 0 15px rgba(50, 44, 45, 0.8);
    --squiggle-shadow: drop-shadow(0 4px 40px rgba(50, 44, 45, 0.6))
      drop-shadow(0 0 15px rgba(50, 44, 45, 0.8));

    /* Figma reports the scrim angle as 0.1487deg (desktop) / 0.5712deg (mobile). Brief
       Note 4 is explicit that both are floating-point noise and are to be treated as
       0deg — a bottom-anchored scrim, not a deliberate tilt. At 0deg the two breakpoints
       become the same gradient, so there is one token, not two. */
    --overlay: linear-gradient(0deg, rgba(0, 0, 0, 0.4) 6.42%, rgba(0, 0, 0, 0) 60.23%);
  }
</style>

{%- liquid
  assign bg_desktop = section.settings.background_image
  assign bg_mobile = section.settings.background_image_mobile
  if bg_mobile == blank
    assign bg_mobile = bg_desktop
  endif

  assign cta_link = section.settings.cta_link
  if cta_link == blank
    assign cta_link = routes.root_url
  endif

  # richtext: already-safe HTML from Shopify — never escape it. The <p> wrapper is unwrapped so
  # the copy stays inline inside the <h1> (same idiom as dev-featured-product).
  assign heading_html = section.settings.heading | remove: '<p>' | remove: '</p>'
  assign cta_label = section.settings.cta_label | escape
-%}

<div
  class="hero"
  style="
    --bg: {{ section.settings.background_color }};
    --color: {{ section.settings.text_color }};
    --accent: {{ section.settings.accent_color }};
    --cta-text: {{ section.settings.cta_text_color }};
    --pt: {{ section.settings.padding_top }}px;
    --pb: {{ section.settings.padding_bottom }}px;
  "
>
  <div class="hero__bg-layer">
    {%- if bg_desktop != blank -%}
      {{
        bg_desktop
        | image_url: width: 2000
        | image_tag:
          loading: 'eager',
          fetchpriority: 'high',
          widths: '800, 1200, 1600, 2000',
          sizes: '100vw',
          alt: '',
          class: 'hero__bg hero__bg--desktop'
      }}
    {%- endif -%}

    {%- if bg_mobile != blank -%}
      {{
        bg_mobile
        | image_url: width: 1200
        | image_tag:
          loading: 'eager',
          fetchpriority: 'high',
          widths: '400, 600, 800, 1200',
          sizes: '115vw',
          alt: '',
          class: 'hero__bg hero__bg--mobile'
      }}
    {%- endif -%}

    <span class="hero__overlay" aria-hidden="true"></span>
  </div>

  <div class="hero__content">
    {%- if section.settings.heading != blank or section.settings.subtext != blank -%}
      <div class="hero__text">
        {%- if section.settings.heading != blank -%}
          <h1 class="hero__heading">{{ heading_html }}</h1>
        {%- endif -%}

        {%- if section.settings.subtext != blank -%}
          <div class="hero__subtext">{{ section.settings.subtext }}</div>
        {%- endif -%}

        {%- if section.settings.show_underline_accent -%}
          {%- comment -%}
            "Vector 3" — the owner's artwork, exported from Figma by the Assets stage to
            .figma-assets/hero/trees-underline-{desktop,mobile}.svg (both files carry the SAME
            path, confirming it is one element that is merely parented differently per
            breakpoint). The `d` below is pasted byte-for-byte from that export; the
            surrounding frame markup in the export (page background rects, gradient and filter
            defs) belongs to the Figma page, not to this component, and is intentionally left
            out. Verified by:  node .claude/tools/svg-fidelity.mjs --section hero
            Figma fills it #A8CF78 = Green/300 = the --accent default, so it is bound to
            currentColor -> var(--accent) rather than hardcoding the hex (CSS hard rule).
          {%- endcomment -%}
          <svg
            class="hero__squiggle"
            viewBox="0 0 51 6"
            fill="none"
            xmlns="http://www.w3.org/2000/svg"
            aria-hidden="true"
            focusable="false"
          >
            <path d="M0.268694 2.31775C0.154535 2.39893 0.0642739 2.51465 0.023716 2.65116C-0.0168879 2.78758 -0.00521541 2.93214 0.0575678 3.05579C0.120351 3.17945 0.230169 3.27418 0.364266 3.3219C0.498409 3.36971 0.645093 3.36512 0.777998 3.32086C0.777998 3.32086 0.777998 3.32086 0.777998 3.32086C1.49334 3.11785 2.31822 3.00934 3.10374 2.95998C3.27765 2.94918 3.45169 2.94127 3.62596 2.93603C5.68199 2.95463 7.90619 4.50152 10.5044 5.39304C11.1532 5.62327 11.8316 5.77484 12.5113 5.84644C14.7664 6.08402 16.9015 5.51728 18.774 4.7851C20.811 4.04769 22.9781 2.82918 24.4649 2.80421C26.0993 2.82887 28.5108 4.01051 30.9967 4.46492C32.6223 4.77748 34.3134 4.77524 35.8394 4.72452C39.273 4.51614 41.9087 2.65709 44.3764 2.24983L44.291 2.24791C45.1811 2.27749 46.0705 2.31193 46.9544 2.36244C47.3947 2.3879 47.8352 2.41732 48.2672 2.45721L48.2419 2.45306C48.5994 2.5029 49.0218 2.58152 49.4231 2.63207C49.5676 2.65089 49.7157 2.6166 49.8356 2.53181C49.9555 2.44707 50.0374 2.31957 50.0633 2.17639C50.0893 2.03321 50.0573 1.8851 49.9748 1.76367C49.8922 1.6422 49.7655 1.55814 49.6236 1.52508C49.6236 1.52508 49.6236 1.52508 49.6236 1.52508C49.2419 1.43802 48.8904 1.33455 48.4679 1.23294L48.4426 1.22879C47.9916 1.14309 47.5434 1.07073 47.0965 1.00317C46.2001 0.868482 45.3065 0.75415 44.4124 0.647804L44.3271 0.645882C40.9588 0.975498 38.3652 2.53737 35.8474 2.47012C34.2992 2.42387 32.8947 2.34114 31.5048 2.0026C29.3682 1.55165 27.5405 0.27136 24.4394 1.26362e-05C21.4995 0.136196 19.7948 1.35873 17.7157 2.02333C16.051 2.64968 14.3789 3.03164 12.827 2.86311C12.3558 2.81327 11.8962 2.72036 11.4466 2.58203C9.10514 1.95434 6.60964 0.416941 3.3395 1.02954C3.14731 1.07937 2.9565 1.13337 2.76704 1.19175C1.8996 1.46413 1.07822 1.79441 0.268694 2.31775Z" fill="currentColor"/>
          </svg>
        {%- endif -%}
      </div>
    {%- endif -%}

    {%- if section.settings.cta_label != blank -%}
      <div class="hero__actions">
        <a class="hero__button" href="{{ cta_link }}">{{ cta_label }}</a>
      </div>
    {%- endif -%}
  </div>
</div>

{% schema %}
{
  "name": "Hero",
  "tag": "section",
  "presets": [
    { "name": "Hero" }
  ],
  "settings": [
    { "type": "header", "content": "Content" },
    {
      "type": "richtext",
      "id": "heading",
      "label": "Heading",
      "info": "Use a line break to split the heading across two lines.",
      "default": "<p>Not just any<br/>ordinary duvet</p>"
    },
    {
      "type": "richtext",
      "id": "subtext",
      "label": "Subtext",
      "info": "Wrap a word in italics to emphasise it.",
      "default": "<p>This one begins with <em>trees</em>.</p>"
    },
    { "type": "text", "id": "cta_label", "label": "Button label", "default": "Discover Our Duvet" },
    { "type": "url", "id": "cta_link", "label": "Button link" },
    { "type": "image_picker", "id": "background_image", "label": "Background image (desktop)" },
    {
      "type": "image_picker",
      "id": "background_image_mobile",
      "label": "Background image (mobile)",
      "info": "Falls back to the desktop image when empty."
    },
    {
      "type": "checkbox",
      "id": "show_underline_accent",
      "label": "Show underline accent",
      "info": "Decorative squiggle beneath the emphasised word.",
      "default": true
    },

    { "type": "header", "content": "Colors" },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background",
      "info": "Sits behind the photo — only visible if no image is set.",
      "default": "#333333"
    },
    { "type": "color", "id": "text_color", "label": "Text color", "default": "#FFFFFF" },
    { "type": "color", "id": "accent_color", "label": "Accent color", "default": "#A8CF78" },
    { "type": "color", "id": "cta_text_color", "label": "Button text color", "default": "#333333" },

    { "type": "header", "content": "Spacing" },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px",
      "label": "Padding top",
      "default": 64
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px",
      "label": "Padding bottom",
      "default": 64
    }
  ]
}
{% endschema %}
