{{ 'dev-trust-badges.css' | asset_url | stylesheet_tag }}
{%- comment -%} No JS: the Brief's Interactivity section is "none" — static row / static stack. {%- endcomment -%}

{%- comment -%} Fixed design tokens from Figma — not merchant-controlled {%- endcomment -%}
<style>
  .trust-badges {

    /* Full-bleed by design. No --container-max: Brief note #3 — no centred max-width
       frame exists in this section (same precedent as dev-site-header). The inset is
       --section-px only, identical on both artboards (16px at 1440 and at 375). */
    --section-px: 16px;

    /* Mobile artboard specifies its own top padding (48px), not a scale factor. */
    --pt-mobile: 48px;

    --font-heading-size: 22px;
    --font-heading-size-mobile: 20px;
    --font-heading-weight: 500;
    --font-heading-lh: 1.2;
    --font-body-size: 18px;
    --font-body-size-mobile: 14px;
    --font-body-weight: 500;
    --font-body-lh: 1.4;

    --spacing-sm: 8px;  /* icon -> text block */
    --spacing-md: 4px;  /* heading -> description */
    --spacing-lg: 32px; /* badge -> badge */

    --badge-width: 343px;

    /* Figma literal: the mobile heading carries an explicit text-black override that
       the desktop heading does not (Brief note #2 — implemented as read, not "fixed"). */
    --heading-color-mobile: #000000;

    /* Confirmed from the exported artwork itself: every path is #666666 (Neutral/500).
       Drives currentColor on the two inline icons. */
    --icon-color: #666666;

    /* Render size == viewBox, so the art lands at its true Figma size. The Brief's
       "Images" numbers are Figma anchor boxes and the art overflows them; sizing to
       the anchor box would letterbox and shrink the art. */
    --icon-warranty-w: 42px;
    --icon-warranty-h: 41px;
    --icon-trial-w: 45px;
    --icon-trial-h: 40px;
    --icon-delivery-w: 56px;
    --icon-delivery-h: 40px;
  }
</style>

<div
  class="trust-badges"
  style="
    --bg: {{ section.settings.background_color }};
    --color: {{ section.settings.text_color }};
    --accent: {{ section.settings.accent_color }};
    --pt: {{ section.settings.padding_top }}px;
    --pb: {{ section.settings.padding_bottom }}px;
  "
>
  <div class="trust-badges__inner">
    {%- for block in section.blocks -%}
      {%- liquid
        assign icon_key = block.settings.icon
        assign icon_uid = section.id | append: '-' | append: forloop.index
      -%}
      <div class="trust-badges__badge" {{ block.shopify_attributes }}>
        <div class="trust-badges__icon trust-badges__icon--{{ icon_key }}">
          {%- if block.settings.icon_image != blank -%}
            {%- liquid
              assign icon_alt = block.settings.icon_image.alt | default: '' | escape
              assign icon_src = block.settings.icon_image | image_url: width: 120
            -%}
            {{
              icon_src
              | image_tag:
                loading: 'lazy',
                widths: '60, 120',
                sizes: '60px',
                alt: icon_alt,
                class: 'trust-badges__icon-img'
            }}
          {%- elsif icon_key == 'warranty' -%}
            {%- comment -%}
              Asset route, not inline: this Figma export is 248 KB raw (79 KB optimised) and
              inlining it would blow Shopify's 256 KB template cap. Keeps its baked #666666,
              so it does not follow currentColor.
            {%- endcomment -%}
            <img
              class="trust-badges__icon-img"
              src="{{ 'dev-trust-badges-warranty.svg' | asset_url }}"
              width="42"
              height="41"
              alt=""
              loading="lazy"
            >
          {%- elsif icon_key == 'trial' -%}
