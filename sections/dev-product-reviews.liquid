{{ 'dev-product-reviews.css' | asset_url | stylesheet_tag }}

{%- comment -%} Fixed design tokens from Figma — not merchant-controlled {%- endcomment -%}
<style>
  .dev-product-reviews {
    --font-body: 'Public Sans', sans-serif;
    --font-heading: 'Test Tiempos Headline', serif;

    /* A 644px column dead-centre on the 1440 artboard. Expressed as a max-width, not as 398px of
       padding a side, so it survives a narrower viewport. */
    --container-max: 644px;
    --section-px: 64px;
    --section-px-mobile: 16px;
    --pt: 40px;

    --font-title-size: 32px;
    --font-title-size-mobile: 24px;
    --font-card-title-size: 20px;
    --font-stars-size: 24px;
    --font-heading-weight: 500;
    --font-heading-lh: 1.2;

    --font-lg: 18px;
    --font-md: 16px;
    --font-sm: 14px;
    --font-body-lh: 1.4;
    --w-medium: 500;
    --w-bold: 700;

    --stack-gap: 64px;
    --block-gap: 24px;
    --head-gap: 8px;
    --card-gap: 16px;
    --card-pad: 24px;
    --card-radius: 16px;

    --bars-w: 343px;
    --bar-h: 26px;
    --bar-track-w: 260px;
    --bar-track-h: 6px;
    --bar-radius: 60px;

    --badge-pad: 4px 8px;
    --badge-radius: 8px;

    /* Inside-stroke correction: Figma draws the button 1px stroke INSIDE, so border + padding must
       add up to its 24/18px inset, not repeat it. */
    --button-pad: 17px 23px;
    --button-radius: 60px;
  }
</style>

{%- liquid
  assign reviews = section.blocks | where: 'type', 'review'

  assign c5 = section.settings.count_5 | plus: 0
  assign c4 = section.settings.count_4 | plus: 0
  assign c3 = section.settings.count_3 | plus: 0
  assign c2 = section.settings.count_2 | plus: 0
  assign c1 = section.settings.count_1 | plus: 0
  assign total = c5 | plus: c4 | plus: c3 | plus: c2 | plus: c1

  assign rating_pct = section.settings.rating_value | times: 20.0
  if rating_pct > 100
    assign rating_pct = 100
  endif
-%}

{%- comment -%}
  Reviews (Figma 45068:2448). A top-level frame on the PDP, not part of the sticky buy column, so
  it is its own section.

  The distribution bars are computed from the counts, not reproduced from the artboard's two static
  images (a filled one and an empty one). A bar whose width does not follow the number beside it is
  a chart that lies. Total is summed from the five counts rather than typed separately — two fields
  that must agree will eventually not.

  Shopify has no native product reviews, so the reviews are merchant-authored blocks. When a real
  reviews app lands, this section is the seam to swap.
{%- endcomment -%}
<div
  class="dev-product-reviews"
  style="
    --bg: {{ section.settings.background_color }};
    --color: {{ section.settings.text_color }};
    --star-color: {{ section.settings.star_color }};
    --card-bg: {{ section.settings.card_color }};
    --border-color: {{ section.settings.border_color }};
    --track-color: {{ section.settings.track_color }};
    --rating-pct: {{ rating_pct }}%;
    --pb: {{ section.settings.padding_bottom }}px;
  "
>
  <div class="dev-product-reviews__inner">
    <div class="dev-product-reviews__stack">
      <div class="dev-product-reviews__head">
        {%- if section.settings.heading != blank -%}
          <h2 class="dev-product-reviews__title">{{ section.settings.heading }}</h2>
        {%- endif -%}

        <span class="dev-product-reviews__stars" role="img" aria-label="{{ section.settings.rating_value }} / 5">
          <span class="dev-product-reviews__stars-base" aria-hidden="true">★★★★★</span>
          <span class="dev-product-reviews__stars-fill" aria-hidden="true">★★★★★</span>
        </span>

        {%- if total > 0 -%}
          <p class="dev-product-reviews__count">
            {{- section.settings.count_prefix | escape }} {{ total }} {{ section.settings.count_suffix | escape -}}
          </p>
        {%- endif -%}
      </div>

      {%- if total > 0 -%}
        <ul class="dev-product-reviews__bars" role="list">
          {%- for star in (1..5) reversed -%}
            {%- liquid
              case star
                when 5
                  assign n = c5
                when 4
                  assign n = c4
                when 3
                  assign n = c3
                when 2
                  assign n = c2
                else
                  assign n = c1
              endcase
              assign pct = n | times: 100.0 | divided_by: total
            -%}
            <li class="dev-product-reviews__bar">
              <span class="dev-product-reviews__bar-star">
                <span class="dev-product-reviews__bar-num">{{ star }}</span>
                <span class="dev-product-reviews__bar-glyph" aria-hidden="true">★</span>
              </span>

              {%- comment -%}
                A meter, not a decorative div: it carries the number it draws, so a screen reader is
                told "43 of 64" instead of nothing at all.
              {%- endcomment -%}
              <span
                class="dev-product-reviews__bar-track"
                role="meter"
                aria-valuenow="{{ n }}"
                aria-valuemin="0"
                aria-valuemax="{{ total }}"
                aria-label="{{ star }}"
              >
                <span class="dev-product-reviews__bar-fill" style="width: {{ pct }}%;"></span>
              </span>

              <span class="dev-product-reviews__bar-count">{{ n }}</span>
            </li>
          {%- endfor -%}
        </ul>
      {%- endif -%}

      {%- if section.settings.summary_text != blank -%}
        <div class="dev-product-reviews__summary">
          {%- if section.settings.summary_heading != blank -%}
            <p class="dev-product-reviews__summary-heading">{{ section.settings.summary_heading | escape }}</p>
          {%- endif -%}
          <p class="dev-product-reviews__summary-text">{{ section.settings.summary_text | escape }}</p>
        </div>
      {%- endif -%}

      {%- if reviews.size > 0 -%}
        <ul class="dev-product-reviews__list" role="list">
          {%- for block in reviews -%}
            {%- liquid
              assign stars = block.settings.stars | times: 20.0
              if stars > 100
                assign stars = 100
              endif
            -%}
            <li class="dev-product-reviews__card" {{ block.shopify_attributes }}>
              <div class="dev-product-reviews__card-head">
                <span
                  class="dev-product-reviews__stars dev-product-reviews__stars--sm"
                  style="--rating-pct: {{ stars }}%;"
                  role="img"
                  aria-label="{{ block.settings.stars }} / 5"
                >
                  <span class="dev-product-reviews__stars-base" aria-hidden="true">★★★★★</span>
                  <span class="dev-product-reviews__stars-fill" aria-hidden="true">★★★★★</span>
                </span>

                {%- if block.settings.author != blank -%}
                  <span class="dev-product-reviews__author">{{ block.settings.author | escape }}</span>
                {%- endif -%}

                {%- if block.settings.verified -%}
                  <span class="dev-product-reviews__badge">{{ section.settings.verified_label | escape }}</span>
                {%- endif -%}
              </div>

              <div class="dev-product-reviews__card-body">
                {%- if block.settings.heading != blank -%}
                  <h3 class="dev-product-reviews__card-title">{{ block.settings.heading }}</h3>
                {%- endif -%}
                {%- if block.settings.body != blank -%}
                  <div class="dev-product-reviews__card-text">{{ block.settings.body }}</div>
                {%- endif -%}
                {%- if block.settings.date != blank -%}
                  <p class="dev-product-reviews__card-date">{{ block.settings.date | escape }}</p>
                {%- endif -%}
              </div>
            </li>
          {%- endfor -%}
        </ul>
      {%- endif -%}
    </div>

    {%- if section.settings.button_label != blank -%}
      <a class="dev-product-reviews__button" href="{{ section.settings.button_link | default: '#' }}">
        {{- section.settings.button_label | escape -}}
      </a>
    {%- endif -%}
  </div>
</div>

{% schema %}
{
  "name": "Product reviews",
  "tag": "section",
  "settings": [
    { "type": "header", "content": "Content" },
    { "type": "inline_richtext", "id": "heading", "label": "Heading", "default": "Rated Excellent" },
    { "type": "range", "id": "rating_value", "min": 0, "max": 5, "step": 0.1, "label": "Rating", "default": 4.9 },
    { "type": "text", "id": "count_prefix", "label": "Count prefix", "default": "Based on" },
    { "type": "text", "id": "count_suffix", "label": "Count suffix", "default": "reviews" },
    { "type": "text", "id": "verified_label", "label": "Verified badge", "default": "Verified" },

    { "type": "header", "content": "Distribution" },
    { "type": "paragraph", "content": "The bars are drawn from these counts, and the total is their sum — there is no separate total to fall out of step with them." },
    { "type": "number", "id": "count_5", "label": "5 star", "default": 43 },
    { "type": "number", "id": "count_4", "label": "4 star", "default": 21 },
    { "type": "number", "id": "count_3", "label": "3 star", "default": 0 },
    { "type": "number", "id": "count_2", "label": "2 star", "default": 0 },
    { "type": "number", "id": "count_1", "label": "1 star", "default": 0 },

    { "type": "header", "content": "Summary" },
    { "type": "text", "id": "summary_heading", "label": "Summary heading", "default": "Review Summary" },
    { "type": "textarea", "id": "summary_text", "label": "Summary", "default": "Customers say these sheets are exceptionally soft and comfortable. Many reviews highlight their temperature-regulating qualities, keeping sleepers cool throughout the night." },

    { "type": "header", "content": "Button" },
    { "type": "text", "id": "button_label", "label": "Button label", "default": "Show more reviews" },
    { "type": "url", "id": "button_link", "label": "Button link" },

    { "type": "header", "content": "Colors" },
    { "type": "color", "id": "background_color", "label": "Background", "default": "#FFFCF4" },
    { "type": "color", "id": "text_color", "label": "Text color", "default": "#333333" },
    { "type": "color", "id": "star_color", "label": "Star color", "default": "#F1B500" },
    { "type": "color", "id": "card_color", "label": "Card background", "default": "#FCF5E3" },
    { "type": "color", "id": "border_color", "label": "Card border", "default": "#C4BCA9" },
    { "type": "color", "id": "track_color", "label": "Bar track", "default": "#C4BCA9" },

    { "type": "header", "content": "Spacing" },
    { "type": "range", "id": "padding_bottom", "min": 0, "max": 120, "step": 4, "unit": "px", "label": "Padding bottom", "default": 40 }
  ],
  "blocks": [
    {
      "type": "review",
      "name": "Review",
      "settings": [
        { "type": "range", "id": "stars", "min": 0, "max": 5, "step": 0.5, "label": "Stars", "default": 5 },
        { "type": "text", "id": "author", "label": "Author", "default": "Ruth S" },
        { "type": "checkbox", "id": "verified", "label": "Verified purchase", "default": true },
        { "type": "inline_richtext", "id": "heading", "label": "Title", "default": "The perfect Vegan cotton duvet!" },
        { "type": "richtext", "id": "body", "label": "Review", "default": "<p>Lorem ipsum dolor sit amet, consectetur adipiscing elit.</p>" },
        { "type": "text", "id": "date", "label": "Date", "default": "18 months ago" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Product reviews",
      "blocks": [{ "type": "review" }, { "type": "review" }, { "type": "review" }, { "type": "review" }]
    }
  ]
}
{% endschema %}
