{{ 'dev-reviews.css' | asset_url | stylesheet_tag }}

{%- comment -%}
  The Judge.me review widget, restyled.

  The markup is the APP's. It is generated by Judge.me and we cannot change a single tag of it, so
  everything below is an override of their CSS — which is why this section exists at all.

  Judge.me's stylesheets (widget_v3_base / _main / _media.css) are injected by their loader at
  RUNTIME, from the judgeme_core app embed. They therefore land AFTER every stylesheet the theme
  emits, and an equally specific rule of ours would lose on source order no matter where we put it.
  The .dev-reviews wrapper is the fix: it buys a class of specificity on every selector, so we win
  without carpeting the file in !important. Where a rule of theirs is already two classes deep, or
  where they set the property inline on the element, !important is used — and each of those is
  marked, because it is a debt, not a habit.

  The app block sits INSIDE this section rather than in a bare `_blocks` container: same official
  block, same app, but now with a wrapper we own.
{%- endcomment -%}

<style>
  .dev-reviews {
    --font-body: 'Public Sans', sans-serif;
    --font-heading: 'Test Tiempos Headline', serif;

    --section-px: 64px;
    --section-px-mobile: 16px;
    /* The reviews block is 644 wide on a 1440 artboard and centred — it is NOT the 1312 page
       container. A measured 644, not a guessed "narrow". */
    --reviews-max: 644px;

    /* Vertical padding on mobile is the artboard's, not the merchant's: 44797:4034 puts its first
       text at y=48, so the block's own top padding is 48. Its BOTTOM padding is 0 — the button ends
       exactly on the frame's edge — but 0 would jam it into the footer, so the bottom mirrors the
       top. That is the one number here the artboard does not give us, and it is called out rather
       than smuggled in. The 80px the desktop settings carry is far too much at 375. */
    --pt-mobile: 48px;
    --pb-mobile: 48px;
  }
</style>

<div
  class="dev-reviews"
  style="
    --bg: {{ section.settings.background_color }};
    --color: {{ section.settings.text_color }};
    --card-bg: {{ section.settings.card_color }};
    --border-color: {{ section.settings.border_color }};
    --star-color: {{ section.settings.star_color }};
    --track-color: {{ section.settings.track_color }};
    --pt: {{ section.settings.padding_top }}px;
    --pb: {{ section.settings.padding_bottom }}px;
  "
  data-reviews
>
  <div class="dev-reviews__inner">
    {% content_for 'blocks' %}
  </div>
</div>

{% schema %}
{
  "name": "Reviews",
  "tag": "section",
  "blocks": [{ "type": "@app" }],
  "settings": [
    { "type": "paragraph", "content": "Holds the Judge.me review widget and restyles it. The widget's own text — the heading ('Customer Reviews'), the button label ('Load More') — comes from the Judge.me app, not from here: CSS cannot rewrite copy." },

    { "type": "header", "content": "Colors" },
    { "type": "color", "id": "background_color", "label": "Background", "default": "#FFFCF4" },
    { "type": "color", "id": "text_color", "label": "Text", "default": "#333333" },
    { "type": "color", "id": "card_color", "label": "Review card", "default": "#FCF5E3" },
    { "type": "color", "id": "border_color", "label": "Border", "default": "#C4BCA9" },
    { "type": "color", "id": "star_color", "label": "Stars", "default": "#F1B500" },
    { "type": "color", "id": "track_color", "label": "Histogram track", "default": "#D8D1C0" },

    { "type": "header", "content": "Spacing" },
    { "type": "range", "id": "padding_top", "min": 0, "max": 160, "step": 4, "unit": "px", "label": "Padding top", "default": 80 },
    { "type": "range", "id": "padding_bottom", "min": 0, "max": 160, "step": 4, "unit": "px", "label": "Padding bottom", "default": 80 }
  ],
  "presets": [{ "name": "Reviews" }]
}
{% endschema %}
