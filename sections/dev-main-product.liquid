{{ 'dev-main-product.css' | asset_url | stylesheet_tag }}
<script src="{{ 'dev-main-product.js' | asset_url }}" defer></script>

{%- comment -%} Fixed design tokens from Figma — not merchant-controlled {%- endcomment -%}
<style>
  .dev-main-product {

    --section-px: 64px;
    --section-px-mobile: 16px;
    /* 1440 artboard minus 2x64 of gutter. Without it the gallery just kept growing on a wide
       monitor — the buy column is fixed at 460, so every extra pixel of viewport landed on the
       image. The artboard is a 1312px frame, not a fluid one. */
    --container-max: 1312px;
    --col-gap: 96px;
    --pt: 32px;
    /* The guide popups tighten to the mobile artboard's 24px inset (head + body) as a bottom sheet. */
    --pt-mobile: 24px;

    /* Desktop/Title 3 vs Mobile/Title 3 — the mobile artboard states its own size. */
    --font-title-size: 32px;
    --font-title-size-mobile: 24px;
    /* Desktop/Title 4 — the accordion headings. Mobile/Title 4 drops them to 20 (44797:2410). */
    --font-title-4-size: 22px;
    --font-title-4-size-mobile: 20px;
    /* Mobile/Title2 + Mobile/Title 4 — the price-comparison card uses the mobile scale on desktop. */
    --font-pc-title-size: 28px;
    --font-pc-label-size: 20px;
    --font-heading-weight: 500;
    --font-heading-lh: 1.2;

    --font-sub-size: 18px;
    --font-sub-size-mobile: 16px;
    --font-label-size: 16px;
    --font-variant-size: 16px;
    /* Body/Lg_Body_Bold on the mobile artboard — the buy button drops 20 -> 18 (44869:1204). */
    --font-cta-size: 20px;
    --font-cta-size-mobile: 18px;
    --font-badge-size: 14px;
    --font-stars-size: 18px;
    /* The rating label alone drops to 14 on mobile — NOT --font-label-size, which the option rows and
       the zoom counter also read and which stays at 16. */
    --font-rating-size-mobile: 14px;
    --font-body-lh: 1.4;
    --w-medium: 500;
    --w-bold: 700;

    /* Gallery */
    --gallery-gap: 24px;
    --thumb-size: 62px;
    --thumb-gap: 12px;
    --thumb-radius: 8px;
    --image-w: 668px;
    --image-h: 640px;
    --image-radius: 32px;
    --image-h-mobile: 365px;
    --arrow-pad: 19px;
    --arrow-radius: 60px;
    --icon-size: 24px;
    --play-size: 28px;
    --badge-pad: 4px 8px;
    --badge-radius: 8px;

    /* Buy column */
    --buy-w: 460px;
    --buy-gap: 32px;
    --title-gap: 8px;
    --group-gap: 16px;
    --variant-gap: 8px;
    --variant-radius: 8px;
    /* 226x58 on the artboard. The border is 1px INSIDE the box in Figma, so CSS padding must be
       one pixel short of the drawn inset: 1 + 31 = 32, 1 + 17 = 18. And the SELECTED chip carries a
       transparent border of the same width — without it the filled chip would be 2px shorter than
       the outlined ones sitting next to it. */
    --variant-pad: 17px 31px;
    --variant-border-w: 1px;

    --cta-h: 60px;
    --cta-radius: 60px;
    --cta-pad: 16px 24px;
    --cta-gap: 24px;
    --cta-divider-h: 28px;

    --transition: 200ms;

    /* Motion. Asymmetric on purpose: a drawer takes its time arriving and leaves briskly, which is
       what makes it feel like an object rather than a div being toggled. The accordion duration is
       read back out of here by the JS (parseFloat on the computed value), so keep it in ms. */
    --guide-in: 480ms;
    --guide-out: 300ms;
    --ease-out: cubic-bezier(0.22, 1, 0.36, 1);
    --ease-in: cubic-bezier(0.55, 0, 1, 0.45);

    /* The zoom lightbox. Quicker than a drawer in both directions: a drawer is an object travelling
       in from off-screen, the lightbox is already where it belongs and only has to fade up. Read
       back out of here by the JS (parseFloat on the computed value) to know when the exit animation
       has landed, so keep them in ms. */
    --zoom-in: 320ms;
    --zoom-out: 200ms;

    /* One curve for the accordion, both directions. Opening on one curve and closing on another
       looked restless when a row closed while its neighbour opened — two motions disagreeing. */
    --acc-dur: 320ms;
    /* Deliberately an even curve, not a snappy one. A steep ease-out puts ~70% of the travel into
       the first fifth of the time, and on a row 450px tall that lands as a jolt no matter how long
       the tail is. This accelerates and decelerates by roughly the same amount. */
    --acc-ease: cubic-bezier(0.4, 0, 0.2, 1);
    /* 24px on the artboard, in three places: under the divider, between the heading and the copy,
       and between one row's copy and the next divider. Measured off 45060:2564. */
    --acc-gap: 24px;

    /* The spacer the artboard drops in above the price-comparison card (45068:2384). */
    --pc-lead: 48px;

    /* The hand-drawn stroke under the italic run of the price-comparison heading. A MASK on the
       <em>, the same construction as dev-hero, dev-tree-fibre-hero and dev-values-we-cherish, so it
       follows whatever the merchant italicises instead of being pinned to "emarkable." */
    --underline: url('{{ 'dev-main-product-underline.svg' | asset_url }}');
    --underline-h: 5.9px;
    --underline-gap: -1px;
  }
</style>

{%- liquid
  assign product_media = product.media
  assign current = product.selected_or_first_available_variant

  # The zoom lightbox is images only: a video carries its own controls and a 3D model its own viewer,
  # and neither has anything to magnify. Counted here, never looped over — the loops below walk
  # product.media itself, so every zoom slide keeps the SAME index the gallery already works in and
  # the two can address each other with no mapping table to get out of step.
  assign zoom_images = product_media | where: 'media_type', 'image'
  assign zoom_on = false
  if section.settings.enable_zoom and zoom_images.size > 0
    assign zoom_on = true
  endif

  # Both guides are the PRODUCT's, not the template's. They used to live in section blocks, which
  # meant a second duvet needed a second product template just to carry different numbers and cards.
  # Now every product points at a metaobject entry, and many products can share one.
  assign size_guide = product.metafields.larke.size_guide.value
  assign seasons_guide = product.metafields.larke.seasons_guide.value

  # The size-guide unit toggle is built from 'unit' blocks. Each block picks a unit type from a fixed
  # list — the type carries the cm-conversion factor — so the merchant adds/reorders units without
  # ever typing a number. The first block is the default. Rendered in two places below: the toggle
  # buttons and one value column per size row.
  assign units = section.blocks | where: 'type', 'unit'

  assign rating = section.settings.rating_value
  assign rating_pct = rating | times: 20.0
  if rating_pct > 100
    assign rating_pct = 100
  endif
-%}

{%- comment -%}
  The PDP buy box. Gallery left, sticky purchase column right (Figma 45060:2105).

  The variant chips are rendered from product.options_with_values — the REAL Shopify options. The
  artboard labels the second option "Tog: Lightweight", but this product's option is "Warmth: 4.5
  tog"; the owner's call was to trust the data, not the mock. So the chips read whatever the product
  actually carries, and this section works on any product instead of only on the one that was drawn.

  Every class is dev-prefixed: Horizon compiles every stock section's {% stylesheet %} into a sheet
  that loads on every page, so an unprefixed BEM name inherits stock rules.

  The cart routes ride on the root as data attributes rather than being hardcoded in the JS: a
  localised storefront serves them under a locale prefix, and "/cart/add" would 404 there.
{%- endcomment -%}
<div
  class="dev-main-product"
  style="
    --bg: {{ section.settings.background_color }};
    --color: {{ section.settings.text_color }};
    --accent: {{ section.settings.accent_color }};
    --star-color: {{ section.settings.star_color }};
    --surface: {{ section.settings.surface_color }};
    --card-bg: {{ section.settings.card_color }};
    --border-color: {{ section.settings.border_color }};
    --rating-pct: {{ rating_pct }}%;
  "
  data-main-product
  data-cart-add-url="{{ routes.cart_add_url }}"
  data-cart-url="{{ routes.cart_url }}"
>
  <div class="dev-main-product__inner">
    {%- comment -%} ---------- Gallery ---------- {%- endcomment -%}
    <div class="dev-main-product__gallery">
      {%- if product_media.size > 1 -%}
        <ul class="dev-main-product__thumbs" role="list">
          {%- for media in product_media -%}
            {%- comment -%}
              The alt is computed BEFORE the tag. A filter chain inside a named image_tag argument
              (`alt: media.alt | default: x | escape,`) does not parse — the comma after the filter
              is read as part of it, and the whole section fails to upload.
            {%- endcomment -%}
            {%- liquid
              assign media_alt = media.alt | default: product.title | escape
              assign thumb_label = 'accessibility.slide_status' | t: index: forloop.index, length: product_media.size
            -%}
            <li class="dev-main-product__thumb-item">
              <button
                type="button"
                class="dev-main-product__thumb{% if forloop.first %} dev-main-product__thumb--active{% endif %}"
                data-thumb
                data-index="{{ forloop.index0 }}"
                aria-label="{{ thumb_label | escape }}"
                aria-current="{% if forloop.first %}true{% else %}false{% endif %}"
              >
                {{
                  media.preview_image
                  | image_url: width: 186
                  | image_tag:
                    loading: 'lazy',
                    widths: '62, 124, 186',
                    sizes: '62px',
                    alt: media_alt,
                    class: 'dev-main-product__thumb-image'
                }}

                {%- comment -%}
                  Only a real video gets the play badge. The artboard shows one because the mock had
                  a video in the gallery; whether THIS product has one is a fact about the product,
                  not about the design.
                {%- endcomment -%}
                {%- if media.media_type == 'video' or media.media_type == 'external_video' -%}
                  <span class="dev-main-product__play" aria-hidden="true">
                    <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" focusable="false">
                      <path d="M8 5.5V18.5L19 12L8 5.5Z" fill="currentColor"/>
                    </svg>
                  </span>
                {%- endif -%}
              </button>
            </li>
          {%- endfor -%}
        </ul>
      {%- endif -%}

      <div class="dev-main-product__stage">
        <ul class="dev-main-product__slides" role="list" data-slides>
          {%- for media in product_media -%}
            {%- liquid
              assign slide_alt = media.alt | default: product.title | escape
              assign slide_loading = 'lazy'
              if forloop.first
                assign slide_loading = 'eager'
              endif
            -%}
            <li
              class="dev-main-product__slide{% if forloop.first %} dev-main-product__slide--active{% endif %}"
              data-slide
              data-index="{{ forloop.index0 }}"
            >
              {%- if media.media_type == 'video' -%}
                {{ media | video_tag: controls: true, class: 'dev-main-product__media' }}
              {%- elsif media.media_type == 'external_video' -%}
                {{ media | external_video_tag: class: 'dev-main-product__media' }}
              {%- else -%}
                {{
                  media
                  | image_url: width: 1400
                  | image_tag:
                    loading: slide_loading,
                    widths: '668, 1000, 1336, 1400',
                    sizes: '(max-width: 768px) 100vw, 668px',
                    alt: slide_alt,
                    class: 'dev-main-product__media'
                }}
              {%- endif -%}

              {%- comment -%}
                The zoom trigger. A transparent button over the whole slide, LAST so it paints above
                the image — the artboard draws no magnifier, and the whole photo is the target the
                way it is in Horizon's own carousel. It cannot swallow the arrows, the badge or the
                seal: those are siblings of the slide LIST, later in the DOM, so they paint above it.
                And an inactive slide is visibility:hidden, which takes its button out of the tab ring
                and out of hit-testing for free — only the photo on screen is clickable.
              {%- endcomment -%}
              {%- if zoom_on and media.media_type == 'image' -%}
                <button
                  type="button"
                  class="dev-main-product__zoom-open"
                  data-zoom-open
                  data-zoom-target="{{ forloop.index0 }}"
                  aria-label="{{ 'actions.zoom_media' | t: index: forloop.index | escape }}"
                ></button>
              {%- endif -%}
            </li>
          {%- endfor -%}
        </ul>

        {%- if section.settings.badge_text != blank -%}
          <span class="dev-main-product__badge">{{ section.settings.badge_text | escape }}</span>
        {%- endif -%}

        {%- comment -%}
          The seal comes from the image picker and nowhere else. It used to fall back to a webp
          bundled in assets/, which meant the theme could never stop shipping that file — the
          fallback WAS the dependency. No image picked, no seal: an award the merchant has not
          uploaded is not an award this section should invent.
        {%- endcomment -%}
        {%- if section.settings.show_seal and section.settings.seal_image != blank -%}
          {%- assign seal_alt = section.settings.seal_alt | escape -%}
          <span class="dev-main-product__seal">
            {{
              section.settings.seal_image
              | image_url: width: 270
              | image_tag:
                loading: 'lazy',
                widths: '90, 180, 270',
                sizes: '90px',
                alt: seal_alt,
                class: 'dev-main-product__seal-image'
            }}
          </span>
        {%- endif -%}

        {%- if product_media.size > 1 -%}
          <div class="dev-main-product__arrows">
            <button type="button" class="dev-main-product__arrow" data-prev aria-label="{{ 'accessibility.slideshow_previous' | t | escape }}">
              {%- comment -%} Exported from Figma (Icon/Outline/arrow-narrow-left) — path data verbatim. {%- endcomment -%}
              <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true" focusable="false">
                <path d="M7 8L3 12L7 16M3 12L21 12" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </button>
            <button type="button" class="dev-main-product__arrow" data-next aria-label="{{ 'accessibility.slideshow_next' | t | escape }}">
              <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true" focusable="false">
                <path d="M17 16L21 12L17 8M21 12L3 12" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </button>
          </div>
        {%- endif -%}
      </div>
    </div>

    {%- comment -%} ---------- Buy column ---------- {%- endcomment -%}
    {%- comment -%} `id` is the anchor target for on-page CTAs elsewhere on the PDP. {%- endcomment -%}
    <div id="buy" class="dev-main-product__buy">
      <div class="dev-main-product__head">
        {%- if section.settings.show_rating -%}
          {%- liquid
            # The whole rating is one anchor — clicking the stars OR the label jumps to the reviews
            # section. A merchant can point the Rating link setting anywhere; when it is blank we
            # default to the on-page reviews anchor (#reviews) instead of rendering a dead <span>.
            # dev-reviews always sits on the PDP, and it carries id="reviews".
            assign rating_href = section.settings.rating_link
            if rating_href == blank
              assign rating_href = '#reviews'
            endif
          -%}
          <a class="dev-main-product__rating" href="{{ rating_href }}">
            {%- if section.settings.show_rating_stars -%}
              {%- comment -%}
                Shared inline-SVG stars (not the ★ glyph). See dev-stars.

                The row is rounded to whole stars, so 4.9 draws FIVE solid ones — the owner's call,
                reversing what this file used to do. It used to clip the fifth star to 90% because
                the artboard fades it with a gradient, on the argument that five solid stars claim a
                nicer number than the product has. The label still reads the true 4.9/5 beside it.

                `round`, not `ceil`: nearest whole star. Round UP and a 4.2 would also show five,
                which is the dishonest version of this change rather than the tidy one.
              {%- endcomment -%}
              {%- liquid
                assign stars_label = rating | append: ' / 5'
                assign stars_rating = rating | round
              -%}
              {%- render 'dev-stars',
                rating: stars_rating,
                max: 5,
                size: 18,
                gap: 1,
                color: section.settings.star_color,
                track: '#ededed',
                label: stars_label
              -%}
            {%- endif -%}
            <span class="dev-main-product__rating-link">{{ section.settings.rating_label | escape }}</span>
          </a>
        {%- endif -%}

        <h1 class="dev-main-product__title">{{ product.title | escape }}</h1>

        {%- comment -%}
          The product's own description, rendered as an optional "Description" block in place of the
          old tagline/subtitle section settings. It sits in the head, under the title. The block has
          no per-block copy — it always pulls from the product, so one block serves every product.
        {%- endcomment -%}
        {%- assign description_blocks = section.blocks | where: 'type', 'description' -%}
        {%- for block in description_blocks -%}
          {%- if product.description != blank -%}
            <div class="dev-main-product__description" {{ block.shopify_attributes }}>
              {{ product.description }}
            </div>
          {%- endif -%}
        {%- endfor -%}
      </div>

      {%- form 'product', product, class: 'dev-main-product__form', novalidate: 'novalidate' -%}
        <input type="hidden" name="id" value="{{ current.id }}" data-variant-id>

        {%- for option in product.options_with_values -%}
          {%- liquid
            assign selected = option.selected_value

            # Each guide hangs off the option its OWN entry says it explains (option_name), not off
            # "whichever option happens to be first or second". Position was a lie the moment a
            # product ordered its options differently — the size guide would open beside the warmth
            # chips. The section now knows nothing about what any particular option is called.
            # A product with no guide entry gets no link and no drawer: nothing to explain, nothing
            # to open.
            assign guide = ''
            assign link_label = ''
            if size_guide != blank and size_guide.option_name.value == option.name
              assign guide = 'size'
              assign link_label = size_guide.link_label.value
            elsif seasons_guide != blank and seasons_guide.option_name.value == option.name
              assign guide = 'tog'
              assign link_label = seasons_guide.link_label.value
            endif
          -%}
          <fieldset class="dev-main-product__group" data-option-index="{{ forloop.index0 }}">
            <legend class="dev-main-product__legend">
              <span class="dev-main-product__legend-row">
                <span class="dev-main-product__legend-text">
                  {{- option.name | escape }}: <strong data-selected-value>{{ selected | escape }}</strong>
                </span>
                {%- comment -%}
                  A button, not a link: it opens a dialog on this page, it does not navigate. Giving
                  it an href would put a destination in the status bar that does not exist and let
                  cmd-click open a blank tab.
                {%- endcomment -%}
                {%- if link_label != blank -%}
                  <button
                    type="button"
                    class="dev-main-product__legend-link"
                    data-guide-open="{{ guide }}"
                    aria-haspopup="dialog"
                    aria-expanded="false"
                    aria-controls="guide-{{ guide }}"
                  >
                    {{- link_label | escape -}}
                  </button>
                {%- endif -%}
              </span>
            </legend>

            <div class="dev-main-product__chips">
              {%- for value in option.values -%}
                {%- assign input_id = 'opt-' | append: option.position | append: '-' | append: forloop.index -%}
                <input
                  class="dev-main-product__chip-input"
                  type="radio"
                  id="{{ input_id }}"
                  name="option-{{ option.position }}"
                  value="{{ value | escape }}"
                  data-option-input
                  {% if value == selected %}checked{% endif %}
                >
                <label class="dev-main-product__chip" for="{{ input_id }}">{{ value | escape }}</label>
              {%- endfor -%}
            </div>
          </fieldset>
        {%- endfor -%}

        <button
          type="submit"
          name="add"
          class="dev-main-product__cta dev-btn dev-btn--filled dev-btn--full"
          data-add
          {% unless current.available %}disabled{% endunless %}
        >
          {%- comment -%}
            Both labels ride on the element. The JS has to swap between them as the buyer moves
            across combinations, and it cannot invent copy the merchant owns.
          {%- endcomment -%}
          <span
            class="dev-main-product__cta-label"
            data-cta-label
            data-add-label="{{ section.settings.cta_label | escape }}"
            data-sold-out-label="{{ section.settings.sold_out_label | escape }}"
          >
            {%- if current.available -%}
              {{- section.settings.cta_label | escape -}}
            {%- else -%}
              {{- section.settings.sold_out_label | escape -}}
            {%- endif -%}
          </span>
          <span class="dev-main-product__cta-divider" aria-hidden="true"></span>
          <span class="dev-main-product__cta-price" data-cta-price>{{ current.price | money }}</span>
        </button>

        {%- comment -%}
          Where a rejected add lands. Adding to cart over fetch means Shopify's own error page never
          appears, so the reason ("You can only add 3 to the cart") has to have somewhere to go —
          otherwise a failed add looks exactly like a successful one that opened no drawer.
          role="alert" so a screen reader hears it without being moved.
        {%- endcomment -%}
        <p class="dev-main-product__cta-error" data-cta-error role="alert" hidden></p>
      {%- endform -%}

      {%- comment -%}
        ---------- Blocks ----------
        Everything below the buy form is a block, rendered in the merchant's order: the two cards
        used to be section settings, which meant they were furniture — always there, always in that
        one spot, and their copy sat in section settings while the accordions beside them were
        blocks. Content in section settings is content nobody can move or remove.

        The accordion rows are drawn as ONE group, in one container, at the position of the first
        accordion block — rather than opening the container on the first row of a run and closing
        it on the last. That version put the <div> and its </div> in different branches of this
        loop, which is unbalanced HTML as far as any parser (theme-check included) can tell, and it
        bought only the ability to split the rows by dropping a card between them. So a card
        dropped mid-run lands below the rows instead of between them; everywhere else block order
        is honoured exactly.
      {%- endcomment -%}
      {%- assign accordions = section.blocks | where: 'type', 'accordion' -%}
      {%- for block in section.blocks -%}
        {%- case block.type -%}
          {%- comment -%}
            ---------- Accordions ----------
            <details>/<summary>, not a div plus a click handler. It opens with no JS, it is keyboard
            operable and announced correctly by screen readers for free, and Ctrl+F on the page can
            still find the text inside a closed panel.

            The JS upgrades it: it animates the height and closes the open row when another is
            opened. Deliberately NOT the native `name` attribute, which would give exclusivity for
            free — the browser slams the sibling shut the instant we set .open on the new row,
            killing the closing animation mid-flight. Exclusivity is worth owning so it can be
            animated. data-acc-group is the scope it closes across.
          {%- endcomment -%}
          {%- when 'accordion' -%}
            {%- if block.id != accordions.first.id -%}
              {%- continue -%}
            {%- endif -%}

            <div class="dev-main-product__accordions" data-acc-group>
              {%- for row in accordions -%}
                <details
                  class="dev-main-product__acc"
                  data-acc
                  {% if row.settings.open_by_default %}open{% endif %}
                  {{ row.shopify_attributes }}
                >
                  <summary class="dev-main-product__acc-summary">
                    <span class="dev-main-product__acc-title">{{ row.settings.heading }}</span>
                    <span class="dev-main-product__acc-icon" aria-hidden="true">
                      {%- comment -%} Figma flips chevron-down to chevron-up when the row opens. {%- endcomment -%}
                      <svg class="dev-main-product__acc-chevron" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" focusable="false">
                        <path d="M19 9L12 16L5 9" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/>
                      </svg>
                    </span>
                  </summary>

                  {%- if row.settings.body != blank -%}
                    <div class="dev-main-product__acc-body">{{ row.settings.body }}</div>
                  {%- endif -%}

                  {%- comment -%}
                    Certifications is the only row that pairs a mark with a line of copy, and
                    richtext cannot hold an <img>. Three optional slots rather than a nested block
                    type: they are a fixed set of accreditations, not a list that grows.
                  {%- endcomment -%}
                  {%- assign has_certs = false -%}
                  {%- for i in (1..3) -%}
                    {%- assign key = 'cert_' | append: i | append: '_text' -%}
                    {%- if row.settings[key] != blank -%}
                      {%- assign has_certs = true -%}
                    {%- endif -%}
                  {%- endfor -%}

                  {%- if has_certs -%}
                    <ul class="dev-main-product__certs" role="list">
                      {%- for i in (1..3) -%}
                        {%- liquid
                          assign text_key = 'cert_' | append: i | append: '_text'
                          assign logo_key = 'cert_' | append: i | append: '_logo'
                          assign cert_text = row.settings[text_key]
                          assign cert_logo = row.settings[logo_key]
                        -%}
                        {%- if cert_text != blank -%}
                          {%- comment -%}
                            Each mark keeps its OWN shape. They were all being handed the same 48x58
                            box, which is the FSC tree's shape — so the OEKO seal, a circle 48x48 on
                            the artboard, was stretched 21% taller and came out an oval. Width is
                            shared (48 on all three); height is not. The pair also reserves the row's
                            space before the file arrives, so nothing jumps as the accordion opens.
                          {%- endcomment -%}
                          {%- liquid
                            case cert_logo
                              when 'vegan'
                                assign cert_file = 'dev-main-product-cert-vegan.webp'
                                assign cert_h = 52
                              when 'fsc'
                                assign cert_file = 'dev-main-product-cert-fsc.svg'
                                assign cert_h = 58
                              when 'oeko'
                                assign cert_file = 'dev-main-product-cert-oeko.svg'
                                assign cert_h = 48
                              else
                                assign cert_file = blank
                            endcase
                          -%}
                          <li class="dev-main-product__cert">
                            {%- if cert_file != blank -%}
                              <img class="dev-main-product__cert-logo" src="{{ cert_file | asset_url }}" alt="" width="48" height="{{ cert_h }}" loading="lazy" aria-hidden="true">
                            {%- endif -%}
                            <span class="dev-main-product__cert-text">{{ cert_text }}</span>
                          </li>
                        {%- endif -%}
                      {%- endfor -%}
                    </ul>
                  {%- endif -%}

                  {%- if row.settings.button_label != blank -%}
                    {%- render 'dev-button',
                      variant: 'outline',
                      label: row.settings.button_label | escape,
                      link: row.settings.button_link | default: '#',
                      class: 'dev-main-product__acc-button'
                    -%}
                  {%- endif -%}
                </details>
              {%- endfor -%}
            </div>

          {%- comment -%} ---------- Still undecided ---------- {%- endcomment -%}
          {%- when 'compare' -%}
            <a
              class="dev-main-product__compare"
              href="{{ block.settings.link | default: '#' }}"
              data-compare-open
              aria-haspopup="dialog"
              aria-controls="compare-modal"
              aria-expanded="false"
              {{ block.shopify_attributes }}
            >
              <span class="dev-main-product__compare-icon" aria-hidden="true">
                {%- comment -%} Exported from Figma (Icon/Outline/scale) — path data verbatim. {%- endcomment -%}
                <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" focusable="false">
                  <path d="M3 6L6 7M6 7L3 16C4.77253 17.3334 7.22866 17.3334 9.00119 16M6 7L9.00006 16M6 7L12 5M18 7L21 6M18 7L15 16C16.7725 17.3334 19.2287 17.3334 21.0012 16M18 7L21.0001 16M18 7L12 5M12 3V5M12 21V5M12 21H9M12 21H15" stroke="currentColor" stroke-width="1.4" stroke-linejoin="round"/>
                </svg>
              </span>

              <span class="dev-main-product__compare-text">
                <span class="dev-main-product__compare-heading">{{ block.settings.heading }}</span>
                <span class="dev-main-product__compare-row">
                  <span class="dev-main-product__compare-link">{{ block.settings.label | escape }}</span>
                  <span class="dev-main-product__compare-arrow" aria-hidden="true">
                    <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" focusable="false">
                      <path d="M17 16L21 12L17 8M21 12L3 12" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                  </span>
                </span>
              </span>
            </a>

          {%- comment -%} ---------- Price comparison (45068:2385) ---------- {%- endcomment -%}
          {%- when 'price_comparison' -%}
            {%- comment -%} `id` is the anchor target for the "Still undecided?" link in the buy column. {%- endcomment -%}
            <div id="compare" class="dev-main-product__pc" {{ block.shopify_attributes }}>
              <div class="dev-main-product__pc-head">
                {%- if block.settings.heading != blank -%}
                  {%- comment -%}
                    Figma turns italic mid-word — "Sleep r" then "emarkable." in italic. Kept as
                    inline_richtext so the merchant owns where the italic starts, rather than
                    hardcoding a split nobody could guess from the copy.

                    The stroke under it is drawn by CSS, as a mask on the <em>. It used to be an
                    <img> sitting here, absolutely positioned at top: 33px / left: 76px — the
                    coordinates of "emarkable." in the default copy. So the setting invited the
                    merchant to move the italic split ("that split is yours to move") while the
                    underline stayed nailed where the artboard had put it. It now goes wherever the
                    italic goes.

                    Still an <h2>, not the <h3> a block heading normally gets: this is the only
                    heading in its region, and demoting it would leave an h3 with no h2 above it.
                  {%- endcomment -%}
                  <h2 class="dev-main-product__pc-title">
                    {{ block.settings.heading }}
                  </h2>
                {%- endif -%}

                {%- if block.settings.subheading != blank -%}
                  <p class="dev-main-product__pc-sub">{{ block.settings.subheading }}</p>
                {%- endif -%}
              </div>

              {%- comment -%}
                Three fixed rows, not a nested block type — a section block cannot hold blocks of
                its own, and the artboard's three points are a fixed set anyway (the old
                compare_row type carried "limit": 3 and said so). Same construction as the
                certification rows above. A row with no label is not drawn.
              {%- endcomment -%}
              {%- assign has_rows = false -%}
              {%- for i in (1..3) -%}
                {%- assign key = 'row_' | append: i | append: '_label' -%}
                {%- if block.settings[key] != blank -%}
                  {%- assign has_rows = true -%}
                {%- endif -%}
              {%- endfor -%}

              {%- if has_rows -%}
                <ul class="dev-main-product__pc-rows" role="list">
                  {%- for i in (1..3) -%}
                    {%- liquid
                      assign label_key = 'row_' | append: i | append: '_label'
                      assign icon_key = 'row_' | append: i | append: '_icon'
                      assign row_label = block.settings[label_key]
                      assign icon_src = 'dev-main-product-' | append: block.settings[icon_key] | append: '.svg'
                    -%}
                    {%- if row_label != blank -%}
                      <li class="dev-main-product__pc-row">
                        <span class="dev-main-product__pc-icon">
                          <img src="{{ icon_src | asset_url }}" alt="" width="40" height="39" loading="lazy" aria-hidden="true">
                        </span>
                        <span class="dev-main-product__pc-label">{{ row_label | escape }}</span>
                      </li>
                    {%- endif -%}
                  {%- endfor -%}
                </ul>
              {%- endif -%}

              {%- if block.settings.link_label != blank -%}
                <a class="dev-main-product__pc-link" href="{{ block.settings.link | default: '#' }}" data-compare-open aria-haspopup="dialog" aria-controls="compare-modal" aria-expanded="false">
                  <span>{{ block.settings.link_label | escape }}</span>
                  <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true" focusable="false">
                    <path d="M17 16L21 12L17 8M21 12L3 12" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
                </a>
              {%- endif -%}
            </div>
        {%- endcase -%}
      {%- endfor -%}
    </div>
  </div>

  {%- comment -%}
    ---------- Guide drawers ----------
    Size Guide (45071:2630) and Seasons Guide (45071:2877). They live in THIS section because this
    section owns the triggers — the same reason the menu and cart drawers are blocks of the header.
    Closed server-side with inert + aria-hidden so they are never focusable before the JS runs.
  {%- endcomment -%}
  {%- if size_guide != blank and size_guide.rows.value.size > 0 -%}
    <div id="guide-size" class="dev-main-product__guide" role="dialog" aria-modal="true" aria-labelledby="guide-size-title" data-guide="size" data-open="false" aria-hidden="true" inert>
      <div class="dev-main-product__guide-backdrop" data-guide-close></div>
      {%- comment -%}
        tabindex="-1": on open the JS focuses THE PANEL, not the first control inside it. Focusing a
        control while the panel is still translated off-screen makes the browser scroll it into view
        — it scrolls the overflow:hidden container, the drawer snaps into place, and only then does
        the transform start. That snap was the whole "horrible animation".
      {%- endcomment -%}
      <div class="dev-main-product__guide-panel" data-guide-panel tabindex="-1">
        <div class="dev-main-product__guide-head">
          <h2 class="dev-main-product__guide-title" id="guide-size-title">{{ size_guide.title.value | escape }}</h2>
          <button type="button" class="dev-main-product__guide-close" data-guide-close aria-label="{{ 'actions.close' | t | escape }}">
            <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true" focusable="false">
              <path d="M7 17L17 7M7 7L17 17" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </button>
        </div>

        <div class="dev-main-product__guide-body">
          <div class="dev-main-product__size-card">
            {%- comment -%}
              CM / IN is a real toggle, not two links. Both values are already in the DOM — a unit
              switch that had to fetch anything would be absurd.
            {%- endcomment -%}
            {%- comment -%} One button per 'unit' block. The toggle only exists when there is a choice to make. {%- endcomment -%}
            {%- if units.size > 1 -%}
              <div class="dev-main-product__units" role="group" aria-label="{{ size_guide.title.value | escape }}">
                {%- for u in units -%}
                  {%- liquid
                    assign ulabel = u.settings.label
                    if ulabel == blank
                      assign ulabel = u.settings.unit | upcase
                    endif
                  -%}
                  <button type="button" class="dev-main-product__unit{% if forloop.first %} dev-main-product__unit--active{% endif %}" data-unit="{{ u.id }}" aria-pressed="{% if forloop.first %}true{% else %}false{% endif %}" {{ u.shopify_attributes }}>{{ ulabel | escape }}</button>
                {%- endfor -%}
              </div>
            {%- endif -%}

            {%- comment -%}
              The rows come from the size_guide metaobject, one size_guide_row each. Every duvet can
              point at the SAME entry — the guide is a fact about the product line, not about the
              template it happens to be rendered in.

              Inches are DERIVED, never typed. The entry stores a real dimension (width x length) and
              the imperial column is computed from it, so the two columns cannot drift apart the way
              two hand-typed text fields eventually do. The artboard's numbers fall out exactly:
              135->53, 200->79, 230->91, 220->87, 260->102.
            {%- endcomment -%}
            <dl class="dev-main-product__size-rows">
              {%- for row in size_guide.rows.value -%}
                {%- liquid
                  assign w = row.width.value
                  assign l = row.length.value

                  # Normalise to centimetres first. The merchant picks the unit from a dropdown, so
                  # "cm" is a convention, not a guarantee — a row typed in mm must not render 1350cm.
                  # Shopify has used both short ("cm") and long ("CENTIMETERS") unit names; match both.
                  assign wu = w.unit | downcase
                  assign w_scale = 1.0
                  if wu == 'mm' or wu == 'millimeters'
                    assign w_scale = 0.1
                  elsif wu == 'm' or wu == 'meters'
                    assign w_scale = 100.0
                  elsif wu == 'in' or wu == 'inches'
                    assign w_scale = 2.54
                  elsif wu == 'ft' or wu == 'feet'
                    assign w_scale = 30.48
                  elsif wu == 'yd' or wu == 'yards'
                    assign w_scale = 91.44
                  endif

                  assign lu = l.unit | downcase
                  assign l_scale = 1.0
                  if lu == 'mm' or lu == 'millimeters'
                    assign l_scale = 0.1
                  elsif lu == 'm' or lu == 'meters'
                    assign l_scale = 100.0
                  elsif lu == 'in' or lu == 'inches'
                    assign l_scale = 2.54
                  elsif lu == 'ft' or lu == 'feet'
                    assign l_scale = 30.48
                  elsif lu == 'yd' or lu == 'yards'
                    assign l_scale = 91.44
                  endif

                  assign w_cm = w.value | times: w_scale
                  assign l_cm = l.value | times: l_scale
                -%}
                <div class="dev-main-product__size-row">
                  <dt class="dev-main-product__size-label">{{ row.label.value | escape }}</dt>
                  {%- if units.size > 0 -%}
                    {%- for u in units -%}
                      {%- liquid
                        # The unit type carries its own cm-conversion factor, suffix and rounding, so a
                        # column can never drift from the stored dimension the way a typed value would.
                        case u.settings.unit
                          when 'in'
                            assign factor = 0.3937008
                            assign suffix = 'in'
                            assign dec = 0
                          when 'mm'
                            assign factor = 10.0
                            assign suffix = 'mm'
                            assign dec = 0
                          when 'ft'
                            assign factor = 0.0328084
                            assign suffix = 'ft'
                            assign dec = 1
                          when 'm'
                            assign factor = 0.01
                            assign suffix = 'm'
                            assign dec = 2
                          else
                            assign factor = 1.0
                            assign suffix = 'cm'
                            assign dec = 0
                        endcase
                        assign wv = w_cm | times: factor | round: dec
                        assign lv = l_cm | times: factor | round: dec
                      -%}
                      <dd class="dev-main-product__size-value" data-unit-value="{{ u.id }}"{% unless forloop.first %} hidden{% endunless %}>{{ wv }} {{ suffix }} x {{ lv }} {{ suffix }}</dd>
                    {%- endfor -%}
                  {%- else -%}
                    {%- comment -%} No unit blocks configured — centimetres so the table still reads. {%- endcomment -%}
                    <dd class="dev-main-product__size-value" data-unit-value="cm">{{ w_cm | round }} cm x {{ l_cm | round }} cm</dd>
                  {%- endif -%}
                </div>
              {%- endfor -%}
            </dl>
          </div>

          {%- comment -%}
            metafield_tag, not a bare print. A rich_text_field's value is an AST — {"type":"root",
            "children":[...]} — and BOTH `{{ field }}` and `{{ field.value }}` dump that JSON onto
            the page as text. metafield_tag is the filter that walks the AST and renders real HTML.
          {%- endcomment -%}
          {%- if size_guide.footer != blank -%}
            <div class="dev-main-product__guide-foot">{{ size_guide.footer | metafield_tag }}</div>
          {%- endif -%}
        </div>
      </div>
    </div>
  {%- endif -%}

  {%- if seasons_guide != blank and seasons_guide.cards.value.size > 0 -%}
    <div id="guide-tog" class="dev-main-product__guide" role="dialog" aria-modal="true" aria-labelledby="guide-tog-title" data-guide="tog" data-open="false" aria-hidden="true" inert>
      <div class="dev-main-product__guide-backdrop" data-guide-close></div>
      {%- comment -%}
        tabindex="-1": on open the JS focuses THE PANEL, not the first control inside it. Focusing a
        control while the panel is still translated off-screen makes the browser scroll it into view
        — it scrolls the overflow:hidden container, the drawer snaps into place, and only then does
        the transform start. That snap was the whole "horrible animation".
      {%- endcomment -%}
      <div class="dev-main-product__guide-panel" data-guide-panel tabindex="-1">
        <div class="dev-main-product__guide-head">
          <h2 class="dev-main-product__guide-title" id="guide-tog-title">{{ seasons_guide.title.value | escape }}</h2>
          <button type="button" class="dev-main-product__guide-close" data-guide-close aria-label="{{ 'actions.close' | t | escape }}">
            <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true" focusable="false">
              <path d="M7 17L17 7M7 7L17 17" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </button>
        </div>

        <div class="dev-main-product__guide-body">
          {%- if seasons_guide.heading.value != blank -%}
            <p class="dev-main-product__tog-heading">{{ seasons_guide.heading.value | escape }}</p>
          {%- endif -%}

          {%- comment -%}
            One seasons_card per card. The chips are a real list on the entry, not one text field
            split on commas — a chip that legitimately contained a comma used to break into two.

            The chip's icon stays in the theme: it is the same mark on every chip, so it is
            decoration, not content, and no merchant should have to attach it three times per card.
            Temperature / How it feels / Best for are interface labels for the same reason.
          {%- endcomment -%}
          {%- for card in seasons_guide.cards.value -%}
            <div class="dev-main-product__tog-card">
              <h3 class="dev-main-product__tog-title">{{ card.heading.value | escape }}</h3>

              {%- if card.temperature.value != blank -%}
                <p class="dev-main-product__tog-line">
                  <span class="dev-main-product__tog-label">{{ section.settings.tog_label_temp | escape }}</span>
                  <span class="dev-main-product__tog-text">{{ card.temperature.value | escape }}</span>
                </p>
              {%- endif -%}

              {%- if card.feel.value != blank -%}
                <p class="dev-main-product__tog-line">
                  <span class="dev-main-product__tog-label">{{ section.settings.tog_label_feel | escape }}</span>
                  <span class="dev-main-product__tog-text">{{ card.feel.value | escape }}</span>
                </p>
              {%- endif -%}

              {%- if card.chips.value.size > 0 -%}
                <p class="dev-main-product__tog-label">{{ section.settings.tog_label_best | escape }}</p>
                <ul class="dev-main-product__tog-chips" role="list">
                  {%- for chip in card.chips.value -%}
                    <li class="dev-main-product__tog-chip">
                      <img src="{{ 'dev-main-product-chip-icon.svg' | asset_url }}" alt="" width="22" height="16" loading="lazy" aria-hidden="true">
                      <span>{{ chip | escape }}</span>
                    </li>
                  {%- endfor -%}
                </ul>
              {%- endif -%}
            </div>
          {%- endfor -%}
        </div>
      </div>
    </div>
  {%- endif -%}

  {%- comment -%}
    The variant table the JS resolves against. Rendered as JSON rather than rebuilt in script from
    the DOM: the DOM only knows what the chips SAY, not which combination is a real, purchasable
    variant, what it costs, or whether it is in stock.
  {%- endcomment -%}
  <script type="application/json" data-variants>
    [
      {%- for variant in product.variants -%}
        {
          "id": {{ variant.id }},
          "options": {{ variant.options | json }},
          "available": {{ variant.available }},
          "price": {{ variant.price | money | json }}
        }{% unless forloop.last %},{% endunless %}
      {%- endfor -%}
    ]
  </script>

  {%- comment -%} ---------- Zoom lightbox ---------- {%- endcomment -%}
  {%- if zoom_on -%}
    {%- comment -%}
      A native <dialog> opened with showModal(). The focus trap, Escape, and the inertness of the page
      behind it all come from the element. What it buys us over a hand-rolled fixed overlay is the TOP
      LAYER: it is painted outside every stacking context on the page, so it cannot be re-anchored by a
      transform on an ancestor — and the gallery above it IS sticky. A position:fixed overlay under a
      transformed ancestor anchors to the ancestor instead of the viewport, which is exactly the bug
      that has bitten the cart drawer here before.

      It sits inside the section root so it inherits the token block at the top of this file. The top
      layer changes where the dialog is PAINTED, not where it lives in the DOM, so inheritance is
      untouched. dev-reveal.js already skips `dialog`, so the scroll-reveal cannot hide it either.
    {%- endcomment -%}
    <dialog class="dev-main-product__zoom" data-zoom-dialog aria-label="{{ 'actions.zoom' | t | escape }}">
      {%- comment -%}
        tabindex="-1": showModal() otherwise lands focus on the first control — the × — and iOS Safari
        paints a focus ring around it. Focus the frame instead; Tab still walks to the ×.
      {%- endcomment -%}
      <div class="dev-main-product__zoom-frame" data-zoom-frame tabindex="-1">
        <ul class="dev-main-product__zoom-slides" role="list">
          {%- comment -%}
            Walks product.media, not the filtered list, so data-media-index IS the gallery's own index
            — one index space for both, and nothing to keep in sync. Images only: the `else` branch of
            the gallery above also catches 3D models, and a model's preview image is not a photo of the
            product to magnify.
          {%- endcomment -%}
          {%- assign zoom_n = 0 -%}
          {%- for media in product_media -%}
            {%- if media.media_type == 'image' -%}
              {%- liquid
                # forloop.index counts MEDIA, and a video in the middle of the gallery would make the
                # spoken count skip a number ("photo 3 of 5" with only 4 photos). This counts photos.
                assign zoom_n = zoom_n | plus: 1

                # Both computed before the tag: a filter chain inside a named image_tag argument does
                # not parse. Same trap as the thumbnails above.
                assign zoom_alt = media.alt | default: product.title | escape
                assign zoom_label = 'accessibility.slide_status' | t: index: zoom_n, length: zoom_images.size
              -%}
              {%- comment -%}
                The 3840 source hangs on the LI, not the img: image_tag takes named arguments, and a
                Liquid argument name cannot contain a hyphen — stock ends up emitting a literal
                `data_max_resolution` for exactly this reason. On the li it is a real data attribute
                the JS reads as `dataset.maxRes`.

                Why swap at all, when the srcset already picks a candidate for this viewport: pinch
                scales the image with a CSS transform, and a transform never makes the browser fetch a
                bigger candidate. The 3840 file is the resolution held in reserve for the gesture.
              {%- endcomment -%}
              <li
                class="dev-main-product__zoom-slide{% if zoom_n == 1 %} dev-main-product__zoom-slide--active{% endif %}"
                data-zoom-slide
                data-media-index="{{ forloop.index0 }}"
                data-max-res="{{ media | image_url: width: 3840 }}"
                data-zoom-label="{{ zoom_label | escape }}"
              >
                {{
                  media
                  | image_url: width: 2048
                  | image_tag:
                    loading: 'lazy',
                    widths: '768, 1024, 1536, 2048',
                    sizes: '100vw',
                    alt: zoom_alt,
                    class: 'dev-main-product__zoom-image'
                }}
              </li>
            {%- endif -%}
          {%- endfor -%}
        </ul>
      </div>

      <button type="button" class="dev-main-product__zoom-close" data-zoom-close aria-label="{{ 'actions.close_dialog' | t | escape }}">
        {%- comment -%} The guide drawers' close mark, verbatim — same Figma icon family as the arrows. {%- endcomment -%}
        <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true" focusable="false">
          <path d="M7 17L17 7M7 7L17 17" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </button>

      {%- if zoom_images.size > 1 -%}
        <div class="dev-main-product__zoom-nav">
          <button type="button" class="dev-main-product__zoom-arrow" data-zoom-prev aria-label="{{ 'accessibility.slideshow_previous' | t | escape }}">
            <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true" focusable="false">
              <path d="M7 8L3 12L7 16M3 12L21 12" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </button>

          {%- comment -%}
            The count is decoration for a screen reader — "1 slash 7" is not a sentence. The live
            region below carries the same fact as one, and the JS writes both.
          {%- endcomment -%}
          <p class="dev-main-product__zoom-counter" data-zoom-counter aria-hidden="true">1 / {{ zoom_images.size }}</p>

          <button type="button" class="dev-main-product__zoom-arrow" data-zoom-next aria-label="{{ 'accessibility.slideshow_next' | t | escape }}">
            <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true" focusable="false">
              <path d="M17 16L21 12L17 8M21 12L3 12" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </button>
        </div>

        <p class="dev-main-product__zoom-status" data-zoom-status role="status" aria-live="polite"></p>
      {%- endif -%}
    </dialog>
  {%- endif -%}
</div>

{% schema %}
{
  "name": "Main product",
  "tag": "section",
  "settings": [
    { "type": "header", "content": "Content" },
    { "type": "paragraph", "content": "The line under the title is the product's own Description — add the \"Description\" block. There is no tagline/subtitle here anymore." },
    { "type": "text", "id": "cta_label", "label": "Add to cart label", "default": "Add to Order" },
    { "type": "text", "id": "sold_out_label", "label": "Sold out label", "default": "Sold out" },

    { "type": "header", "content": "Rating" },
    { "type": "checkbox", "id": "show_rating", "label": "Show rating", "default": true },
    { "type": "checkbox", "id": "show_rating_stars", "label": "Show rating stars", "default": true, "info": "Hides only the stars — the rating label stays." },
    { "type": "range", "id": "rating_value", "min": 0, "max": 5, "step": 0.1, "label": "Rating", "default": 4.9, "info": "Fills the stars proportionally — 4.9 leaves the fifth star 90% full, as drawn." },
    { "type": "text", "id": "rating_label", "label": "Rating label", "default": "4.9/5" },
    { "type": "url", "id": "rating_link", "label": "Rating link", "info": "Point it at the reviews section." },

    { "type": "header", "content": "Gallery" },
    { "type": "checkbox", "id": "enable_zoom", "label": "Enable image zoom", "default": true, "info": "Clicking a photo opens it full screen. Photos only — a video keeps its own controls. On a phone the zoomed photo can be pinched and double-tapped." },
    { "type": "text", "id": "badge_text", "label": "Image badge", "default": "Smooth & Breezy" },
    { "type": "checkbox", "id": "show_seal", "label": "Show approval seal", "default": true },
    { "type": "image_picker", "id": "seal_image", "label": "Approval seal", "info": "Pick the seal from Files. Leave it empty and no seal is drawn — the theme no longer bundles one." },
    { "type": "text", "id": "seal_alt", "label": "Approval seal alt text", "default": "Good Housekeeping Institute approved" },

    { "type": "header", "content": "Guides" },
    { "type": "paragraph", "content": "Neither guide is set here any more. Both come from the product: larke.size_guide and larke.seasons_guide. Each entry names the option it explains, so its link appears beside that option \u2014 leave a metafield empty and that product simply has no link and no drawer. What stays below is interface, not content: the three row labels in the seasons drawer. The size-guide unit toggle is built from \u201cSize unit\u201d blocks \u2014 add or reorder them, the first is the default." },
    { "type": "text", "id": "tog_label_temp", "label": "Label: temperature", "default": "Temperature:" },
    { "type": "text", "id": "tog_label_feel", "label": "Label: feel", "default": "How it feels over you:" },
    { "type": "text", "id": "tog_label_best", "label": "Label: best for", "default": "Best for:" },

    { "type": "header", "content": "Colors" },
    { "type": "color", "id": "background_color", "label": "Background", "default": "#FFFCF4" },
    { "type": "color", "id": "text_color", "label": "Text color", "default": "#333333" },
    { "type": "color", "id": "accent_color", "label": "Accent (chips & button)", "default": "#A8CF78" },
    { "type": "color", "id": "star_color", "label": "Star color", "default": "#F1B500" },
    { "type": "color", "id": "surface_color", "label": "Arrow buttons", "default": "#FFFCF4" },
    { "type": "color", "id": "card_color", "label": "Card background", "default": "#FCF5E3" },
    { "type": "color", "id": "border_color", "label": "Borders & dividers", "default": "#C4BCA9" }
  ],
  "blocks": [
    {
      "type": "unit",
      "name": "Size unit",
      "limit": 6,
      "settings": [
        { "type": "paragraph", "content": "A tab in the size-guide unit toggle. Pick the unit — it carries the conversion, so the numbers stay correct — and give it a short label. The first Size unit block is shown by default." },
        { "type": "select", "id": "unit", "label": "Unit", "default": "cm", "options": [
          { "value": "cm", "label": "Centimetres" }, { "value": "in", "label": "Inches" },
          { "value": "mm", "label": "Millimetres" }, { "value": "ft", "label": "Feet" }, { "value": "m", "label": "Metres" } ] },
        { "type": "text", "id": "label", "label": "Toggle text", "info": "The button text — CM, IN… Leave empty to use the unit’s short form." }
      ]
    },
    {
      "type": "accordion",
      "name": "Accordion",
      "settings": [
        { "type": "inline_richtext", "id": "heading", "label": "Heading", "default": "Why you’ll love it" },
        { "type": "richtext", "id": "body", "label": "Body", "default": "<ul><li>Awarded <strong>Best Lightweight Duvet</strong> by Good Housekeeping 2025.</li></ul>", "info": "Use a bullet list — the dots are styled to the artboard." },
        { "type": "checkbox", "id": "open_by_default", "label": "Open by default", "default": false },
        { "type": "text", "id": "button_label", "label": "Button label", "info": "Optional — the Care row carries one." },
        { "type": "url", "id": "button_link", "label": "Button link" },

        { "type": "header", "content": "Certification rows" },
        { "type": "paragraph", "content": "Only the Certifications row uses these. A mark plus a line of copy — richtext cannot hold an image." },
        { "type": "select", "id": "cert_1_logo", "label": "Logo 1", "default": "none", "options": [
          { "value": "none", "label": "None" }, { "value": "vegan", "label": "The Vegan Society" },
          { "value": "fsc", "label": "FSC" }, { "value": "oeko", "label": "OEKO-TEX" } ] },
        { "type": "inline_richtext", "id": "cert_1_text", "label": "Text 1" },
        { "type": "select", "id": "cert_2_logo", "label": "Logo 2", "default": "none", "options": [
          { "value": "none", "label": "None" }, { "value": "vegan", "label": "The Vegan Society" },
          { "value": "fsc", "label": "FSC" }, { "value": "oeko", "label": "OEKO-TEX" } ] },
        { "type": "inline_richtext", "id": "cert_2_text", "label": "Text 2" },
        { "type": "select", "id": "cert_3_logo", "label": "Logo 3", "default": "none", "options": [
          { "value": "none", "label": "None" }, { "value": "vegan", "label": "The Vegan Society" },
          { "value": "fsc", "label": "FSC" }, { "value": "oeko", "label": "OEKO-TEX" } ] },
        { "type": "inline_richtext", "id": "cert_3_text", "label": "Text 3" }
      ]
    },
    {
      "type": "compare",
      "name": "Still undecided",
      "limit": 1,
      "settings": [
        { "type": "inline_richtext", "id": "heading", "label": "Heading", "default": "Still undecided?" },
        { "type": "text", "id": "label", "label": "Link text", "default": "See how our duvet compares" },
        { "type": "url", "id": "link", "label": "Link", "info": "Point it at the price comparison block: #compare" }
      ]
    },
    {
      "type": "price_comparison",
      "name": "Price comparison",
      "limit": 1,
      "settings": [
        { "type": "inline_richtext", "id": "heading", "label": "Heading", "default": "Sleep r<em>emarkable.</em>", "info": "The artboard turns italic mid-word — that split is yours to move." },
        { "type": "inline_richtext", "id": "subheading", "label": "Subheading", "default": "Without any compromises" },

        { "type": "header", "content": "Rows" },
        { "type": "paragraph", "content": "Three points, as drawn. Clear a label and that row is not drawn." },
        { "type": "select", "id": "row_1_icon", "label": "Icon 1", "default": "care", "options": [
          { "value": "care", "label": "Easier to care for" }, { "value": "warranty", "label": "Longer warranties" },
          { "value": "trial", "label": "Longer trial periods" } ] },
        { "type": "text", "id": "row_1_label", "label": "Label 1", "default": "Easier to care for" },
        { "type": "select", "id": "row_2_icon", "label": "Icon 2", "default": "warranty", "options": [
          { "value": "care", "label": "Easier to care for" }, { "value": "warranty", "label": "Longer warranties" },
          { "value": "trial", "label": "Longer trial periods" } ] },
        { "type": "text", "id": "row_2_label", "label": "Label 2", "default": "Longer warranties" },
        { "type": "select", "id": "row_3_icon", "label": "Icon 3", "default": "trial", "options": [
          { "value": "care", "label": "Easier to care for" }, { "value": "warranty", "label": "Longer warranties" },
          { "value": "trial", "label": "Longer trial periods" } ] },
        { "type": "text", "id": "row_3_label", "label": "Label 3", "default": "Longer trial periods" },

        { "type": "header", "content": "Link" },
        { "type": "text", "id": "link_label", "label": "Link text", "default": "See how we’re different" },
        { "type": "url", "id": "link", "label": "Link" }
      ]
    },
    {
      "type": "description",
      "name": "Description",
      "limit": 1,
      "settings": [
        { "type": "paragraph", "content": "Shows the product's own Description (from the product admin), under the title. Nothing to edit here — one block serves every product." }
      ]
    }
  ],
  "presets": [
    {
      "name": "Main product",
      "blocks": [
        { "type": "description" },
        { "type": "unit", "settings": { "unit": "cm", "label": "CM" } },
        { "type": "unit", "settings": { "unit": "in", "label": "IN" } },
        { "type": "compare" },
        { "type": "accordion", "settings": { "open_by_default": true } },
        { "type": "price_comparison" }
      ]
    }
  ]
}
