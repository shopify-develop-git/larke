{{ 'dev-pdp-guarantees.css' | asset_url | stylesheet_tag }}
{%- comment -%}
  Section: "PDP guarantees" (dev name `pdp-guarantees`).
  Figma: desktop 45068:2590 (1312x234), mobile 44850:1746 (375x388).
  Page: PDP (product). Part 3 of 3 carved out of Figma frame 45071:2617 — the other two are
  dev-sleep-grows-on-trees (the cards) and dev-naturally-best-sleep (the CTA).

  No JS: three static badges. Nothing here is interactive.

  NOT dev-trust-badges. They look alike and they are not the same component.
  dev-trust-badges (homepage) carries an ICON per badge and sits on the bare page. This one has
  no icons at all, and it nests two levels of card: a cream outer panel (--bg, Cream/100) holding
  three lighter inner tiles (--badge-bg, Cream/50 — the same colour as the page behind it). That
  nesting is the whole visual idea. Do not collapse it to one card, and do not reuse the homepage
  section here.

  TWO BACKGROUNDS, BOTH REAL.
  --bg is the outer cream panel; --badge-bg is the inner tile. The section ROOT stays transparent
  so the page shows through the gutters and the 80px top spacer, same convention as the sibling
  sections on this page.

  BOTTOM PADDING IS DESKTOP-ONLY — 64px there, 0 on mobile.
  Confirmed by node math, not inferred. On desktop the 64px is the parent frame's own bottom
  padding and it opens the gap before the reviews divider. On the Mobile artboard this frame ends
  flush at y=4213 and the reviews section starts at exactly 4213 — no gap — because the reviews
  section carries its own 48px top spacer. So mobile genuinely has none, and padding_bottom is a
  desktop-only setting here.
{%- endcomment -%}

{%- comment -%} Fixed design tokens from Figma — not merchant-controlled {%- endcomment -%}
<style>
  .pdp-guarantees {
    /* Brand params (Brief → Brand Params table). Faces are loaded by snippets/dev-brand-fonts.liquid. */
    --font-body: 'Public Sans', sans-serif;
    --font-heading: 'Test Tiempos Headline', serif;

    /* The outer panel sits inside the parent frame's 64px gutter AND its own 16px inset, so the
       panel is 1440 - 64*2 - 16*2 = 1280 wide. That total (80px) is --section-px; --container-max
       is the 1280 it produces. Mobile collapses both to a single 16px inset (343 wide panel). */
    --container-max: 1280px;
    --section-px: 80px;
    --section-px-m: 16px;

    /* Typography — desktop (Desktop/Title 4, Body/Md_Body_Medium) */
    --font-heading-size: 22px;
    --font-heading-weight: 500;
    --font-heading-lh: 1.2;
    --font-body-size: 16px;
    --font-body-weight: 500;
    --font-body-lh: 1.4;

    /* Typography — mobile: read off the Mobile artboard (Mobile/Title 4, Body/S_Body_Medium),
       not derived with a scale factor. */
    --font-heading-size-m: 20px;
    --font-body-size-m: 14px;

    /* Spacing */
    --spacing-xs: 4px;  /* badge heading -> badge text */
    --spacing-md: 24px; /* badge -> badge, desktop */
    --spacing-md-m: 16px; /* badge -> badge, mobile (the stack tightens) */
    --panel-pad: 24px;
    --badge-pad: 16px;

    /* Mobile top spacer is 48px against a desktop 80px. Scaling the merchant's own padding_top
       keeps that relationship intact if they change it. 80 * 0.6 = 48. */
    --pt-scale-m: 0.6;

    /* Layout / decoration */
    --radius-panel: 32px;
    --radius-badge: 16px;
  }
</style>

<div
  class="pdp-guarantees"
  style="
    --bg: {{ section.settings.background_color }};
    --badge-bg: {{ section.settings.badge_color }};
    --color: {{ section.settings.text_color }};
    --accent: {{ section.settings.accent_color }};
    --pt: {{ section.settings.padding_top }}px;
    --pb: {{ section.settings.padding_bottom }}px;
  "
>
  <div class="pdp-guarantees__inner">
    {%- if section.blocks.size > 0 -%}
      <ul class="pdp-guarantees__panel" role="list">
        {%- for block in section.blocks -%}
          <li class="pdp-guarantees__badge" {{ block.shopify_attributes }}>
            {%- if block.settings.heading != blank -%}
              <h3 class="pdp-guarantees__badge-heading">{{ block.settings.heading | escape }}</h3>
            {%- endif -%}

            {%- if block.settings.text != blank -%}
              <p class="pdp-guarantees__badge-text">{{ block.settings.text | escape }}</p>
            {%- endif -%}
          </li>
        {%- endfor -%}
      </ul>
    {%- endif -%}
  </div>
</div>

{% schema %}
{
  "name": "PDP guarantees",
  "tag": "section",
  "settings": [
    { "type": "header", "content": "Colors" },
    {
      "type": "color",
      "id": "background_color",
      "label": "Panel background",
      "info": "The cream panel behind the badges. The section itself stays transparent.",
      "default": "#FCF5E3"
    },
    {
      "type": "color",
      "id": "badge_color",
      "label": "Badge background",
      "info": "The lighter tile each badge sits on.",
      "default": "#FFFCF4"
    },
    { "type": "color", "id": "text_color", "label": "Text color", "default": "#333333" },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Accent color",
      "info": "Focus outlines only — this section has no button.",
      "default": "#333333"
    },

    { "type": "header", "content": "Spacing" },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px",
      "label": "Padding top",
      "info": "Scales to 60% of this on mobile (80px → 48px), matching the Mobile artboard.",
      "default": 80
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px",
      "label": "Padding bottom",
      "info": "Desktop only. The Mobile artboard has no bottom spacer here — the reviews section below carries its own.",
      "default": 64
    }
  ],
  "blocks": [
    {
      "type": "badge",
      "name": "Badge",
      "limit": 4,
      "settings": [
        { "type": "text", "id": "heading", "label": "Heading", "default": "Badge heading" },
        { "type": "textarea", "id": "text", "label": "Text", "default": "Badge text" }
      ]
    }
  ],
  "max_blocks": 4,
  "presets": [
    {
      "name": "PDP guarantees",
      "blocks": [
        {
          "type": "badge",
          "settings": { "heading": "5-year warranty", "text": "Sleep sound knowing you’re covered" }
        },
        {
          "type": "badge",
          "settings": {
            "heading": "60-night trial",
            "text": "Every tree is traced back to responsibly managed forests."
          }
        },
        {
          "type": "badge",
          "settings": { "heading": "Free delivery", "text": "Cosy comfort delivered across UK" }
        }
      ]
    }
  ]
}
{% endschema %}
