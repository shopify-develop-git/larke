{{ 'dev-site-footer.css' | asset_url | stylesheet_tag }}
{%- comment -%}
  No dev-site-footer.js: the Design Brief records Interactivity = None. The only dynamic
  element is the newsletter signup, which is a native Shopify {% form 'customer' %} submit,
  not a JS state machine. Do not add a script tag for this section.
{%- endcomment -%}

{%- comment -%}
  Fixed design tokens from Figma — not merchant-controlled.

  The Mobile artboard (44821:918) overrides many of these with its OWN measured values, so the
  mobile token block lives here too rather than in dev-site-footer.css. Reason: this <style> tag
  is emitted AFTER the stylesheet link, so at equal specificity it wins on source order — a
  `.site-footer { --token: … }` rule inside a media query in the stylesheet could never beat it.
  One declaration site, no specificity war. Layout/decoration still lives entirely in the CSS file.
{%- endcomment -%}
<style>
  .site-footer {
    /* brand params */
    --font-body: 'Public Sans', sans-serif;
    --font-heading: 'Test Tiempos Headline', serif;
    --section-px: 64px;
    /* No --container-max by design: like dev-site-header, this is full-bleed shared chrome.
       The cream card is 100% of the section frame; content is inset only by --section-px. */

    /* structure */
    --footer-top-spacer: 80px;
    --radius-card: 32px;
    --radius-button: 60px;
    --radius-input: 8px;
    --border-width: 1px;
    --border: #c4bca9;   /* bottom-bar rule + mobile payment-block rules (sampled from both artboards) */
    --divider: #c4bca9;  /* full-width divider line — mobile overrides this to #d8d1c0 */

    /* type */
    --font-heading-size: 32px;
    --font-heading-weight: 500;
    --font-heading-lh: 1.2;
    --font-heading-sm-size: 22px;
    --font-heading-sm-weight: 500;
    --font-heading-sm-lh: 1.2;
    --font-body-size: 18px;
    --font-body-lh: 1.4;
    --font-body-sm-size: 16px;
    --font-address-size: 16px;
    --font-copyright-size: 14px;
    --font-input-size: 16px;
    --font-button-size: 18px;
    --font-button-weight: 700;

    /* newsletter form */
    --input-bg: #ffffff;
    --input-padding: 18px 24px;
    --button-bg: rgba(52, 52, 52, 0.66);
    --button-color: #ffffff;
    --button-border-color: #ffffff;
    --button-padding: 18px 24px;

    /* spacing */
    --spacing-sm: 8px;
    --spacing-md: 16px;
    --spacing-lg: 24px;
    --gap-section: 64px;
    --gap-newsletter: 24px;
    --gap-form: 24px;
    --gap-heading-sub: 8px;
    --gap-columns: 32px;
    --gap-col-group: 24px;
    --gap-col-heading: 12px;
    --gap-link-list: 4px;
    --gap-menus: 32px;
    --gap-identity: 16px;
    --gap-brand: 24px;
    --gap-address: 8px;
    --gap-payments: 4px;
    --link-row-min-h: 24px;
    --payment-block-py: 40px;
    --copyright-pt: 40px;
    --bottom-bar-pt: 32px;

    /* fixed widths read off the Desktop artboard */
    --newsletter-text-w: 642px;
    --newsletter-form-w: 640px;
    /* The columns row on the 1440 artboard: 1312 (container) = 418 (brand) + 32 (gap)
       + [304 + 24 + 310 + 24 + 200] (the three right-hand columns). All four are flex BASES,
       not fixed widths — they sum to the container at 1440 so the artboard matches exactly, and
       below it every column gives up width in proportion instead of the brand column alone. */
    --col-brand-w: 418px;
    --col-group-w: 862px; /* 304 + 24 + 310 + 24 + 200 — the three right-hand columns together */
    --col-menu-w: 304px;
    --col-menu-2-w: 310px;
    --col-social-w: 200px;
    --brand-text-w: 343px;
    --logo-w: 110px;
    --logo-h: 33.016px;
    --icon-size: 24px;
    --social-gap: 14px;
  }

  @media (max-width: 768px) {
    .site-footer {
      --section-px: 16px;
      --footer-top-spacer: 48px;
      --divider: #d8d1c0; /* the two mobile divider lines really are a lighter tan than the rules */

      --font-heading-size: 24px;
      --font-heading-sm-size: 20px;
      --font-heading-sm-weight: 600; /* deliberate mobile-only Semibold — do not "fix" to 500 */
      --font-body-size: 16px;
      --font-address-size: 14px;
      --font-button-size: 16px;
      --button-padding: 12px 18px;

      --gap-section: 40px;
      --gap-newsletter: 16px;
      --gap-form: 16px;
      --gap-col-heading: 8px;
      --gap-link-list: 0px;
      --gap-address: 16px;
      --link-row-min-h: 0px;
    }
  }
</style>

<footer
  class="site-footer"
  style="
    --page-bg: {{ section.settings.page_background_color }};
    --bg: {{ section.settings.background_color }};
    --color: {{ section.settings.text_color }};
    --accent: {{ section.settings.accent_color }};
    --pt: {{ section.settings.padding_top }}px;
    --pb: {{ section.settings.padding_bottom }}px;
  "
>
  {%- comment -%}
    The 80px / 48px band above the rounded card is a real child layer of the Figma Footer frame
    (SectionPaddingD, 28764:32899). It reveals the page background behind the card's rounded top
    corners, so the root paints --page-bg and the card paints --bg.
  {%- endcomment -%}
  <div class="site-footer__content">
    {%- comment -%} ---------- newsletter ---------- {%- endcomment -%}
    <div class="site-footer__newsletter">
      {%- if section.settings.newsletter_heading != blank or section.settings.newsletter_subheading != blank -%}
        <div class="site-footer__newsletter-text">
          {%- if section.settings.newsletter_heading != blank -%}
            <h2 class="site-footer__heading">{{ section.settings.newsletter_heading }}</h2>
          {%- endif -%}
          {%- if section.settings.newsletter_subheading != blank -%}
            <p class="site-footer__subheading">{{ section.settings.newsletter_subheading | escape }}</p>
          {%- endif -%}
        </div>
      {%- endif -%}

      {%- assign newsletter_id = 'site-footer-email-' | append: section.id -%}
      {%- form 'customer', class: 'site-footer__form' -%}
        <input type="hidden" name="contact[tags]" value="newsletter">
        <div class="site-footer__form-row">
          <label class="site-footer__visually-hidden" for="{{ newsletter_id }}">
            {{ section.settings.newsletter_placeholder | escape }}
          </label>
          <input
            id="{{ newsletter_id }}"
            class="site-footer__input"
            type="email"
            name="contact[email]"
            value="{{ form.email }}"
            placeholder="{{ section.settings.newsletter_placeholder | escape }}"
            autocomplete="email"
            autocorrect="off"
            autocapitalize="off"
            spellcheck="false"
            required
          >
          <button type="submit" class="site-footer__button">
            {{- section.settings.newsletter_button_label | escape -}}
          </button>
        </div>
        {%- if form.posted_successfully? -%}
          <p class="site-footer__form-message" role="status" tabindex="-1">
            {{- 'blocks.email_signup.success' | t -}}
          </p>
        {%- endif -%}
        {%- if form.errors -%}
          <p class="site-footer__form-message" role="alert" tabindex="-1">
            {{- form.errors.translated_fields.email | capitalize }} {{ form.errors.messages.email -}}
          </p>
        {%- endif -%}
      {%- endform -%}
    </div>

    {%- comment -%} ---------- divider 1 ---------- {%- endcomment -%}
    <hr class="site-footer__divider site-footer__divider--1">

    {%- comment -%}
      ---------- columns ----------
      Desktop: [ brand (logo+tagline / address) ] [ menu · menu · social ]
      Mobile:  the three wrappers below collapse to `display: contents` so every leaf becomes a
      direct flex child of __content and CSS `order` can re-sequence them — the Mobile artboard
      genuinely REORDERS (menus, then logo, then social, then address), it does not just restack.
    {%- endcomment -%}
    <div class="site-footer__columns">
      <div class="site-footer__brand">
        <div class="site-footer__identity">
          <a class="site-footer__logo" href="{{ routes.root_url }}" aria-label="{{ shop.name | escape }}">
            <svg class="site-footer__logo-mark" viewBox="0 0 110 34" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true" focusable="false">
<g id="sf-logo-Size-lg--White-True" clip-path="url(#sf-logo-clip0_43_2171)">
