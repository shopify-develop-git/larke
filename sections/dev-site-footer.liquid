</g>
</g>
</g>
</svg>
            <span class="site-footer__address-text">{{ section.settings.address_text | escape }}</span>
          </address>
        {%- endif -%}
      </div>

      <div class="site-footer__column-group">
        {%- for block in section.blocks -%}
          {%- if block.type == 'footer_menu' -%}
            <nav
              class="site-footer__menu"
              aria-label="{{ block.settings.title | strip_html | escape }}"
              {{ block.shopify_attributes }}
            >
              {%- if block.settings.title != blank -%}
                <h3 class="site-footer__menu-heading">{{ block.settings.title }}</h3>
              {%- endif -%}

              <ul class="site-footer__menu-list" role="list">
                {%- if block.settings.menu != blank -%}
                  {%- for link in block.settings.menu.links -%}
                    <li class="site-footer__menu-item">
                      <a class="site-footer__link" href="{{ link.url }}">{{ link.title | escape }}</a>
                    </li>
                  {%- endfor -%}
                {%- else -%}
                  {%- comment -%}
                    Fallback when no navigation menu is picked: the block's own label/url pairs,
                    seeded from the Figma copy. This is what lets the section render the designed
                    link list on a store whose menus have not been set up yet.
                  {%- endcomment -%}
                  {%- for i in (1..5) -%}
                    {%- assign label_key = 'link_' | append: i | append: '_label' -%}
                    {%- assign url_key = 'link_' | append: i | append: '_url' -%}
                    {%- assign label = block.settings[label_key] -%}
                    {%- assign url = block.settings[url_key] -%}
                    {%- if label != blank -%}
                      <li class="site-footer__menu-item">
                        <a class="site-footer__link" href="{{ url | default: '#' }}">{{ label | escape }}</a>
                      </li>
                    {%- endif -%}
                  {%- endfor -%}
                {%- endif -%}
              </ul>
            </nav>
          {%- endif -%}
        {%- endfor -%}

        <div class="site-footer__social">
          {%- if section.settings.social_heading != blank -%}
            <h3 class="site-footer__social-heading">{{ section.settings.social_heading }}</h3>
          {%- endif -%}
          <ul class="site-footer__social-list" role="list">
            {%- if section.settings.social_facebook_url != blank -%}
              <li>
                <a
                  class="site-footer__social-link"
                  href="{{ section.settings.social_facebook_url }}"
                  aria-label="Facebook"
                  rel="noopener"
                  target="_blank"
                >
                  <svg class="site-footer__social-icon" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true" focusable="false">
