</svg>
          </a>
          {%- if section.settings.brand_tagline != blank -%}
            <p class="site-footer__tagline">{{ section.settings.brand_tagline | escape }}</p>
          {%- endif -%}
        </div>

        {%- if section.settings.address_text != blank -%}
          <address class="site-footer__address">
            <svg class="site-footer__address-icon" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true" focusable="false">
<g id="sf-marker-_Master-Icons">
<g id="sf-marker-Icon-Outline-location-marker">
<g id="sf-marker-Icon">
