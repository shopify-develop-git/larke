{% schema %}
{
  "name": "Footer",
  "tag": "section",
  "settings": [
    { "type": "header", "content": "Content" },
    { "type": "inline_richtext", "id": "newsletter_heading", "label": "Newsletter heading", "default": "Be the first to know." },
    { "type": "text", "id": "newsletter_subheading", "label": "Newsletter subheading", "default": "Stay in touch – only for the good stuff like new launches and offers." },
    { "type": "text", "id": "newsletter_placeholder", "label": "Email placeholder", "default": "Your Email" },
    { "type": "text", "id": "newsletter_button_label", "label": "Newsletter button label", "default": "Subscribe" },
    { "type": "text", "id": "brand_tagline", "label": "Brand tagline", "default": "Nature-based sleep for the everyday." },
    { "type": "text", "id": "address_text", "label": "Address", "default": "Monks Way, London, NW11 0AF" },
    { "type": "inline_richtext", "id": "social_heading", "label": "Social heading", "default": "Social" },
    { "type": "url", "id": "social_facebook_url", "label": "Facebook link" },
    { "type": "url", "id": "social_instagram_url", "label": "Instagram link" },
    { "type": "checkbox", "id": "show_payment_icons", "label": "Show payment icons", "default": true },
    { "type": "richtext", "id": "copyright_text", "label": "Copyright", "default": "<p>Copyright © 2026 <a href=\"https://wearelarke.com/\">Larke</a></p>" },

    { "type": "header", "content": "Colors" },
    { "type": "color", "id": "background_color", "label": "Background", "default": "#FCF5E3" },
    { "type": "color", "id": "page_background_color", "label": "Page background", "info": "Shows through the gap above the rounded card.", "default": "#FFFCF4" },
    { "type": "color", "id": "text_color", "label": "Text color", "default": "#333333" },
    { "type": "color", "id": "accent_color", "label": "Accent color", "default": "#4EA448" },

    { "type": "header", "content": "Spacing" },
    { "type": "range", "id": "padding_top", "min": 0, "max": 200, "step": 4, "unit": "px", "label": "Padding top", "default": 64 },
    { "type": "range", "id": "padding_bottom", "min": 0, "max": 200, "step": 4, "unit": "px", "label": "Padding bottom", "default": 32 }
  ],
  "blocks": [
    {
      "type": "footer_menu",
      "name": "Link column",
      "limit": 4,
      "settings": [
        { "type": "inline_richtext", "id": "title", "label": "Heading", "default": "Inside Larke" },
        { "type": "link_list", "id": "menu", "label": "Navigation menu", "info": "Optional. When set, it replaces the links below." },
        { "type": "text", "id": "link_1_label", "label": "Link 1 label", "default": "Shop Our Duvet" },
        { "type": "url", "id": "link_1_url", "label": "Link 1 URL" },
        { "type": "text", "id": "link_2_label", "label": "Link 2 label", "default": "Our Story" },
        { "type": "url", "id": "link_2_url", "label": "Link 2 URL" },
        { "type": "text", "id": "link_3_label", "label": "Link 3 label", "default": "Discover Tree-Fibre" },
        { "type": "url", "id": "link_3_url", "label": "Link 3 URL" },
        { "type": "text", "id": "link_4_label", "label": "Link 4 label" },
        { "type": "url", "id": "link_4_url", "label": "Link 4 URL" },
        { "type": "text", "id": "link_5_label", "label": "Link 5 label" },
        { "type": "url", "id": "link_5_url", "label": "Link 5 URL" }
      ]
    }
  ],
  "max_blocks": 4,
  "presets": [
    {
      "name": "Footer",
      "blocks": [
        {
          "type": "footer_menu",
          "settings": {
            "title": "Inside Larke",
            "link_1_label": "Shop Our Duvet",
            "link_2_label": "Our Story",
            "link_3_label": "Discover Tree-Fibre"
          }
        },
        {
          "type": "footer_menu",
          "settings": {
            "title": "Help Centre",
            "link_1_label": "FAQs",
            "link_2_label": "Delivery",
            "link_3_label": "Returns",
            "link_4_label": "Contact"
          }
        }
      ]
    }
  ]
}
